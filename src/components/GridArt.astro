---
// Renders an `sw.bitmap.v1` cell grid (from tools/image2bitmap.html) as a crisp,
// responsive SVG — one <rect> per cell. Centre-crops to a target aspect by
// dropping outer rows/columns, then scales to fill its container. No client JS.
//
// Props:
//   bitmap  — the parsed sw.bitmap.v1 object ({ cols, rows, cell:{size,gap,radius}, cells:[hex|null] })
//   aspect  — desired width/height of the slot (e.g. 3/2). Defaults to the art's own aspect.
//   fit     — 'width' (default: fill container width, height follows),
//             'contain' (letterbox the whole art inside the box), or
//             'cover' (fill the box in both axes, cropping the overflow — box needs a set height)
//   class   — passed through to the <svg>
//   label   — accessible label; when omitted the SVG is aria-hidden
const { bitmap, aspect, fit = 'width', class: className, label } = Astro.props;

const { cols, rows, cells } = bitmap;
const size = bitmap.cell?.size ?? 14;
const gap = bitmap.cell?.gap ?? 2;
const radius = bitmap.cell?.radius ?? 2;

// Centre-crop, in whole cells, to the requested aspect (remove rows or cols).
const target = aspect ?? cols / rows;
let vCols = cols, vRows = rows;
if (cols / rows >= target) vCols = Math.max(1, Math.round(rows * target));
else vRows = Math.max(1, Math.round(cols / target));
vCols = Math.min(vCols, cols);
vRows = Math.min(vRows, rows);
const startCol = Math.floor((cols - vCols) / 2);
const startRow = Math.floor((rows - vRows) / 2);

const pitch = size + gap;
const W = vCols * pitch - gap;
const H = vRows * pitch - gap;

const rects = [];
for (let r = 0; r < vRows; r++) {
  for (let c = 0; c < vCols; c++) {
    const hex = cells[(startRow + r) * cols + (startCol + c)];
    if (!hex) continue; // null/empty = transparent
    rects.push({ x: c * pitch, y: r * pitch, fill: hex });
  }
}
---
<svg
  class={className}
  viewBox={`0 0 ${W} ${H}`}
  width={W}
  height={H}
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  preserveAspectRatio={fit === 'cover' ? 'xMidYMid slice' : 'xMidYMid meet'}
  style={fit === 'cover'
    ? 'display:block; width:100%; height:100%;'
    : fit === 'contain'
      ? 'display:block; max-width:100%; max-height:100%; width:auto; height:auto;'
      : 'display:block; width:100%; height:auto;'}
>
  {rects.map((rc) => (
    <rect x={rc.x} y={rc.y} width={size} height={size} rx={radius} ry={radius} fill={rc.fill} />
  ))}
</svg>
