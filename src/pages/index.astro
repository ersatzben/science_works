---
import BaseLayout from '../layouts/BaseLayout.astro';
import GridArt from '../components/GridArt.astro';
import { getCover } from '../lib/covers.js';
---
<BaseLayout title="Science Works">
  <section id="splash">
    <div class="stage">
      <div class="scaler">
        <div class="matrix-wrap">
          <div id="matrix" class="matrix" role="img" aria-label="Science Works dot-matrix field"></div>
          <div class="hero-box">
            <div class="line-1">Reshaping the British</div>
            <div class="line-2">Research System</div>
            <div class="hero-actions">
              <a class="hero-btn hero-btn--primary" href="/writing">Explore Our Work</a>
              <a class="hero-btn hero-btn--secondary" href="/about">About Us</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="mobile-hero">
      <div class="mhero-hero">
        <h1 class="mhero-title">Reshaping<br>the British<br>Research<br>System</h1>
        <p class="mhero-blurb">Science Works is an independent research and policy studio aiming to tackle the biggest problems facing UK science and technology.</p>
        <div class="mhero-rule"></div>
        <div class="mhero-actions">
          <a class="mhero-btn mhero-btn--primary" href="/writing">Explore Our Work</a>
          <a class="mhero-btn mhero-btn--secondary" href="/about">About Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Spotlight: pinned intro (left) + scrolling featured projects (right) -->
  <section class="spotlight" id="projects">
    <div class="content-wrap spotlight-grid">
      <div class="spotlight-intro">
        <div class="intro-matrix" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
        <div class="intro-pic" aria-hidden="true"></div>
        <p class="intro-eyebrow">Science Works</p>
        <h2>Britain needs a metascientific revolution.</h2>
        <p>The UK's place in the world has long been underwritten by the creativity of its laboratories, workshops, and universities. Today that imagination is running into the limits of institutions built for another era. We've lost much of the freedom that once defined British science, and failed to seize the possibilities of our technological age.</p> 
        <p>We have deep talent, trusted universities, and a culture of rigour. But the systems that fund and govern research move slowly, tangled in crude metrics and misaligned incentives, while public science lags behind the private frontier.</p>
        <p>Science Works exists to change that.</p>
        <a class="hero-btn hero-btn--primary" href="/writing">Explore Our Work</a>
      </div>
      <div class="spotlight-main">
        <h2 class="section-label"><a href="/projects">featured projects</a></h2>
        <div class="projects">
        <article class="project">
          <div class="project-body">
            <h3 class="project-title">Institutional Dynamism</h3>
            <div class="project-detail">
              <p class="project-sub">The UK&rsquo;s research ecosystem is unusually homogeneous and slow to evolve</p>
              <p class="project-text"><span class="hidden">In other countries, R&amp;D is spread across a much wider range of institutional forms. </span>We want to inject diversity and dynamism into the sector &ndash; mapping <span class="hidden">the </span>institutional models<span class="hidden"> available to funders and policymakers</span>, strengthening <span class="hidden">the </span>state<span class="hidden">&rsquo;s</span> capacity<span class="hidden"> to assess and support proposals for new organisations</span>, and incubating new organisational forms<span class="hidden"> where we are best placed to do so</span>.</p>
            </div>
            <a class="project-more" href="#">More from this project &rarr;</a>
          </div>
          <div class="project-divider" aria-hidden="true"></div>
          <div class="project-img" aria-hidden="true"></div>
        </article>
        <article class="project">
          <div class="project-body">
            <h3 class="project-title">AI and Science</h3>
            <div class="project-detail">
              <p class="project-sub">Artificial intelligence is poised to change what it means to be a scientist</p>
              <p class="project-text"><span class="hidden">But the UK risks compounding existing dysfunctions rather than unlocking the gains: much of the scientific record remains invisible, research software is undervalued, and the infrastructure for AI-enabled discovery is unevenly available. </span>We are developing an ambitious British agenda for AI in science &ndash; covering data, software, automation, and <span class="hidden">the </span>institutional changes<span class="hidden"> needed to make them count</span>.</p>
            </div>
            <a class="project-more" href="#">More from this project &rarr;</a>
          </div>
          <div class="project-divider" aria-hidden="true"></div>
          <div class="project-img" aria-hidden="true"></div>
        </article>
        <article class="project">
          <div class="project-body">
            <h3 class="project-title">The Research Economy</h3>
            <div class="project-detail">
              <p class="project-sub">The UK funds research without a clear picture of its real costs and trade-offs</p>
              <p class="project-text">We bring quantitative and qualitative analysis to bear on the research base<span class="hidden">: highlighting the hidden costs, frictions, trade-offs, and cross-subsidies that underpin the economics of institutions and the architecture of national R&amp;D spending. We pair this with detailed mapping of the system&rsquo;s structure, and with practical work on the design of funding and assessment</span>, pushing for a system that is less bureaucratic, more honest, and more dynamic.</p>
            </div>
            <a class="project-more" href="#">More from this project &rarr;</a>
          </div>
          <div class="project-divider" aria-hidden="true"></div>
          <div class="project-img" aria-hidden="true"></div>
        </article>
        <article class="project">
          <div class="project-body">
            <h3 class="project-title">Software for Science</h3>
            <div class="project-detail">
              <p class="project-sub">The future of research is digital&mdash;and we need to adapt</p>
              <p class="project-text"><span class="hidden">Scientists lack modern and interoperable software tools for undertaking research in the age of intelligence. The research software engineer is a forgotten role without a clear career path. Much of the research process remains analogue; there is a lack of a well-functioning market for software; open tools are poorly maintained. </span>We are building and testing new software tools <span class="hidden">to address this gap, </span>while working on the incentives that will allow software to flourish.</p>
            </div>
            <a class="project-more" href="#">More from this project &rarr;</a>
          </div>
          <div class="project-divider" aria-hidden="true"></div>
          <div class="project-img" aria-hidden="true"></div>
        </article>
        <article class="project">
          <div class="project-body">
            <h3 class="project-title">The Story of British Science</h3>
            <div class="project-detail">
              <p class="project-sub">Scientific progress requires public confidence and political willpower</p>
              <p class="project-text">Neither is guaranteed to endure over the coming decade. <span class="hidden">The UK currently lacks a compelling, forward-looking story about what its scientific and technological future could be. </span>We want to help develop and articulate an account of British scientific renewal that can resonate<span class="hidden"> across the political spectrum</span>.</p>
            </div>
            <a class="project-more" href="#">More from this project &rarr;</a>
          </div>
          <div class="project-divider" aria-hidden="true"></div>
          <div class="project-img" aria-hidden="true"></div>
        </article>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. In Focus: one highlighted publication -->
  <section class="infocus">
    <div class="content-wrap">
      <div class="infocus-card">
        <a class="infocus-link" href="/writing/how-not-to-waste-an-ai-for-science-mission" aria-label="How not to waste an AI for science mission"></a>
        <div class="infocus-art" aria-hidden="true"><GridArt bitmap={getCover('how-not-to-waste-an-ai-for-science-mission')} aspect={3 / 2} /></div>
        <div class="infocus-meta">
          <p class="infocus-tag">In Focus</p>
          <h3 class="infocus-title">How not to waste an AI for science mission</h3>
          <p class="infocus-authors"><a href="#">Ben Johnson</a><span class="sep">,</span> <a href="#">Laura Ryan</a></p>
          <p class="infocus-sub">The government's proposed AI for Science missions will only succeed with rigorous selection criteria and proper delivery thinking. Vague, poorly-governed missions would waste public money and damage the credibility of ambitious state action.</p>
          <p class="infocus-foot"><span class="infocus-date">7 March 2026</span><span class="infocus-type">Essay</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Latest reports carousel -->
  <section class="reports">
    <div class="content-wrap">
      <div class="reports-head">
        <h2 class="section-label"><a href="/writing">latest from science works</a></h2>
        <a class="reports-viewall" href="/writing">View all &rarr;</a>
      </div>
      <div class="reports-box-wrapper">
        <div class="reports-box">
          <div class="carousel-track">
                  <div class="report-card">
            <a class="report-card-link" href="/writing/designing-ai-for-disruptive-science" aria-label="Designing AI for Disruptive Science"></a>
            <div class="report-card-art" aria-hidden="true"><GridArt bitmap={getCover('designing-ai-for-disruptive-science')} aspect={14 / 12} /></div>
            <div class="report-card-body">
              <h3 class="report-title">Designing AI for Disruptive Science</h3>
              <p class="report-authors"><a href="#">Alvin Djajadikerta</a></p>
              <p class="report-foot"><span class="report-date">23 March 2026</span><span class="report-type">Essay</span></p>
            </div>
          </div>
                  <div class="report-card">
            <a class="report-card-link" href="/writing/the-bucket-stops-here" aria-label="The Bucket Stops Here"></a>
            <div class="report-card-art" aria-hidden="true"><GridArt bitmap={getCover('the-bucket-stops-here')} aspect={14 / 12} /></div>
            <div class="report-card-body">
              <h3 class="report-title">The Bucket Stops Here</h3>
              <p class="report-authors"><a href="#">Ben Johnson</a></p>
              <p class="report-foot"><span class="report-date">14 February 2026</span><span class="report-type">Essay</span></p>
            </div>
          </div>
                  <div class="report-card">
            <a class="report-card-link" href="/writing/the-three-bucket-problem" aria-label="The three-bucket problem"></a>
            <div class="report-card-art" aria-hidden="true"><GridArt bitmap={getCover('the-three-bucket-problem')} aspect={14 / 12} /></div>
            <div class="report-card-body">
              <h3 class="report-title">The three-bucket problem</h3>
              <p class="report-authors"><a href="#">Ben Johnson</a></p>
              <p class="report-foot"><span class="report-date">18 November 2025</span><span class="report-type">Essay</span></p>
            </div>
          </div>
                  <div class="report-card">
            <a class="report-card-link" href="/writing/the-counter-reformation-of-science" aria-label="The Counter-Reformation of science"></a>
            <div class="report-card-art" aria-hidden="true"><GridArt bitmap={getCover('the-counter-reformation-of-science')} aspect={14 / 12} /></div>
            <div class="report-card-body">
              <h3 class="report-title">The Counter-Reformation of science</h3>
              <p class="report-authors"><a href="#">Ben Johnson</a></p>
              <p class="report-foot"><span class="report-date">1 September 2025</span><span class="report-type">Essay</span></p>
            </div>
          </div>
        </div>
      </div>
        <div class="carousel-arrows">
          <button class="carousel-arrow" data-dir="-1" type="button" aria-label="Previous reports">&larr;</button>
          <button class="carousel-arrow" data-dir="1" type="button" aria-label="Next reports">&rarr;</button>
        </div>
      </div>
    </div>
  </section>

<style is:global>
    /* Homepage scrolls continuously (no snap); the hero stage fills the
       viewport and simply scrolls away. */

    .section-inner {
      max-width: 800px;
      padding: 80px 50px;
      margin: 0 auto;
    }
    .section-inner--wide {
      max-width: 1400px;
    }
    .section-heading {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      color: var(--text);
      font-size: 56px;
      letter-spacing: 0.02em;
      margin: 0 0 24px;
    }
    .section-body {
      font-family: 'Antique Olive', sans-serif;
      font-size: 18px;
      font-weight: 300;
      line-height: 1.5;
      color: var(--text);
      margin: 0 0 16px;
    }

    /* ===================================================================
       Homepage content sections (continuous scroll, IFP-style)
       =================================================================== */
    .content-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 40px;
      box-sizing: border-box;
    }
    .section-label {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      font-size: 28px;
      letter-spacing: 0.02em;
      color: var(--text);
      margin: 0 0 15px;
    }
    .section-label a { color: var(--theme); text-decoration: none; border-bottom: 1px solid var(--theme); padding: 0 0 3px;}
    .section-label a:hover { border-bottom-width: 3px; }

    /* ---------- Spotlight: pinned intro (left) + scrolling projects (right) ---------- */
    .spotlight { 
      padding: 70px 0 56px; 
      background-color: var(--almost-white);
    }

    .spotlight-grid {
      display: grid;
      grid-template-columns: minmax(280px, 1.5fr) 1.55fr;   /* intro col ~25% wider */
      gap: 56px;
      align-items: start;
    }
    .spotlight-intro {
      position: sticky;
      top: 140px;                   /* sticky threshold — freezes 80px below viewport top (clears the 60px nav) */
      margin-top: 70px;            /* initial gap before the intro */
      align-self: start;
      padding-left: 70px; 
      padding-right: 20px;
    }
    /* Decorative 7x2 dot grid, top-left of the intro. Anchored to the
       container's top-left corner; nudge it anywhere (incl. outside the
       container) with the margins below — negative values are fine. */
    .intro-matrix {
      position: absolute;
      top: 0;
      left: 0;
      margin: -65px 0 0 -40px;      /* top right bottom left — move the grid with these */
      display: grid;
      grid-template-columns: repeat(7, var(--small-block-size));
      grid-auto-rows: var(--small-block-size);
      gap: var(--small-block-gap);
    }
    .intro-matrix span {
      background: var(--border-grey);
      border-radius: var(--small-block-radius);
    }
    .intro-eyebrow { display: none; }   /* mobile-only (shown in the 600px query) */
    .intro-pic { display: none; }       /* mobile-only (shown in the 600px query) */
    .spotlight-intro h2 {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      font-size: 30px;
      letter-spacing: 0.02em;
      color: var(--text);
      margin: 0 0 20px;
    }
    .spotlight-intro p {
      font-family: 'Antique Olive', sans-serif;
      font-size: 15px;
      line-height: 1.6;
      color: var(--text);
      margin: 0 0 16px;
      max-width: 520px;     /* use the now-wider column */
    }
    .spotlight-intro .hero-btn { margin-top: 8px; }

    .projects { display: flex; flex-direction: column; gap: 22px; padding-right: 55px; }
    .project {
      display: flex;
      gap: 28px;
      align-items: stretch;
      background: var(--bg);
      border: 1px solid var(--border-grey);
      border-radius: 6px;
      padding: 24px 24px;
      box-sizing: border-box;
    }
    .project-body { flex: 1; min-width: 0; display: flex; flex-direction: column; }
    .project-title {
      font-family: 'Copperplate', serif;
      font-weight: 600;
      font-size: 22px;
      line-height: 1.15;
      color: var(--text);
      margin: 0 0 6px;
    } 
    .project-sub {
      font-family: 'Playfair Display', serif;
      font-weight: bold;
      font-size: 16px;
      letter-spacing: 0.01em;
      line-height: 1.4;
      color: var(--text);
      margin: 0 0 12px;
    }
    .project-text {
      font-family: 'Antique Olive', sans-serif;
      font-size: 13px;
      line-height: 1.55;
      color: var(--text);
      margin: 0;
    }
    .project-detail {
      border-left: 1px solid var(--border-grey);
      padding-left: 16px;
      margin-top: 0px;
      padding-bottom: 8px;
    }
    .project-more {
      font-family: 'Roboto', sans-serif;
      display: inline-block;
      align-self: flex-start;   /* content-width within the flex column */
      margin-top: auto;         /* push to the bottom of the card */
      margin-left: 16px;
      font-family: var(--button-text);
      font-weight: 500;
      font-size: 16px;
      letter-spacing: 0.01em;
      color: var(--theme);
      text-decoration: none;
    }
    .project-more:hover { text-decoration: underline; }
    .project-divider {
      flex: 0 0 auto;
      width: 1px;
      align-self: stretch;
      background: var(--border-grey);
      margin: -24px 0;            /* extend to the card's top/bottom edges through the padding */
    }
    /* Procedural dot-matrix filling the card's right panel. The column count
       fixes the panel width; the row count is computed in JS to fit the card
       height in WHOLE cells, so differing card heights never slice a pixel.
       One colour for now. */
    .project-img {
      flex: 0 0 auto;
      align-self: stretch;              /* panel height = card content height */
      --card-pix-cols: 11;              /* columns → drives the panel width */
      --card-pix-cell: var(--small-block-size);   /* pixel size */
      --card-pix-gap: var(--small-block-gap);      /* spacing between pixels */
      --card-pix-color: var(--border-grey);   /* single fill colour for now */
      width: calc(var(--card-pix-cols) * var(--card-pix-cell)
                  + (var(--card-pix-cols) - 1) * var(--card-pix-gap));
      display: grid;
      grid-template-columns: repeat(var(--card-pix-cols), var(--card-pix-cell));
      grid-auto-rows: var(--card-pix-cell);
      gap: var(--card-pix-gap);
      align-content: start;             /* pack pixels from the top down */
      overflow: hidden;
    }

    /* ---------- In Focus: one highlighted publication ---------- */
    .infocus { padding: 45px 0 45px; }
    /* Fixed max width, left-aligned to the content-wrap's left edge. Room is
       left to the right of the card for future content (tune width later). */
    .infocus-card {
      position: relative;               /* contains the stretched whole-card link */
      display: flex;
      align-items: stretch;
      max-width: 860px;
      min-height: 300px;
      background: var(--almost-white);
      border: 1px solid var(--border-grey);
      border-radius: 14px;
      overflow: hidden;
      cursor: pointer;
    }
    /* 2px red edge on hover via an inset ring (border stays 1px → no layout shift, no animation). */
    .infocus-card:hover {
      border-color: var(--theme);
      box-shadow: inset 0 0 0 1px var(--theme);
    }
    /* Stretched link covers the whole card; author links sit above it. */
    .infocus-link { position: absolute; inset: 0; z-index: 1; }
    /* Picture replaced by a whole-cell dot grid (filled by the shared JS),
       with a margin of card-background around the pixels. */
    .infocus-pix {
      flex: 0 0 auto;
      align-self: center;               /* stay vertically centred if the card grows */
      margin: 24px;                     /* whitespace around the pixels */
      --card-pix-cols: 24;              /* exact column count */
      --card-pix-rows: 16;              /* exact row count */
      --card-pix-cell: var(--cell-size);     /* hero grid size (14px) */
      --card-pix-gap: var(--cell-gap);       /* hero grid spacing (2px) */
      --card-pix-radius: var(--cell-radius); /* hero grid radius (2px) */
      --card-pix-color: var(--border-grey);
      width: calc(var(--card-pix-cols) * var(--card-pix-cell)
                  + (var(--card-pix-cols) - 1) * var(--card-pix-gap));
      display: grid;
      grid-template-columns: repeat(var(--card-pix-cols), var(--card-pix-cell));
      grid-auto-rows: var(--card-pix-cell);
      gap: var(--card-pix-gap);
      overflow: hidden;
    }
    /* Grid-art cover: occupies the same left slot as the dot grid it replaces. */
    .infocus-art { flex: 0 0 360px; align-self: center; margin: 20px; }
    .infocus-meta {
      flex: 1;
      min-width: 0;
      padding: 0px 36px 0px 4px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .infocus-tag {
      font-family: 'Antique Olive', sans-serif;
      font-weight: bold;
      font-size: 13px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text);
      margin: 2px 0 18px;
    }
    .infocus-title {
      font-family: 'Playfair Display', serif;
      font-weight: 300;
      font-size: 26px;
      line-height: 1.12;
      color: var(--text);
      margin: 0 0 12px;
    }
    .infocus-authors {
      font-family: 'Roboto', sans-serif;
      font-weight: bold;
      font-size: 17px;
      color: var(--theme);
      margin: 0 0 14px;
    }
    .infocus-authors a { color: var(--theme); text-decoration: none; position: relative; z-index: 2; }
    .infocus-authors a:hover { text-decoration: underline; }
    .infocus-authors .sep { color: var(--theme); }
    .infocus-sub {
      font-family: 'Antique Olive', sans-serif;
      font-size: 13px;
      line-height: 1.5;
      color: var(--text);
      margin: 0 0 6px;
    }
    .infocus-foot {
      display: flex;
      gap: 40px;                        /* the gap between Date and Essay */
      font-family: 'Antique Olive', sans-serif;
      font-size: 13px;
      color: var(--text);
      margin: 0;
    }

    /* ---------- Latest reports carousel ---------- */
    .reports { padding: 0 0 40px; }

    .reports-box-wrapper { padding: 0 30px; }
    .reports-box {
      position: relative;               /* anchors the overlaid arrows */
      border: 1px solid var(--border-grey);
      border-radius: 14px;
      padding: 28px 28px 18px;
    }
    .reports-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 18px;
    }
    .reports-head .section-label { margin: 0; }
    .reports-viewall {
      font-family: var(--button-text);
      font-weight: 500;
      font-size: 14px;
      color: var(--theme);
      text-decoration: none;
      white-space: nowrap;
    }
    .reports-viewall:hover { text-decoration: underline; }
    /* Arrows overlaid on the left/right edges of the cards, vertically centred. */
    /* Wrapper generates no box; the buttons position themselves against
       reports-box directly. */
    .carousel-arrows { display: contents; }
    /* Each arrow is pinned to its edge BY ROLE (data-dir), so prev is always
       left and next always right — independent of DOM/flex order. Only the
       42px buttons intercept pointers, so the gap between them stays draggable. */
    .carousel-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 3;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: 1.5px solid var(--theme);
      background: #fff;
      color: var(--theme);
      font-size: 18px;
      line-height: 1;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 1px 4px rgba(0,0,0,0.12);   /* lift off the cards underneath */
      transition: background-color 0.15s ease, color 0.15s ease;
    }
    .carousel-arrow[data-dir="-1"] { left: 10px; }    /* prev: always the left edge */
    .carousel-arrow[data-dir="1"]  { right: 10px; }   /* next: always the right edge */
    .carousel-arrow:hover { background: var(--theme); color: #fff; }
    /* Hidden (not just dimmed) at the corresponding end. */
    .carousel-arrow:disabled { visibility: hidden; }
    .carousel-track {
      display: flex;
      gap: 20px;
      overflow-x: auto;
      scroll-snap-type: x proximity;
      scroll-behavior: smooth;
      padding: 2px 2px 10px;
      scrollbar-width: none;
      cursor: grab;
    }
    .carousel-track::-webkit-scrollbar { display: none; }
    .carousel-track.dragging { cursor: grabbing; scroll-behavior: auto; }
    .report-card {
      position: relative;               /* contains the stretched whole-card link */
      flex: 0 0 212px;                  /* narrower; = 14-col grid (179px) + 2*16 padding */
      scroll-snap-align: start;
      background: var(--almost-white);
      border: 1px solid var(--border-grey);
      border-radius: 12px;
      overflow: hidden;
      padding: 16px;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
    }
    .report-card-link { position: absolute; inset: 0; z-index: 1; }   /* whole card clickable */
    /* Pixel-art image: fixed 14x12 grid at the small block size, filled by the shared JS. */
    .report-card-pix {
      --card-pix-cols: 14;
      --card-pix-rows: 12;
      --card-pix-cell: var(--small-block-size);
      --card-pix-gap: var(--small-block-gap);
      --card-pix-radius: var(--small-block-radius);
      --card-pix-color: var(--border-grey);
      width: calc(var(--card-pix-cols) * var(--card-pix-cell)
                  + (var(--card-pix-cols) - 1) * var(--card-pix-gap));
      display: grid;
      grid-template-columns: repeat(var(--card-pix-cols), var(--card-pix-cell));
      grid-auto-rows: var(--card-pix-cell);
      gap: var(--card-pix-gap);
      margin-bottom: 16px;
    }
    /* Grid-art cover: fills the card's content width, cropped to the card shape. */
    .report-card-art { width: 100%; margin-bottom: 16px; }
    .report-card-body { flex: 1; display: flex; flex-direction: column; }
    .report-title {
      font-family: 'Playfair Display', serif;
      font-weight: 600;
      font-size: 18px;
      line-height: 1.2;
      color: var(--text);
      margin: 0 0 10px;
    }
    /* Authors styled like the In Focus card: red links, red comma separator. */
    .report-authors {
      font-family: 'Antique Olive', sans-serif;
      font-size: 13px;
      margin: 0 0 12px;
    }
    .report-authors a { color: var(--theme); text-decoration: none; position: relative; z-index: 2; }
    .report-authors a:hover { text-decoration: underline; }
    .report-authors .sep { color: var(--theme); }
    /* Date (left) and type (right, e.g. "Essay"), pinned to the bottom of the card. */
    .report-foot {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 12px;
      font-family: 'Antique Olive', sans-serif;
      font-size: 12px;
      color: var(--text);
      margin: auto 0 0;          /* top:auto pushes it to the card bottom */
    }


    /* ---------- Mobile hero (phones): 3-col × 6-row pixel-block grid ---------- */
    .mobile-hero { display: none; }
    @media (max-width: 600px) {
      #splash .stage { display: none; }
      #splash {
        box-sizing: border-box;
        padding: 14px 0 6px;     /* content height, not full viewport — next section peeks up */
      }
      .mobile-hero {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 9px;
        width: 100%;
        padding: 10px 14px 30px;
        box-sizing: border-box;
      }
      .mhero-block {
        aspect-ratio: 190 / 174;
        align-self: center;
        transform: scale(0.86);    /* shrink toward centre -> equal H & V whitespace;
                                     full-size layout box also gives more vertical room */
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-template-rows: repeat(11, 1fr);
        gap: 1px;
      }
      .mhero-cell { border-radius: 1.5px; background: var(--bg); }
      /* hero (title + blurb + buttons) fills cols 2-3, rows 2-4 (2x3), no border */
      .mhero-hero {
        grid-column: 2 / 4;
        grid-row: 2 / 5;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 6px 4px 6px 14px;
      }
      .mhero-title {
        font-family: 'Copperplate', serif;
        font-weight: 700;
        color: var(--text);
        font-size: 32px;
        line-height: 1.1;
        margin: 20px 0 0;
        
      }
      .mhero-blurb {
        font-family: 'Antique Olive', sans-serif;
        font-weight: 300;
        color: var(--text);
        font-size: 11px;
        line-height: 1.45;
        margin: 20px 20px 0 0;
      }
      /* red rule between blurb and buttons — move it with these margins */
      .mhero-rule { border-top: 1px solid var(--theme); margin: 16px 120px 26px 0px; }
      .mhero-actions { display: flex; gap: 7px; margin-top: 14px; margin-right: 10px; margin-bottom: 3px;}
      .mhero-btn {
        font-family: var(--button-text);
        font-size: 11px;
        text-align: center;
        text-decoration: none;
        box-sizing: border-box;
        flex: 1 1 0;          /* side by side, equal width */
        min-width: 0;
        border: 1.5px solid var(--theme);
        border-radius: 5px;
        padding: 5px 0px;
        white-space: nowrap;
  
      }
      .mhero-btn--primary { background: var(--theme); color: #fff; }
      .mhero-btn--secondary { background: #fff; color: var(--theme); }

      /* ----- rest of the homepage, reformatted for phones ----- */
      .content-wrap { padding: 0 18px; }
      .section-label { font-size: 22px; margin-bottom: 16px; }

      .spotlight {
        padding-top: 40px; 
        padding-bottom: 20px;
        }

      .spotlight-intro {  
        margin: 0; 
        padding: 0 10px 0;
      }

      .spotlight-intro .intro-eyebrow {
        display: block;
        font-family: var(--button-text);
        font-weight: 500;
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--theme);
        margin: 0 0 12px;
      }

      /* Picture floated top-right; heading + paragraphs flow around it. */
      .intro-pic {
        display: block;
        float: right;
        width: 44%;
        aspect-ratio: 5 / 4;
        background: var(--border-grey);   /* grey placeholder box */
        border-radius: 4px;
        margin: 0 0 10px 16px;            /* gap below + left of the wrapping text */
      }

      .spotlight-intro h2 {
        font-size: 20px;
        letter-spacing: 0.02em;
        color: var(--text);
        margin: 0 0 14px;
      }

      .spotlight-intro p { font-size: 12px; }

      /* Projects become a horizontal, swipeable carousel on mobile. */
      .spotlight-main { min-width: 0; }   /* let the grid item shrink so the carousel can overflow-scroll instead of stretching the column */
      .projects {
        flex-direction: row;
        gap: 14px;
        padding: 2px 0 14px;            /* content-wrap already insets 18px each side */
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
      }
      .projects::-webkit-scrollbar { display: none; }
      .project {
        flex: 0 0 90%;                  /* one card per view, next card peeks */
        scroll-snap-align: start;
        gap: 16px;
        padding: 15px;
      }
      .project-img { --card-pix-cols: 8; }   /* narrower dot strip to fit the card */
      .project-title { font-size: 16px; }
      .project-detail { padding-left: 7px;}
      .project-sub { font-size: 13px; }
      .project-text { font-size: 10px; }
      .project-more { margin-top: auto; margin-left: 0; font-size: 12px; }
      .project-divider { margin: -16px 0; }
      .hidden { display: none;}

      .infocus { padding: 24px 0 24px; background-color: var(--theme);}
      .infocus-card { flex-direction: column; min-height: 0; border-radius: 0; }
      .infocus-meta { padding: 22px 22px 10px; }
      .infocus-tag { margin: 0 0 10px; }
      .infocus-title { font-size: 22px; }
      .infocus-authors { font-size: 14px; }
      .infocus-sub { font-size: 13px; margin-bottom: 14px; }
      .infocus-foot { font-size: 12px;}
      .infocus-pix { margin: 0; }
      .infocus-art { flex: none; width: 100%; margin: 0; }

      .reports { padding: 14px 0 24px; }
      .reports-box { padding: 10px; border-radius: 8px; }
      .reports-head .section-label {  }
      .reports-viewall {display: none;}

      .carousel-arrows { display: none; }
      /* Horizontal swipe carousel on mobile (like the projects carousel);
         cards keep their 212px design width so the dot grid still fills them. */
      .carousel-track { scroll-snap-type: x mandatory; gap: 14px; padding: 4px 0 4px;}


    }

    @media (max-width: 900px) {
      .spotlight-grid { grid-template-columns: 1fr; gap: 34px; }
      .spotlight-intro { position: static; top: auto; }
    }
</style>

<script is:inline>
    (function () {
      const COLS = 12;
      const ROWS = 11;
      const MATRIX_COLS = 6;
      const MATRIX_ROWS = 3;
      const GRID_COUNT = MATRIX_COLS * MATRIX_ROWS;

      // Brand palette, exposed so JS can address cells by colour name later.
      const PALETTE = {
        bg: '#f6f0ed',
        text: '#66223b',
        theme: '#eb3131',
        sage: '#00726b',
        brightBlue: '#004ee6',
        paleBlue: '#a3c0d7',
        lightGreen: '#64b37b',
        deepGreen: '#0e676a',
        coral: '#f45e57',
        beige: '#ebe5cf',
        almostWhite: '#faf8f6',
        purpleBlue: '#4b5cce',
        darkestBrown: '#440214',
        opt1: '#3a3c7c',
        opt2: '#72679b',
      };

      const matrixEl = document.getElementById('matrix');

      // grids[i].cells[row][col] -> HTMLElement
      // grids[i].el                -> grid container
      const grids = [];

      function buildGrid() {
        const gridEl = document.createElement('div');
        gridEl.className = 'grid';
        const cells = [];
        for (let r = 0; r < ROWS; r++) {
          const rowArr = [];
          for (let c = 0; c < COLS; c++) {
            const el = document.createElement('div');
            el.className = 'cell';
            el.dataset.row = r;
            el.dataset.col = c;
            gridEl.appendChild(el);
            rowArr.push(el);
          }
          cells.push(rowArr);
        }
        return { el: gridEl, cells };
      }

      for (let i = 0; i < GRID_COUNT; i++) {
        const g = buildGrid();
        g.el.dataset.index = i;
        matrixEl.appendChild(g.el);
        grids.push(g);
      }

      // Helpers exposed for future animation code.
      function setCell(gridIdx, row, col, color) {
        const el = grids[gridIdx]?.cells[row]?.[col];
        if (el) el.style.background = color;
      }

      function setAll(color) {
        for (let i = 0; i < grids.length; i++) {
          for (let r = 0; r < ROWS; r++) {
            for (let c = 0; c < COLS; c++) grids[i].cells[r][c].style.background = color;
          }
        }
      }

      // ----- Pixel art loading + dissolve animation --------------------
      // Editor stores under this key. Palette order matches the editor's
      // stored data exactly — DO NOT reorder.
      const ART_STORAGE_KEY = 'sw.pixelart.v1';
      const ART_PALETTE = [
        '#f6f0ed', // 0 empty / bg
        '#66223b', // 1 text
        '#eb3131', // 2 theme
        '#00726b', // 3 sage
        '#004ee6', // 4 brightBlue
        '#a3c0d7', // 5 paleBlue
        '#64b37b', // 6 lightGreen
        '#0e676a', // 7 deepGreen
        '#f45e57', // 8 coral
        '#ebe5cf', // 9 beige
        '#faf8f6', // 10 almostWhite
        '#4b5cce', // 11 purpleBlue
        '#440214', // 12 darkestBrown
        '#3a3c7c', // 13 opt1
        '#72679b', // 14 opt2
      ];

      const TOTAL_CELLS = COLS * ROWS; // 132
      const HERO_SLOTS = new Set([7, 8, 9, 10]);
      const EDITABLE_SLOTS = [];
      for (let i = 0; i < grids.length; i++) {
        if (!HERO_SLOTS.has(i)) EDITABLE_SLOTS.push(i);
      }

      // Per-slot current cell data (palette indices). Mutated by swaps so
      // each pair oscillates between its two states over time.
      const slotData = grids.map(() => new Array(TOTAL_CELLS).fill(0));

      function ingestArt(art) {
        for (let i = 0; i < grids.length; i++) {
          slotData[i] = new Array(TOTAL_CELLS).fill(0);
        }
        if (!art?.grids || art.grids.length !== EDITABLE_SLOTS.length) return;
        for (let ei = 0; ei < EDITABLE_SLOTS.length; ei++) {
          const data = art.grids[ei];
          if (Array.isArray(data) && data.length === TOTAL_CELLS) {
            slotData[EDITABLE_SLOTS[ei]] = data.slice();
          }
        }
      }

      function renderSlot(slotIdx) {
        const data = slotData[slotIdx];
        const cells = grids[slotIdx].cells;
        for (let i = 0; i < TOTAL_CELLS; i++) {
          const r = (i / COLS) | 0;
          const c = i % COLS;
          cells[r][c].style.background = ART_PALETTE[data[i]] || ART_PALETTE[0];
        }
      }

      function renderAll() {
        for (let i = 0; i < grids.length; i++) renderSlot(i);
      }

      const ART_FILE_URL = '/assets/pixel_art/splash.json';

      function loadArtLocal() {
        try {
          const raw = localStorage.getItem(ART_STORAGE_KEY);
          return raw ? JSON.parse(raw) : null;
        } catch (_) { return null; }
      }

      async function loadArtFile() {
        try {
          const resp = await fetch(ART_FILE_URL, { cache: 'no-cache' });
          if (!resp.ok) return null;
          return await resp.json();
        } catch (_) { return null; }
      }

      // localStorage wins when present (so the editor's live drafts show
      // up in the splash during dev). Falls back to the committed file
      // when there's no draft — which is the production path.
      async function loadArt() {
        return loadArtLocal() || await loadArtFile();
      }

      // ----- Pair selection --------------------------------------------
      const FIXED_PAIRS = [[0, 12], [5, 17]];

      function buildPairs() {
        const used = new Set(FIXED_PAIRS.flat());
        const remaining = EDITABLE_SLOTS.filter(s => !used.has(s));
        // Fisher–Yates shuffle on the remaining 10 slots.
        for (let i = remaining.length - 1; i > 0; i--) {
          const j = (Math.random() * (i + 1)) | 0;
          [remaining[i], remaining[j]] = [remaining[j], remaining[i]];
        }
        const pairs = FIXED_PAIRS.map(p => p.slice());
        for (let i = 0; i + 1 < remaining.length; i += 2) {
          pairs.push([remaining[i], remaining[i + 1]]);
        }
        return pairs;
      }

      // ----- Dissolve animation ----------------------------------------
      const DISSOLVE_MS = 20000;        // per-swap dissolve window
      const SWAP_INTERVAL_MS = 120000;   // time between swaps for one pair
      const PAIR_STAGGER_MS = 7000;     // offset between pairs' first swap
      const FIRST_SWAP_DELAY_MS = 2000;

      // Generation counter lets in-flight setTimeouts no-op when art reloads.
      let animGen = 0;
      let activeIntervals = [];

      function stopAnimations() {
        animGen++;
        activeIntervals.forEach(clearInterval);
        activeIntervals = [];
      }

      function dissolveSwap(a, b, gen) {
        for (let i = 0; i < TOTAL_CELLS; i++) {
          const delay = Math.random() * DISSOLVE_MS;
          setTimeout(() => {
            if (gen !== animGen) return;
            const tmp = slotData[a][i];
            slotData[a][i] = slotData[b][i];
            slotData[b][i] = tmp;
            const r = (i / COLS) | 0;
            const c = i % COLS;
            grids[a].cells[r][c].style.background = ART_PALETTE[slotData[a][i]] || ART_PALETTE[0];
            grids[b].cells[r][c].style.background = ART_PALETTE[slotData[b][i]] || ART_PALETTE[0];
          }, delay);
        }
      }

      function startAnimations() {
        const pairs = buildPairs();
        const gen = animGen;
        pairs.forEach((pair, idx) => {
          const startDelay = FIRST_SWAP_DELAY_MS + idx * PAIR_STAGGER_MS;
          setTimeout(() => {
            if (gen !== animGen) return;
            dissolveSwap(pair[0], pair[1], gen);
            const intervalId = setInterval(() => {
              if (gen !== animGen) { clearInterval(intervalId); return; }
              dissolveSwap(pair[0], pair[1], gen);
            }, SWAP_INTERVAL_MS);
            activeIntervals.push(intervalId);
          }, startDelay);
        });
      }

      function paintFromArt(art) {
        stopAnimations();
        ingestArt(art);
        renderAll();
        startAnimations();
      }

      loadArt().then(paintFromArt);

      // Auto-refresh when the editor saves in another tab.
      window.addEventListener('storage', (e) => {
        if (e.key === ART_STORAGE_KEY) loadArt().then(paintFromArt);
      });

      // Proportional scaling: shrink the whole composition when the viewport
      // is narrower than its natural width. Mobile layout (fewer grids) TBD.
      const NATURAL_W = 1390;
      const VIEWPORT_PAD = 100;
      function updateScale() {
        const available = window.innerWidth - VIEWPORT_PAD;
        const scale = Math.min(1, available / NATURAL_W);
        document.documentElement.style.setProperty('--scale', scale);
      }
      window.addEventListener('resize', updateScale);
      updateScale();

      // Expose for console tinkering / future modules.
      window.SW = {
        grids, PALETTE, setCell, setAll,
        COLS, ROWS, MATRIX_COLS, MATRIX_ROWS,
        updateScale,
        ART_PALETTE, HERO_SLOTS, EDITABLE_SLOTS,
        slotData, loadArt, loadArtLocal, loadArtFile, paintFromArt,
        buildPairs, dissolveSwap,
        stopAnimations, startAnimations,
      };
    })();

    // ----- Mobile hero: render the 8 pixel-art blocks (same art as desktop) --
    (function () {
      const host = document.querySelector('.mobile-hero');
      if (!host || !window.SW) return;
      const PAL = window.SW.ART_PALETTE;
      const TOTAL = 132, N = 6;
      const blocks = [];
      for (let b = 0; b < N; b++) {
        const el = document.createElement('div');
        el.className = 'mhero-block';
        const cells = [];
        for (let i = 0; i < TOTAL; i++) {
          const cell = document.createElement('div');
          cell.className = 'mhero-cell';
          el.appendChild(cell);
          cells.push(cell);
        }
        host.appendChild(el);
        blocks.push(cells);
      }
      function render(art) {
        const grids = (art && art.grids) || [];
        for (let b = 0; b < N; b++) {
          const data = grids[b] || [];
          const cells = blocks[b];
          for (let i = 0; i < TOTAL; i++) cells[i].style.background = PAL[data[i]] || PAL[0];
        }
      }
      window.SW.loadArt().then(render);
    })();

    // ----- Spotlight cards: fill each right panel with a whole-cell dot grid -
    (function () {
      const panels = document.querySelectorAll('.project-img, .infocus-pix, .report-card-pix');
      if (!panels.length) return;

      function fill(el) {
        const cs = getComputedStyle(el);
        const cols = parseInt(cs.getPropertyValue('--card-pix-cols'), 10) || 11;
        const cell = parseFloat(cs.getPropertyValue('--card-pix-cell')) || 10;
        const gap  = parseFloat(cs.getPropertyValue('--card-pix-gap'))  || 3;
        const fixedRows = parseInt(cs.getPropertyValue('--card-pix-rows'), 10);
        // Fixed row count if declared; otherwise fit whole rows to the height
        // (last partial cell dropped, never sliced).
        const rows = fixedRows > 0
          ? fixedRows
          : Math.max(0, Math.floor((el.clientHeight + gap) / (cell + gap)));
        const need = rows * cols;
        let have = el.childElementCount;
        if (have === need) return;
        while (el.childElementCount > need) el.removeChild(el.lastChild);
        if (have < need) {
          const frag = document.createDocumentFragment();
          for (let i = have; i < need; i++) {
            const c = document.createElement('div');
            c.className = 'pix-cell';
            frag.appendChild(c);
          }
          el.appendChild(frag);
        }
      }

      // Re-fill whenever a panel's height changes (font load, reflow, resize).
      const ro = new ResizeObserver(function (entries) {
        for (const e of entries) fill(e.target);
      });
      panels.forEach(function (el) { fill(el); ro.observe(el); });
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function () { panels.forEach(fill); });
      }
    })();

    // ----- Latest reports carousel: arrow controls + drag-to-scroll ------
    (function () {
      const track = document.querySelector('.carousel-track');
      if (!track) return;
      const prev = document.querySelector('.carousel-arrow[data-dir="-1"]');
      const next = document.querySelector('.carousel-arrow[data-dir="1"]');

      function stepWidth() {
        const card = track.querySelector('.report-card');
        return card ? card.getBoundingClientRect().width + 20 : 320;
      }
      function updateArrows() {
        // Tolerance band: scroll-snap + the track's 2px padding leave "home" a
        // few px off 0 (and likewise at the far end), so an exact test misses.
        // 8px is comfortably under a card width, so it never misfires mid-scroll.
        const EDGE = 8;
        const max = track.scrollWidth - track.clientWidth;
        if (prev) prev.disabled = track.scrollLeft <= EDGE;
        if (next) next.disabled = track.scrollLeft >= max - EDGE;
      }
      if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -stepWidth(), behavior: 'smooth' }); });
      if (next) next.addEventListener('click', function () { track.scrollBy({ left: stepWidth(), behavior: 'smooth' }); });
      track.addEventListener('scroll', updateArrows, { passive: true });
      window.addEventListener('resize', updateArrows);
      window.addEventListener('load', updateArrows);
      // Re-check once card images load and reflow the track width.
      if (window.ResizeObserver) new ResizeObserver(updateArrows).observe(track);
      updateArrows();

      // Drag / swipe to scroll.
      let down = false, startX = 0, startLeft = 0, moved = false;
      track.addEventListener('pointerdown', function (e) {
        if (e.pointerType !== 'mouse') return;   // touch/pen use native scroll (no manual drag)
        down = true; moved = false;
        startX = e.clientX; startLeft = track.scrollLeft;
        track.classList.add('dragging');
        track.setPointerCapture(e.pointerId);
      });
      track.addEventListener('pointermove', function (e) {
        if (!down) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4) moved = true;
        track.scrollLeft = startLeft - dx;
      });
      function release() { down = false; track.classList.remove('dragging'); }
      track.addEventListener('pointerup', release);
      track.addEventListener('pointercancel', release);
      // Suppress the click that follows a drag so cards don't navigate.
      track.addEventListener('click', function (e) {
        if (moved) { e.preventDefault(); e.stopPropagation(); }
      }, true);
    })();

    // ----- Intro matrix: colour the 7x2 decorative grid from a motif ----
    (function () {
      const grid = document.querySelector('.intro-matrix');
      if (!grid) return;
      const MOTIF = '1335513' + '5122403';   // 7 cols x 2 rows, row-major
      const COLOURS = {
        '0': 'var(--almost-white)',
        '1': 'var(--beige)',
        '2': 'var(--bright-blue)',
        '3': 'var(--theme)',
        '4': 'var(--pale-blue)',
        '5': 'var(--coral)',
      };
      const spans = grid.children;
      for (let i = 0; i < spans.length && i < MOTIF.length; i++) {
        const c = COLOURS[MOTIF[i]];
        if (c) spans[i].style.background = c;
      }
    })();
</script>
