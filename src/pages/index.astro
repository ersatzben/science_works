    .rr-promo-l2 { font-size: 60px; }
    .rr-rule { display: block; height: 2px; background: rgba(255,255,255,0.5); margin-top: 16px; }
    /* pixel-square motifs */
    .rr-pix { display: inline-flex; gap: 12px; margin-left: 27px; }
    .rr-pix i { width: 10px; height: 10px; background: var(--almost-white); }
    .rr-pix i.m { background: rgb(255, 255, 255, 0.75); }
    .rr-pix i.o { background: rgb(255, 255, 255, 0.5); }
    .rr-footpix { display: inline-grid; grid-template-columns: repeat(4, 8px); gap: 5px; margin-left: 50px; margin-top: 10px;  }
    .rr-footpix i { width: 9px; height: 9px; background:  rgb(255, 255, 255, 0.75); }
    .rr-footpix i.o { background:  rgb(255, 255, 255, 0.5); }

    /* Right cards */
    .rr-promo-cards { display: grid; grid-template-columns: 1fr 1fr; }
    .rr-promo-col { display: flex; flex-direction: column; }   /* content grows; essay's strip pins to the bottom */
    .rr-col-content { flex: 1 1 auto; padding: 20px 28px; }
    .rr-card-icon { display: block; height: 18px; width: auto; margin-bottom: 18px; margin-left: 2px; }   /* pixel motif above the heading */
    .rr-promo-cfe { border-left: 1px solid var(--border-grey); }
    .rr-promo-h {
      margin: 10px 0;
      font-family: 'Copperplate', serif;
      font-weight: normal;
      font-size: 20px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text);
    }
    .rr-promo-p {
      margin: 0;
      font-family: 'Antique Olive', sans-serif;
      font-weight: 300;
      font-size: 14px;
      line-height: 1.55;
      color: var(--text);
    }
    .rr-promo-p strong { font-weight: 700; }
    .rr-bullets { list-style: none; margin: 14px 0 0; padding: 0; }
    .rr-bullets li {
      position: relative;
      padding-left: 20px;
      margin-bottom: 5px;
      font-family: 'Antique Olive', sans-serif;
      font-weight: 300;
      font-size: 14px;
      color: var(--text);
    }
    .rr-bullets li::before {
      content: '';
      position: absolute;
      left: 0; top: 0.18em;
      width: 9px; height: 9px;
      background: var(--theme);
    }
    .rr-bullets strong { font-weight: 700; }

    /* Bottom strip */
    .rr-promo-strip {
      border-top: 1px solid var(--border-grey);
      padding: 12px 28px;
      display: flex;
      align-items: center;
    }
    /* "Find out more" — bottom-right footer of the Call-for-Evidence card */
    .rr-promo-more {
      padding: 12px 28px;
      text-align: right;
    }
    .rr-strip-left {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: 'Roboto', sans-serif;
      font-weight: 500; font-size: 12px;
      letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--text);
    }
    .rr-strip-icon { width: 15px; height: 15px; flex: 0 0 auto; color: var(--text); }
    .rr-strip-right {
      font-family: 'Roboto', sans-serif;
      font-weight: 600; font-size: 12px;
      letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--theme);
    }
    .rr-promo-card:hover .rr-strip-right { text-decoration: underline; text-underline-offset: 3px; }

    /* Tablet/mobile: red panel goes full-width on top, then cards, then strip */
    @media (max-width: 1080px) {
      .rr-promo-card {
        grid-template-columns: 1fr;   /* title on top, right region (cards) below */
        min-height: 0;
      }
      .rr-promo-l1 { font-size: 36px; }
      .rr-promo-l2 { font-size: 48px; }
    }
    @media (max-width: 600px) {
      .rr-promo { padding: 24px 18px; }
      .rr-promo-cards { grid-template-columns: 1fr; }
      .rr-promo-cfe { border-left: none; border-top: 1px solid var(--border-grey); }
      .rr-promo-strip { flex-direction: column; align-items: flex-start; gap: 8px; }
      .rr-promo-l1 { font-size: 30px; }
      .rr-promo-l2 { font-size: 42px; }
    }
    .section-label {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      font-size: 28px;
      letter-spacing: 0.02em;
      color: var(--text);
      margin: 0 0 15px;
    }
    .section-label a { color: var(--text); text-decoration: none; }   /* plain brown heading, not a red/underlined link */
    /* Mobile-only hint that the projects are a horizontal swipe carousel. */
    .scroll-cue {
      display: none;             /* shown only at the carousel breakpoint (≤600px) */
      align-items: center;
      gap: 5px;
      font-family: 'Roboto', sans-serif;
      font-weight: 500;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--border-grey);
      white-space: nowrap;
    }
    .scroll-cue-arrow {
      display: inline-block;
      animation: scroll-cue-nudge 1.5s ease-in-out infinite;
    }
    @keyframes scroll-cue-nudge {
      0%, 100% { transform: translateX(0); }
      50%      { transform: translateX(4px); }
    }
    @media (prefers-reduced-motion: reduce) {
      .scroll-cue-arrow { animation: none; }
    }

    /* ---------- Spotlight: pinned intro (left) + scrolling projects (right) ---------- */
    .spotlight { 
      padding: 70px 0 56px; 
      background-color: var(--almost-white);
    }

    .spotlight-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 520px;   /* intro flexes; cards hold 520px and never compress */
      gap: 56px;
      align-items: start;
      margin: 0 auto;               /* centred — side gutters are whitespace, not fixed chrome */
      max-width: 1200px;            /* beyond this the gutters just grow */
    }
    /* Anchor for the rain layer, which sits in the grid's right margin band. */
    .spotlight-main { position: relative; }
    .spotlight-rain {
      position: absolute;
      top: 0;                      /* height set in JS — reaches the top of card 3 */
      left: 100%;                  /* right edge of the project cards */
      width: 96px;                 /* 20% narrower band */
      margin-left: 40px;           /* keep 40px clear of the cards' right edge (fits the 160px margin) */
      pointer-events: none;
      z-index: 0;
      /* Soft top/bottom edges so drops fade in/out instead of popping at a hard line. */
      -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 60px, #000 calc(100% - 60px), transparent 100%);
              mask-image: linear-gradient(to bottom, transparent 0, #000 60px, #000 calc(100% - 60px), transparent 100%);
    }
    .spotlight-intro {
      position: sticky;
      top: 240px;                   /* sticky threshold — freezes 80px below viewport top (clears the 60px nav) */
      margin-top: 120px;            /* initial gap before the intro */
      align-self: start;
      padding-left: 0px; 
      padding-right: 80px;
    }
    /* Decorative 7x2 dot grid, top-left of the intro. Anchored to the
       container's top-left corner; nudge it anywhere (incl. outside the
       container) with the margins below — negative values are fine. */
    .intro-matrix {
      position: absolute;
      top: 0;
      left: 0;
      margin: -110px 0 0 -100px;      /* top right bottom left — move the grid with these */
      display: grid;
      grid-template-columns: repeat(7, var(--small-block-size));
      grid-auto-rows: var(--small-block-size);
      gap: var(--small-block-gap);
    }
    .intro-matrix span {
      background: var(--border-grey);
      border-radius: var(--small-block-radius);
      box-sizing: border-box;
      box-shadow: inset 0 0 0 0 transparent;   /* baseline for the hollow-ring transition */
      transition: background-color 0.9s ease, box-shadow 0.9s ease;
    }
    .intro-eyebrow { display: none; }   /* mobile-only (shown in the 600px query) */
    .intro-pic { display: none; }       /* mobile-only (shown in the 600px query) */
    .spotlight-intro h2 {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      font-size: 26px;
      letter-spacing: 0.02em;
      color: var(--text);
      margin: 0 0 20px;
      line-height: 1.3;  
    }
    .spotlight-intro p {
      font-family: 'Antique Olive', sans-serif;
      font-weight: 300; 
      font-size: 15px;
      line-height: 1.5;
      color: var(--text);
      margin: 0 0 16px;
      max-width: 520px;     /* use the now-wider column */
    }
    .spotlight-intro .hero-link {
      display: block;
      font-family: 'Roboto', sans-serif;
      text-decoration: none;
      color: var(--theme);
      text-transform: uppercase;
      font-size: 13px;
      font-weight: bold;
      margin-top: 30px;

    }
    /* Four section titles arranged in a row, evenly spaced across the width. */
    .spotlight-intro-footer {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-top: 10px;
      padding-top: 40px; 
      padding-bottom: 80px; 
    }
    .sif-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }
    .sif-art {
      display: grid;
      grid-template-columns: repeat(4, var(--small-block-size));
      grid-auto-rows: var(--small-block-size);
      gap: var(--small-block-gap);
      margin-bottom: 10px;
      margin-left: 10px;        /* nudge all four motifs right */
    }
    /* Pull the Analytics + Toolbuilding labels left a touch */
    .sif-item:nth-child(2) .sif-label { margin-left: -3px; }
    .sif-item:nth-child(3) .sif-label { margin-left: -6px; }
    /* Nudge the Community label + motif right a touch */
    .sif-item:nth-child(4) .sif-label { margin-left: 14px; }
    .sif-item:nth-child(4) .sif-art { margin-left: 19px; }
    .sif-cell {
      width: var(--small-block-size);
      height: var(--small-block-size);
      border-radius: var(--small-block-radius);
      border: 2.5px solid transparent;   /* border-only cells set border-color; fills set background */
      box-sizing: border-box;
    }
    .sif-label {
      text-align: left;
      font-family: 'Copperplate', serif;
      font-weight: normal;
      color: var(--text);
      font-size: 12px;
    }

    .projects { display: flex; flex-direction: column; gap: 22px; padding-right: 0px; }


    .project {                                /* TUNE THE GAP AND PADDING TO CHANGE SPACING AROUND GRID - BUT ALSO CHANGE INTERNAL DIV FOR PROJECT TEXT */
      display: flex;
      gap: 12px;
      align-items: stretch;
      background: var(--bg-secondary);
      border: 1px solid var(--border-grey);
      border-radius: 4px;
      padding: 12px;
      box-sizing: border-box;
      height: 315px;           /* fixed so every card is uniform: content area = 315 - 2(border) - 24(pad) = 289px,
                                  which is exactly the 14×29 grid-art height (29×10 - 1). Reset on mobile. */
      overflow: hidden;        /* clip any text overflow at narrow desktop widths rather than spilling the card */
    }

    .project-body { flex: 1; min-width: 0; display: flex; flex-direction: column; 
      padding: 10px; 
      padding-right: 15px; 
      padding-bottom: 3px;
    
    }


  
    .project-title {
      font-family: 'Copperplate', serif;
      font-weight: 600;
      font-size: 20px;
      line-height: 1.15;
      color: var(--text);
      margin: 0 0 16px;
    } 
    .project-sub {
      font-family: 'Playfair Display', serif;
      font-weight: 300;
      font-size: 16px;
      letter-spacing: 0.01em;
      line-height: 1.2;
      color: var(--text);
      margin: 0 0 16px;
    }
    .project-text {
      font-family: 'Antique Olive', sans-serif;
      font-weight: 300; 
      font-size: 14px;
      line-height: 1.4;
      color: var(--text);
      margin: 0 0 10px;
    }
    .project-detail {
      border-left: 1px solid var(--border-grey);
      padding-left: 16px;
      margin-top: 0px;
      margin-bottom: 6px; 
      padding-bottom: 0px;
    }
    .project-more {
      font-family: 'Roboto', sans-serif;
      display: inline-block;
      align-self: flex-start;   /* content-width within the flex column */
      margin-top: auto;         /* push to the bottom of the card */
      margin-left: 16px;
      font-family: var(--button-text);
      font-weight: 300;
      font-size: 14px;
      letter-spacing: 0.01em;
      color: var(--theme);
      text-decoration: none;
    }
    .project-more:hover { text-decoration: underline; }
    .project-divider {
      flex: 0 0 auto;
      width: 1px;
      align-self: stretch;
      background: var(--border-grey);
      margin: -12px 0;            /* extend to the card's top/bottom edges through the padding */
    }
    /* Procedural dot-matrix filling the card's right panel. The column count
       fixes the panel width; the row count is computed in JS to fit the card
       height in WHOLE cells, so differing card heights never slice a pixel.
       One colour for now. */
    .project-img {
      flex: 0 0 auto;
      align-self: stretch;              /* stretches to the card height set by the body… */
      position: relative;               /* …and anchors the out-of-flow cell layer below */
      --card-pix-cols: 18;              /* procedural-dot columns (cards not yet using grid art) */
      --card-pix-cell: 7px;
      --card-pix-gap: 1px;
      --card-pix-color: var(--border-grey);
      /* Width derived from the fixed 289px strip height and the 18×37 art aspect
         (native 179×369 at 9px/1px) so GridArt (fit:width) fills the height exactly.
         289 × 179/369 ≈ 140.19px. */
      width: calc(289px * 179 / 369);
      overflow: hidden;
    }
    /* The dot grid lives in an absolutely-positioned layer so its row count
       never contributes to the card's height. Without this, taller cards (from
       wrapped body text at narrow widths) grow the grid, and the grid's own
       height then holds the card open — so it can't contract when widened. */
    .project-img-cells {
      position: absolute;
      inset: 0;
      display: grid;
      grid-template-columns: repeat(var(--card-pix-cols), var(--card-pix-cell));
      grid-auto-rows: var(--card-pix-cell);
      gap: var(--card-pix-gap);
      align-content: start;             /* pack pixels from the top down */
    }
    /* Grid-art variant of the strip: top-anchored and out of flow (same reason as
       .project-img-cells) so it never feeds the card height. At the fixed 315px
       card height the 18×37 art fills the 289px strip exactly. */
    .project-img-art {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
    }
