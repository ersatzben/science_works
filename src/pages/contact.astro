---
import BaseLayout from '../layouts/BaseLayout.astro';

// Web3Forms access key — generate one at https://web3forms.com using
// contact@science.works as the destination, then paste it here. The key is
// public by design (it only routes mail to that fixed address).
const WEB3FORMS_KEY = 'dab1459e-1f8b-4c4d-b37a-295ef3899413';

// Brand palette for the mosaic maker — index order matches tools/editor.html +
// image2bitmap (the site's pixel-art contract). Index 0 = background / erase.
const PALETTE = [
  { name: 'Erase', hex: '#f6f0ed' },
  { name: 'Text', hex: '#66223b' },
  { name: 'Theme red', hex: '#eb3131' },
  { name: 'Sage', hex: '#00726b' },
  { name: 'Bright blue', hex: '#004ee6' },
  { name: 'Pale blue', hex: '#a3c0d7' },
  { name: 'Light green', hex: '#64b37b' },
  { name: 'Deep green', hex: '#0e676a' },
  { name: 'Coral', hex: '#f45e57' },
  { name: 'Beige', hex: '#ebe5cf' },
  { name: 'Almost white', hex: '#faf8f6' },
  { name: 'Purple blue', hex: '#4b5cce' },
  { name: 'Darkest brown', hex: '#440214' },
  { name: 'Indigo', hex: '#3a3c7c' },
  { name: 'Mauve', hex: '#72679b' },
];

// Decorative pixel-art motifs scattered around the contact content. Each motif is
// a small matrix, absolutely positioned relative to .contact-inner. '0' is always
// transparent; other digits are coloured via `color` (single fill) or `colors`
// (per-digit map). List a digit in `hollow` to render it as an outline instead of
// a fill. `cell` overrides the pixel size (default 12px); `pos.transform` allows
// centred placement (e.g. translateY(-50%)). Add/adjust entries as we go.
const motifs = [
  // worked example: 2x3, purple, out to the left near the top
  { rows: ['11', '10', '01'], color: 'var(--purple-blue)', pos: { top: '-20px', left: '-100px' } },
  // 3x2, light blue with a hollow cell, out to the middle-left
  { rows: ['001', '200'], color: 'var(--pale-blue)', hollow: '2', pos: { top: '45%', left: '-70px', transform: 'translateY(-50%)' } },
  // single coral pixel, bottom-left
  { rows: ['1'], color: 'var(--coral)', pos: { bottom: '80px', left: '-140px' } },
  // dark green trio, top-right
  { rows: ['010', '011'], color: 'var(--deep-green)', pos: { top: '-60px', right: '-130px' } },
  // single dark green pixel near the trio
  { rows: ['1'], color: 'var(--deep-green)', pos: { top: '-12px', right: '-95px' } },
  // 3x2, theme + coral, middle-right
  { rows: ['002', '100'], colors: { '1': 'var(--theme)', '2': 'var(--coral)' }, pos: { top: '40%', right: '-100px', transform: 'translateY(-50%)' } },
  // 2x2 hollow light-blue, slightly below the theme/coral set
  { rows: ['0X', 'X0'], color: 'var(--pale-blue)', hollow: 'X', pos: { top: 'calc(40% + 10px)', right: '-130px' } },
];
const motifStyle = (m) => [
  m.pos.top    ? `top:${m.pos.top};` : '',
  m.pos.right  ? `right:${m.pos.right};` : '',
  m.pos.bottom ? `bottom:${m.pos.bottom};` : '',
  m.pos.left   ? `left:${m.pos.left};` : '',
  m.pos.transform ? `transform:${m.pos.transform};` : '',
  `--cart-cols:${m.rows[0].length};`,
  m.cell ? `--cart-cell:${m.cell};` : '',
].join('');
const cartCell = (ch, m) => {
  if (ch === '0') return '';   // transparent
  const col = (m.colors && m.colors[ch]) || m.color;
  if (!col) return '';
  return (m.hollow && m.hollow.indexOf(ch) !== -1)
    ? `box-shadow: inset 0 0 0 2px ${col};`   // hollow outline
    : `background:${col};`;                    // fill
};
---
<BaseLayout title="Contact — Science Works" description="Got an idea to share or something you're building? Get in touch with the Science Works team.">
  <main class="contact">
    <div class="contact-inner">
     {motifs.map((m) => (
       <div class="cart-motif" aria-hidden="true" style={motifStyle(m)}>
         {m.rows.map((row) => row.split('').map((ch) => (
           <span class="cart-cell" style={cartCell(ch, m)}></span>
         )))}
       </div>
     ))}
     <div class="contact-grid">
      <div class="contact-left">
      <h1 class="contact-title">Get in touch</h1>
      <p class="contact-intro">Got something to say? An idea to share? Something cool you're building? We'd love to hear from you.</p>

      <form id="cform" class="cform" method="POST" action="https://api.web3forms.com/submit" novalidate>
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value="New message via the science.works contact form" />
        <input type="hidden" name="from_name" value="science.works contact form" />
        <!-- Honeypot: bots fill it, humans never see it -->
        <input type="checkbox" name="botcheck" class="cform-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="cform-row">
          <div class="cform-field">
            <label for="cf-name">Name <span class="asterisk">*</span></label>
            <input id="cf-name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="cform-field">
            <label for="cf-email">Email <span class="asterisk">*</span></label>
            <input id="cf-email" name="email" type="email" autocomplete="email" required />
          </div>
        </div>

        <div class="cform-field">
          <label for="cf-org">Organisation</label>
          <input id="cf-org" name="organisation" type="text" autocomplete="organization" />
        </div>

        <div class="cform-field">
          <label for="cf-message">Message <span class="asterisk">*</span></label>
          <textarea id="cf-message" name="message" rows="4" required></textarea>
        </div>

        <label class="cform-check">
          <input type="checkbox" name="newsletter" value="Yes" />
          <span>I'd like to receive updates about your work and events</span>
        </label>

        <div class="cform-actions">
          <button type="submit" class="cform-submit">Send message</button>
          <p class="cform-status" id="cform-status" role="status" aria-live="polite"></p>
        </div>
      </form>
      </div><!-- /.contact-left -->

      <div class="contact-right">
        <div class="mk-head">
          <h2 class="mk-title" id="mk-title">Design a mosaic for us</h2>
          <div class="mk-modes" role="tablist" aria-label="Maker mode">
            <button type="button" class="mk-mode is-active" data-mode="mosaic" role="tab" aria-selected="true" title="Mosaic" aria-label="Mosaic">
              <svg viewBox="0 0 16 16" aria-hidden="true"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
            </button>
            <button type="button" class="mk-mode" data-mode="snake" role="tab" aria-selected="false" title="Snake" aria-label="Snake">
              <svg viewBox="0 0 16 16" aria-hidden="true"><rect x="1" y="1" width="4" height="4" rx="1"/><rect x="1" y="6" width="4" height="4" rx="1"/><rect x="6" y="6" width="4" height="4" rx="1"/><rect x="6" y="11" width="4" height="4" rx="1"/><rect x="11" y="11" width="4" height="4" rx="1"/></svg>
            </button>
          </div>
        </div>


        <div class="mk-stage">
          <div class="mk-canvas" id="mk-canvas" role="group" aria-label="20 by 20 grid"><div class="mk-overlay" id="mk-overlay" hidden></div></div>
          <div class="mk-side">
            <div class="mk-mosaic-side">
              <div class="mk-intro">Paint a mosaic by clicking or dragging in the grid. If you send it to us, we might use it on our website.</div>
              <div class="mk-tools">
              <div class="mk-palette" id="mk-palette">
                {PALETTE.map((p, i) => (
                  <button
                    type="button"
                    class:list={["mk-swatch", { "mk-swatch--erase": i === 0 }]}
                    data-idx={i}
                    data-hex={p.hex}
                    style={`background:${p.hex}`}
                    title={p.name}
                    aria-label={p.name}
                  ></button>
                ))}
              </div>
              <button type="button" class="mk-clear" id="mk-clear">Clear</button>
              </div>
            </div>
            <div class="mk-snake-side" hidden>
              <div class="mk-intro">Eat the dots. Arrow keys or WASD to steer — don't hit the walls or yourself.</div>
              <div class="mk-scores">
                <div class="mk-score">Score <span id="mk-score">0</span></div>
                <div class="mk-score">Best <span id="mk-best">0</span></div>
              </div>
              <button type="button" class="mk-clear" id="mk-restart">Restart</button>
            </div>
          </div>
        </div>

        <form id="mk-form" class="cform mk-form" method="POST" action="https://api.web3forms.com/submit" novalidate>
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="New mosaic submission via science.works" />
          <input type="hidden" name="from_name" value="science.works mosaic maker" />
          <input type="checkbox" name="botcheck" class="cform-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div class="mk-submit-row">
            <div class="cform-field">
              <label for="mk-name">Your name</label>
              <input id="mk-name" name="name" type="text" autocomplete="name" required />
            </div>
            <button type="submit" class="cform-submit" id="mk-submit">Submit</button>
          </div>
          <p class="cform-status" id="mk-status" role="status" aria-live="polite"></p>
        </form>
      </div><!-- /.contact-right -->
     </div><!-- /.contact-grid -->
    </div>
  </main>

  <style>
    .contact { padding: 130px 24px 104px; }
    .contact-inner { max-width: 1100px; margin: 0 auto; position: relative; }

    /* Decorative pixel-art motifs, absolutely placed around the content. */
    .cart-motif {
      position: absolute;
      display: grid;
      grid-template-columns: repeat(var(--cart-cols), var(--cart-cell, 12px));
      grid-auto-rows: var(--cart-cell, 12px);
      gap: var(--cart-gap, 3px);
      pointer-events: none;
      z-index: 0;
    }
    .cart-cell { border-radius: var(--small-block-radius); }
    /* Side-margin art needs room — only show on wide screens. */
    @media (max-width: 1199px) { .cart-motif { display: none; } }

    /* Two columns: contact form (left) + mosaic maker (right) */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 100px; align-items: start; }
    .contact-left, .contact-right { min-width: 0; }

    .contact-left {padding-right:30px; padding-left: 20px; }

    .contact-right { background-color: var(--almost-white); border: 1px solid var(--border-grey); padding: 24px 24px 14px; border-radius: 5px; }

    .mk-title { font-family: 'Copperplate', serif; font-weight: normal; font-size: 21px; letter-spacing: 0.02em; color: var(--text); margin: 0 0 10px; }
    .mk-intro { font-family: 'Antique Olive', sans-serif; font-weight: 300; font-size: 13px; line-height: 1.4; color: var(--text); margin: 0 0px 16px 0; }
    .mk-stage { display: flex; gap: 12px; align-items: flex-start; flex-wrap: wrap; margin: 0 0 22px; }
    .mk-side { flex: 1 1 130px; min-width: 0; display: flex; flex-direction: column; gap: 14px; }   /* right column: intro on top, palette/clear beneath */
    .mk-canvas {
      position: relative;            /* anchor for the snake overlay */
      flex: 1 1 300px; max-width: 320px; aspect-ratio: 1; display: grid;
      grid-template-columns: repeat(20, 1fr); gap: 2px; padding: 2px;
      background: var(--almost-white); border-radius: 0px;
      touch-action: none; user-select: none; -webkit-user-select: none;
    }
    .mk-canvas--snake .mk-cell { cursor: default; }
    .mk-cell { aspect-ratio: 1; border-radius: 2px; cursor: crosshair; }
    .mk-form { max-width: 405px; gap: 10px; }
    .mk-submit-row { display: flex; align-items: flex-end; gap: 12px; }
    .mk-submit-row .cform-field { flex: 1 1 auto; min-width: 0; }   /* name field shortens to make room */
    .mk-submit-row .cform-submit { flex: 0 0 auto; margin-bottom: 5px; }                /* submit sits to its right, bottom-aligned */
    .mk-tools { flex: 0 0 auto; display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }
    .mk-palette { display: flex; flex-wrap: wrap; gap: 6px; width: 72px; }
    .mk-swatch { width: 20px; height: 20px; border-radius: 4px; border: 2px solid transparent; box-shadow: inset 0 0 0 1px rgba(68,2,20,0.12); cursor: pointer; padding: 0; position: relative; }
    .mk-swatch:hover { box-shadow: inset 0 0 0 1px var(--theme); }
    .mk-swatch.is-selected { border-color: var(--text); box-shadow: 0 0 0 2px var(--bg), 0 0 0 4px var(--theme); }
    .mk-swatch--erase::after { content: ''; position: absolute; inset: 3px; background: linear-gradient(45deg, transparent 44%, var(--theme) 44%, var(--theme) 56%, transparent 56%); border-radius: 3px; }
    .mk-clear { font-family: var(--button-text); font-weight: 500; font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--theme); background: var(--almost-white); border: 1px solid var(--border-grey); border-radius: 4px; padding: 7px 14px; cursor: pointer; }
    .mk-clear:hover { border-color: var(--theme); }

    /* Mode toggle (mosaic / snake) */
    .mk-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin: 0 0 10px; }
    .mk-head .mk-title { margin: 0; }
    .mk-modes { display: inline-flex; gap: 2px; padding: 2px; background: var(--bg-secondary); border: 1px solid var(--border-grey); border-radius: 999px; flex: 0 0 auto; }
    .mk-mode { width: 26px; height: 22px; display: inline-flex; align-items: center; justify-content: center; padding: 0; border: none; border-radius: 999px; background: transparent; color: var(--border-grey); cursor: pointer; transition: background 0.15s ease, color 0.15s ease; }
    .mk-mode svg { width: 13px; height: 13px; fill: currentColor; }
    .mk-mode:hover { color: var(--text); }
    .mk-mode.is-active { background: var(--almost-white); color: var(--theme); box-shadow: 0 1px 2px rgba(68,2,20,0.08); }

    /* Snake: start/over overlay + score readout */
    .mk-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; text-align: center; padding: 10px; background: rgba(250,248,246,0.86); color: var(--text); font-family: 'Roboto', sans-serif; font-size: 13px; line-height: 1.45; pointer-events: none; }
    .mk-overlay[hidden] { display: none; }
    /* These are injected via innerHTML, so they never get the scope attribute —
       :global() opts them out of Astro's style scoping so the rules apply. */
    :global(.mk-ov-msg) { line-height: 1.45; }
    :global(.mk-ov-title) { display: block; font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 3px; }
    :global(.mk-ov-sub) { display: block; font-size: 13px; color: var(--text); margin-bottom: 5px; }
    :global(.mk-ov-sub b) { color: var(--theme); }
    :global(.mk-ov-hint) { display: block; font-size: 12px; color: var(--text); opacity: 0.75; }
    .mk-scores { display: flex; gap: 18px; margin-bottom: 16px; }
    .mk-score { font-family: 'Roboto', sans-serif; font-size: 13px; color: var(--text); }
    .mk-score span { font-weight: 700; color: var(--theme); }
    .mk-form[hidden] { display: none; }   /* beats .cform display:flex when hidden in snake mode */
    .contact-title {
      font-family: 'Copperplate', serif; font-weight: normal; font-size: 34px;
      letter-spacing: -0.02em; color: var(--text); margin: 20px 0 14px;
    }
    .contact-intro {
      font-family: 'Antique Olive', sans-serif; font-size: 14px; line-height: 1.4; font-weight: 300;
      color: var(--text); margin: 0 0 24px; max-width: 560px;
    }

    .cform { display: flex; flex-direction: column; gap: 10px; }
    .cform-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .cform-field { display: flex; flex-direction: column; gap: 4px;}
    .cform-field label {
      font-family: 'Antique Olive'; font-weight: 500; 
      letter-spacing: 0em; font-size: 13px; color: var(--text);
    }
    .cform-opt { color: var(--text); opacity: 0.5; text-transform: none; letter-spacing: 0; font-weight: 400; }
    .cform-field input,
    .cform-field textarea {
      font-family: 'Antique Olive', sans-serif; font-size: 14px; color: var(--text); font-weight: 300; 
      background: var(--almost-white); border: 1px solid var(--border-grey); border-radius: 4px;
      padding: 11px 13px; width: 100%; box-sizing: border-box; transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .cform-field textarea { resize: vertical; min-height: 100px; line-height: 1.5; }
    .cform-field input:focus,
    .cform-field textarea:focus { outline: none; border-color: var(--theme); box-shadow: inset 0 0 0 1px var(--theme); }

    /* Custom checkbox: red fill + white tick when checked */
    .cform-check { display: flex; align-items: flex-start; gap: 11px; cursor: pointer; font-family: 'Antique Olive', sans-serif; font-weight: 300; font-size: 13px; line-height: 1.8; color: var(--text); margin-top: 5px; margin-bottom: -5px; }
    .cform-check input {
      appearance: none; -webkit-appearance: none; width: 18px; height: 18px; flex: 0 0 auto; margin: 0;
      border: 1.5px solid var(--border-grey); border-radius: 4px; background: transparent; cursor: pointer; position: relative; top: 1px;
    }
    .cform-check input:checked { background: var(--theme); border-color: var(--theme); }
    .cform-check input:checked::after { content: ''; position: absolute; left: 5px; top: 1px; width: 5px; height: 10px; border: solid #fff; border-width: 0 2px 2px 0; transform: rotate(45deg); }

    .cform-hp { position: absolute; left: -9999px; opacity: 0; }

    .cform-actions { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; margin-top: 4px; }
    .cform-submit {
      font-family: var(--button-text); font-weight: 500; font-size: 14px; letter-spacing: 0.02em; text-transform: uppercase;
      color: #fff; background: var(--theme); border: 1.5px solid var(--theme); border-radius: 5px;
      padding: 6px 16px; cursor: pointer; transition: background-color 0.15s ease, color 0.15s ease;
    }
    .cform-submit:hover { background: #fff; color: var(--theme); }
    .cform-submit:disabled { opacity: 0.6; cursor: default; }

    .cform-status { font-family: 'Antique Olive', sans-serif; font-weight: 300; font-size: 15px; margin: 0; }
    .cform-status.is-success { color: var(--sage); }
    .cform-status.is-error { color: var(--theme); }

    .asterisk { color: var(--theme); font-weight: 500; }

    @media (max-width: 820px) {
      .contact-grid { grid-template-columns: 1fr; gap: 44px; }
      .contact-right { display: none; }   /* mosaic maker is desktop-only */
    }
    @media (max-width: 600px) {
      .contact { padding: 50px 18px 74px; }
      .contact-title { font-size: 30px; }
      .cform-row { grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline>
    (function () {
      const form = document.getElementById('cform');
      if (!form) return;
      const statusEl = document.getElementById('cform-status');
      const btn = form.querySelector('.cform-submit');

      // Best-effort newsletter subscribe via the same Brevo (Sendinblue) hosted
      // endpoint the footer signup posts to. Fire-and-forget (no-cors): it never
      // blocks or fails the contact message. If the list uses double opt-in, the
      // person receives a confirmation email before being added.
      function subscribeToBrevo(email) {
        const BREVO_SERVE = 'https://02b7cd5d.sibforms.com/serve/MUIFAJZ2eGNQzP0fGOsdltQtijRH1_hQcf_201A1U1qBQOWLgR7qRj244ABWg5NLG5B6Rm1V-_xpC6-BuGPXst4EnyRgaXSpNPTg1A4LsUjNRkKK6WPYxiFAn-4vrviBP6pLhkfhwy9WGTeIp_c4mMpFJ7abXlKWzVWumXm-dGtig8AfnEVxT13RhIw76k1FbHXRB78e0PzuS7F_Sw==';
        const fd = new FormData();
        fd.append('EMAIL', email);
        fd.append('GDPR_ACCEPTED', '1');
        fd.append('locale', 'en');
        fd.append('email_address_check', '');   // honeypot — must stay empty
        fetch(BREVO_SERVE, { method: 'POST', body: fd, mode: 'no-cors' }).catch(function () {});
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        // Basic client-side required check (form has novalidate for nicer UX control).
        if (!form.checkValidity()) { form.reportValidity(); return; }

        // Capture before the form is reset, for the optional Brevo subscribe.
        const wantsUpdates = form.querySelector('input[name="newsletter"]').checked;
        const emailValue = (form.querySelector('#cf-email').value || '').trim();

        statusEl.textContent = '';
        statusEl.className = 'cform-status';
        const label = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Sending…';

        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: new FormData(form),
          });
          const data = await res.json();
          if (data.success) {
            form.reset();
            statusEl.textContent = "Thanks for getting in touch!";
            statusEl.classList.add('is-success');
            if (wantsUpdates && emailValue) subscribeToBrevo(emailValue);
          } else {
            statusEl.textContent = (data && data.message) || 'Something went wrong. Please email contact@science.works directly.';
            statusEl.classList.add('is-error');
          }
        } catch (err) {
          statusEl.textContent = 'Network error — please try again, or email contact@science.works directly.';
          statusEl.classList.add('is-error');
        } finally {
          btn.disabled = false;
          btn.textContent = label;
        }
      });
    })();

    // ----- Maker: mosaic + snake (shared 20x20 grid) --------------------
    (function () {
      const GRID = 20, N = GRID * GRID;
      const canvas = document.getElementById('mk-canvas');
      if (!canvas) return;
      const swatches = Array.prototype.slice.call(document.querySelectorAll('.mk-swatch'));
      const PAL = swatches.map(function (s) { return s.dataset.hex; });

      // Shared grid. The mosaic lives in `data[]`; snake only repaints cell
      // backgrounds, so it never touches the mosaic.
      const cells = [];
      const data = new Array(N).fill(0);
      const frag = document.createDocumentFragment();
      for (let i = 0; i < N; i++) {
        const c = document.createElement('div');
        c.className = 'mk-cell'; c.dataset.i = i; c.style.background = PAL[0];
        frag.appendChild(c); cells.push(c);
      }
      canvas.appendChild(frag);

      let mode = 'mosaic';

      // ---- Mosaic ----
      let current = 2;
      function selectColour(i) { current = i; swatches.forEach(function (s, k) { s.classList.toggle('is-selected', k === i); }); }
      swatches.forEach(function (s, i) { s.addEventListener('click', function () { selectColour(i); }); });
      selectColour(2);

      let drawing = false, drawColour = 2;
      function paintAt(x, y) {
        const el = document.elementFromPoint(x, y);
        if (!el || !el.classList.contains('mk-cell')) return;
        const i = +el.dataset.i;
        if (data[i] === drawColour) return;
        data[i] = drawColour; el.style.background = PAL[drawColour];
      }
      canvas.addEventListener('pointerdown', function (e) { if (mode !== 'mosaic') return; drawing = true; drawColour = current; canvas.setPointerCapture(e.pointerId); paintAt(e.clientX, e.clientY); e.preventDefault(); });
      canvas.addEventListener('pointermove', function (e) { if (mode === 'mosaic' && drawing) paintAt(e.clientX, e.clientY); });
      const stop = function () { drawing = false; };
      canvas.addEventListener('pointerup', stop);
      canvas.addEventListener('pointercancel', stop);

      document.getElementById('mk-clear').addEventListener('click', function () { for (let i = 0; i < N; i++) { data[i] = 0; cells[i].style.background = PAL[0]; } });

      function encode() { return data.map(function (v) { return v.toString(16); }).join(''); }
      function load(code) {
        if (!code || code.length !== N) return;
        for (let i = 0; i < N; i++) {
          const v = parseInt(code[i], 16);
          if (isNaN(v) || v < 0 || v > 14) continue;
          data[i] = v; cells[i].style.background = PAL[v];
        }
      }
      function repaintMosaic() { for (let i = 0; i < N; i++) cells[i].style.background = PAL[data[i]] || PAL[0]; }
      if (location.hash.length > 1 && /^[0-9a-f]+$/i.test(location.hash.slice(1))) load(location.hash.slice(1));

      const form = document.getElementById('mk-form');
      const statusEl = document.getElementById('mk-status');
      const btn = document.getElementById('mk-submit');
      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (!form.checkValidity()) { form.reportValidity(); return; }
        if (data.every(function (v) { return v === 0; })) { statusEl.textContent = 'Paint something first!'; statusEl.className = 'cform-status is-error'; return; }
        const code = encode();
        const link = location.origin + '/contact#' + code;
        const fd = new FormData(form);
        fd.append('mosaic_code', code);
        fd.append('mosaic_link', link);
        statusEl.textContent = ''; statusEl.className = 'cform-status';
        const label = btn.textContent; btn.disabled = true; btn.textContent = 'Submitting…';
        try {
          const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', headers: { Accept: 'application/json' }, body: fd });
          const d = await res.json();
          if (d.success) {
            statusEl.textContent = 'Thanks for sending us your mosaic! We might feature it.';
            statusEl.classList.add('is-success');
          } else {
            statusEl.textContent = (d && d.message) || 'Something went wrong. Please try again.';
            statusEl.classList.add('is-error');
          }
        } catch (err) {
          statusEl.textContent = 'Network error — please try again.';
          statusEl.classList.add('is-error');
        } finally {
          btn.disabled = false; btn.textContent = label;
        }
      });

      // ---- Snake ----
      const S_BG = PAL[0], S_BODY = PAL[1], S_HEAD = PAL[2], S_FOOD = PAL[3];  // erase / text / theme / sage
      const SPEED = 130;
      const overlay = document.getElementById('mk-overlay');
      const scoreEl = document.getElementById('mk-score');
      const bestEl = document.getElementById('mk-best');
      const ix = function (x, y) { return y * GRID + x; };
      let snake, dir, nextDir, food, score = 0, running = false, over = false, timer = 0;
      let canRestart = false, overTimer = 0;   // 1s grace after death before input restarts
      let best = parseInt(localStorage.getItem('sw_snake_best') || '0', 10) || 0;

      function setScore() { scoreEl.textContent = score; bestEl.textContent = best; }
      function showOverlay(html) { overlay.innerHTML = '<div class="mk-ov-msg">' + html + '</div>'; overlay.hidden = false; }
      function paintSnake() {
        for (let i = 0; i < N; i++) cells[i].style.background = S_BG;
        cells[ix(food.x, food.y)].style.background = S_FOOD;
        for (let k = 0; k < snake.length; k++) cells[ix(snake[k].x, snake[k].y)].style.background = (k === 0) ? S_HEAD : S_BODY;
      }
      function placeFood() {
        const occ = {}; snake.forEach(function (s) { occ[ix(s.x, s.y)] = 1; });
        let i; do { i = (Math.random() * N) | 0; } while (occ[i]);
        food = { x: i % GRID, y: (i / GRID) | 0 };
      }
      function resetSnake() {
        clearInterval(timer); clearTimeout(overTimer); running = false; over = false; canRestart = false;
        snake = [{ x: 10, y: 10 }, { x: 9, y: 10 }, { x: 8, y: 10 }];
        dir = { x: 1, y: 0 }; nextDir = dir; score = 0; setScore();
        placeFood(); paintSnake();
        showOverlay('<span class="mk-ov-hint">Press an arrow to start</span>');
      }
      function startSnake() { if (running || over) return; running = true; overlay.hidden = true; timer = setInterval(tick, SPEED); }
      function endSnake() {
        running = false; over = true; canRestart = false; clearInterval(timer);
        if (score > best) { best = score; try { localStorage.setItem('sw_snake_best', String(best)); } catch (_) {} setScore(); }
        // Render the hint up front but invisible (so it reserves its space and
        // nothing shifts), then reveal it — and accept input — after 1s.
        showOverlay('<strong class="mk-ov-title">Game Over</strong><span class="mk-ov-sub">Score: <b>' + score + '</b></span><span class="mk-ov-hint" style="visibility:hidden">Press an arrow to play again</span>');
        overTimer = setTimeout(function () {
          canRestart = true;
          const h = overlay.querySelector('.mk-ov-hint');
          if (h) h.style.visibility = 'visible';
        }, 1000);
      }
      function tick() {
        dir = nextDir;I
        const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };
        if (head.x < 0 || head.x >= GRID || head.y < 0 || head.y >= GRID) return endSnake();   // die on wall
        for (let k = 0; k < snake.length; k++) if (snake[k].x === head.x && snake[k].y === head.y) return endSnake();
        snake.unshift(head);
        if (head.x === food.x && head.y === food.y) { score++; setScore(); placeFood(); }
        else snake.pop();
        paintSnake();
      }
      const KEYS = { ArrowUp: [0, -1], ArrowDown: [0, 1], ArrowLeft: [-1, 0], ArrowRight: [1, 0], w: [0, -1], s: [0, 1], a: [-1, 0], d: [1, 0] };
      function onKey(e) {
        const t = e.target;   // don't hijack keys while typing in the contact form
        if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
        const v = KEYS[e.key] || KEYS[(e.key || '').toLowerCase()];
        if (!v) return;
        e.preventDefault();
        if (over) { if (!canRestart) return; resetSnake(); }   // ignore input during the 1s grace
        const nd = { x: v[0], y: v[1] };
        if (!(snake.length > 1 && nd.x === -dir.x && nd.y === -dir.y)) nextDir = nd;   // no 180° turns
        if (!running) startSnake();
      }
      document.getElementById('mk-restart').addEventListener('click', resetSnake);
      document.addEventListener('visibilitychange', function () {
        if (document.hidden && mode === 'snake' && running) { running = false; clearInterval(timer); showOverlay('<strong class="mk-ov-title">Paused</strong><span class="mk-ov-hint">Press an arrow to resume</span>'); }
      });

      // ---- Mode controller ----
      const titleEl = document.getElementById('mk-title');
      const mosaicSide = document.querySelector('.mk-mosaic-side');
      const snakeSide = document.querySelector('.mk-snake-side');
      const modeBtns = Array.prototype.slice.call(document.querySelectorAll('.mk-mode'));
      function setMode(m) {
        if (m === mode) return;
        mode = m;
        modeBtns.forEach(function (b) { const on = b.dataset.mode === m; b.classList.toggle('is-active', on); b.setAttribute('aria-selected', on ? 'true' : 'false'); });
        if (m === 'snake') {
          mosaicSide.hidden = true; snakeSide.hidden = false;
          if (form) form.hidden = true;
          titleEl.textContent = 'Snake';
          canvas.classList.add('mk-canvas--snake');
          document.addEventListener('keydown', onKey);
          resetSnake();
        } else {
          clearInterval(timer); clearTimeout(overTimer); running = false; over = false; canRestart = false;
          document.removeEventListener('keydown', onKey);
          overlay.hidden = true;
          canvas.classList.remove('mk-canvas--snake');
          titleEl.textContent = 'Design a mosaic for us';
          snakeSide.hidden = true; mosaicSide.hidden = false;
          if (form) form.hidden = false;
          repaintMosaic();
        }
      }
      modeBtns.forEach(function (b) { b.addEventListener('click', function () { setMode(b.dataset.mode); }); });
      setScore();
    })();
  </script>
</BaseLayout>
