---
import BaseLayout from '../layouts/BaseLayout.astro';
import MosaicNetwork from '../components/MosaicNetwork.astro';
import decor from '../data/decor/projects-corner.json';
import banner from '../data/decor/projects-banner.json';

// Every JSON in src/data/mosaics/ becomes its own network block (sorted by name).
const mods = import.meta.glob('../data/mosaics/*.json', { eager: true });
const mosaics = Object.keys(mods).sort().map((k) => mods[k].default ?? mods[k]);

// Decorative corner art. Index 1 (#f7f0ed) is the blank filler → transparent.
const decorCells = decor.grid.flat();

// Grow order: an 8-connected flood from the leftmost visible pixel. Both corners
// share it; the right figure is mirrored (scaleX(-1)), so the same left-seeded
// growth reads as growing from the right there. (Tree-branch reveal.)
const dVisible = (r, c) => r >= 0 && c >= 0 && r < decor.rows && c < decor.cols && decor.grid[r][c] !== 1;
let dSeed = null;
for (let c = 0; c < decor.cols && !dSeed; c++) for (let r = 0; r < decor.rows; r++) if (dVisible(r, c)) { dSeed = [r, c]; break; }
const dStep = Array.from({ length: decor.rows }, () => new Array(decor.cols).fill(-1));
if (dSeed) {
  const q = [dSeed];
  dStep[dSeed[0]][dSeed[1]] = 0;
  // radius 2: the art is sparse, so bridge gaps up to 2 cells — the flood then
  // travels along the branch rather than stalling at the first gap.
  const RAD = 2;
  for (let h = 0; h < q.length; h++) {
    const [r, c] = q[h], d = dStep[r][c];
    for (let dr = -RAD; dr <= RAD; dr++) for (let dc = -RAD; dc <= RAD; dc++) {
      if (!dr && !dc) continue;
      const nr = r + dr, nc = c + dc;
      if (dVisible(nr, nc) && dStep[nr][nc] < 0) { dStep[nr][nc] = d + 1; q.push([nr, nc]); }
    }
  }
}
for (let r = 0; r < decor.rows; r++) for (let c = 0; c < decor.cols; c++) {   // islands → nearest reachable step + 1
  if (dVisible(r, c) && dStep[r][c] < 0) {
    let bd = Infinity, bs = 0;
    for (let rr = 0; rr < decor.rows; rr++) for (let cc = 0; cc < decor.cols; cc++)
      if (dVisible(rr, cc) && dStep[rr][cc] >= 0) { const dd = (rr - r) ** 2 + (cc - c) ** 2; if (dd < bd) { bd = dd; bs = dStep[rr][cc]; } }
    dStep[r][c] = bs + 1;
  }
}
const decorStepFlat = dStep.flat();

// Project copy + offsets (translate, px). tx/ty nudge the whole pair; ctx/cty
// nudge the text card independently of the network. Tune freely.
// `slug` is the canonical deep-link: /projects#<slug> opens that project's modal.
// Keep slugs stable even if the order/index changes. The numeric `index` (e.g. 01)
// also works as an inbound alias and canonicalises to the slug.
const PROJECTS = [
  { index: '01', slug: 'institutional-dynamism',   title: 'Institutional Dynamism',   subtitle: 'What mix of research institutions does Britain need, and how could we build them?', tx: 30, ty: 10, ctx: -25, cty: 0 },
  { index: '02', slug: 'ai-and-science',           title: 'AI and Science',           subtitle: 'How should British science adapt to the coming AI revolution?', tx: 20, ty: 64, ctx: -25, cty: 0 },
  { index: '03', slug: 'the-research-economy',     title: 'The Research Economy',      subtitle: 'How does Britain’s research and innovation economy really work – and can it be made more dynamic?', tx: 0, ty: 24, ctx: -25, cty: 0 },
  { index: '04', slug: 'software-for-science',     title: 'Software for Science',      subtitle: 'Why does public research still run on poor software – and what could great tools unlock?', tx: -80, ty: 16, ctx: 0, cty: 0 },
  { index: '05', slug: 'a-story-of-british-science', title: 'A Story of British Science', subtitle: 'How can we tell a story of British scientific renewal – linking institutions, place, and purpose?', tx: 10, ty: 36, ctx: -5, cty: 0 },
];
const items = mosaics.map((m, i) => ({ data: m, ...(PROJECTS[i] || { index: String(i + 1).padStart(2, '0'), slug: 'project-' + String(i + 1).padStart(2, '0'), title: 'Project', subtitle: '', tx: 0, ty: 0, ctx: 0, cty: 0 }) }));

// ── PROJECT DESCRIPTIONS ────────────────────────────────────────────────────
// Edit the modal body copy here — keyed by the project's `slug` (above). Each
// array entry is one paragraph. Use backticks so apostrophes/quotes are fine,
// and you can include inline HTML, e.g. `… see our <a href="/charter">charter</a>.`
const DESCRIPTIONS = {
  'institutional-dynamism': [
    `Every era of technological change has required new organisational forms – from the research University and the Royal Society to Bell Labs and DARPA. Today’s science will stagnate unless we create institutions fit for the 21st century.`,
    `Institutions are technologies in their own right: architectures with design choices, affordances and constraints. The organisation of labs and funding, the incentives, risk-appetite, and timescales hardwired into the system: each promotes certain types of research and invention while rendering others near impossible.`,
    `Britain is unusually dependent on one dominant model: the academic lab, funded by external grants, organised around a principal investigator, assessed primarily on papers, and built around a fairly standard career pathway.`,
    `It has produced extraordinary science. But its near-monopoly leaves the system fragile, narrowing our horizons, and leaving us with little capacity for evolution in the way we pursue science.`,
    `That model is now visibly under strain, and AI is about to reshape what research organisations need to be. The case for diversifying Britain's institutional base has never been stronger. We are interested in new models for organising and funding research: in the public and private sectors, inside universities and beyond them.`,
  ],
  'ai-and-science': [
    `Artificial intelligence will fundamentally change how science is done and what it means to be a researcher. Used well, it has the potential to unshackle researchers – automating drudgery, expanding cognitive bandwidth, and accelerating discovery. Used badly, it could compound dysfunctions: exacerbating the replication crisis, hollowing out scientific judgement, or overloading the system with superficially plausible but insubstantial outputs.`,
    `The UK's research base is not ready for this change. Scientific "dark data" – negative results, instrument traces,  technical experimental detail – sits in paper notebooks or local hard drives, invisible to the wider network of people and machines. Lab automation is concentrated in a handful of well-resourced institutes; and the formal credit system still rewards conventional papers over the reusable datasets, models, and tools that AI-enabled science depends on.`,
    `The default trajectory is unlikely to deliver the better future. Britain's path through this transition will be set by deliberate efforts — or by their absence.`,
    `We are developing an ambitious national operating agenda for AI in science, covering data, software, infrastructure, and talent.`,
  ],
  'the-research-economy': [
    `The UK research and innovation sector is a multi-billion-pound system that runs without enough insight, and thus with insufficient strategy.`,
    `How funding flows within institutions, what research really costs, where talent flows and pools, and how incentives shape choices on the ground – most of this is invisible to the people steering the public system, which remains undisturbed by the market dynamics that force reinvention in the private sector.`,
    `In place of rich understanding, the system relies on crude metrics and proxies that capture little of what we care about but, over time, become what it optimises for. Intuitive but misleading models of both research and innovation stand in for deep appreciation of how value is really created.`,
    `The policy tools we have are blunt. Research assessment is bureaucratic and expensive; grant-making is risk-averse and slow; promising alternatives go untested against the status quo. A system this opaque and conservative cannot adapt.`,
    `We are bringing quantitative and qualitative analysis to bear on how the research and innovation economy really works — its implicit assumptions and hidden distortions – and pushing for a system that is less bureaucratic, more intelligible, and more dynamic.`,
  ],
  'software-for-science': [
    `Modern research is becoming increasingly digital, but software tooling is underrecognised as a research output, with neither the infrastructure to share and maintain tools nor the incentives to do so.`,
    `In many fields, scientists lack up-to-date and interoperable tools for undertaking research in the age of intelligence. Though modern research depends on software and data infrastructure, the system still treats them as second-class outputs; both are neglected, and valuable tools are rarely maintained or shared.`,
    `Software for science is a public-good insufficiently catered to by the private sector – in part because of systemic and cultural barriers to adoption within academia.`,
    `There are few public institutions with the remit or the funding to build what the market can’t. The cost of that absence will compound as AI becomes inseparable from the scientific workflow.`,
    `Research software should be a first-class research output, with well-defined career paths for engineers, organisational infrastructure, and proper funding. At Science Works, we adapt and build open tools, and work with policymakers and the wider research software community to push for system-wide changes that will close the tooling gap.`,
  ],
  'a-story-of-british-science': [
    `A country gets the science it can imagine – and for all its strengths, Britain has lost the confidence to imagine very much. We pull the obvious levers, and somehow the system stays stuck: a decade of big decisions and bigger budgets has bought us less vitality than it should have, because we’re seized up on a deeper level.`,
    `This is partly a way of seeing. Science has become procedural – prescribed, measured out, and administered to the public like medicine. That temper is nothing like how it actually feels to do science.`,
    `It’s also the opposite of this country at its best: pragmatic and imaginative, fond of our eccentrics, suspicious of self-importance, historically brilliant not just at doing science but at inventing whole new ways to do it. Britain has always been at its strongest when it stood out from the pack.`,
    `The moment to recover that spirit is now. The whole order is being reshuffled by AI; a country that’s brave enough can leap a generation ahead. Having conviction to act depends on having a story worth believing: ambitious yet tangible, brilliant, and beautiful. This programme works on that story.`,
  ],
};
---
<BaseLayout title="Projects — Science Works" description="Science Works organises its work around five centres of gravity in British science and technology. Explore the projects driving our research and policy agenda.">
  <main class="projects-page">
    <!-- Mosaic header banner (mobile only; lifted from About/Writing). -->
    <div class="wi-header">
      <div class="wi-pix wi-header-pix" aria-hidden="true"></div>
      <h1 class="wi-heading">projects</h1>
      <script type="application/json" id="projects-banner-data" set:html={JSON.stringify(banner)}></script>
    </div>

    <div class="pp-decor pp-decor--left anim-ready" style={`--d-cols:${decor.cols}`} aria-hidden="true">
      {decorCells.map((v, i) => (<span class="d-cell" style={v === 1 ? '' : `background:${decor.palette[v]}; --step:${decorStepFlat[i]}`}></span>))}
    </div>
    <div class="pp-decor pp-decor--right anim-ready" style={`--d-cols:${decor.cols}`} aria-hidden="true">
      {decorCells.map((v, i) => (<span class="d-cell" style={v === 1 ? '' : `background:${decor.palette[v]}; --step:${decorStepFlat[i]}`}></span>))}
    </div>
    <noscript><style>.pp-decor .d-cell { opacity: 1 !important; transform: none !important; }</style></noscript>

    <div class="pp-inner">
      <header class="pp-head">
        <h1 class="pp-title">projects</h1>
        <p class="pp-intro">We organise our work around five centres of gravity that reflect our team&rsquo;s main areas of interest. If they are of interest to you, too, <a href="/contact">get in touch</a>.</p>
      </header>
    </div>

    <!-- Staggered scatter: flow handles the cascade, translate handles the scatter. -->
    <div class="pp-networks">
      {items.map((it) => (
        <div class="pp-item" style={`--tx:${it.tx}px; --ty:${it.ty}px; --ctx:${it.ctx}px; --cty:${it.cty}px`}>
          <div class="pp-block">
            <MosaicNetwork data={it.data} cell="6px" gap="1px" />
          </div>
          <a class="project-card" href={`#${it.slug}`} data-open data-slug={it.slug} data-index={it.index} data-title={it.title} data-subtitle={it.subtitle}>
            <p class="project-index">{it.index}</p>
            <h3 class="project-title">{it.title}</h3>
            <p class="project-subtitle">{it.subtitle}</p>
            <span class="project-toggle">+ Open Project</span>
          </a>
        </div>
      ))}
    </div>

    <!-- Project modal (populated on open; placed outside transformed ancestors). -->
    <div class="pp-modal" id="pp-modal" hidden>
      <div class="pp-modal-scrim" data-close></div>
      <div class="pp-modal-card" role="dialog" aria-modal="true" aria-labelledby="pp-modal-title">
        <button class="pp-modal-close" type="button" aria-label="Close" data-close>&times;</button>
        <div class="pp-modal-scroll">
          <p class="pp-modal-index" id="pp-modal-index"></p>
          <h2 class="pp-modal-title" id="pp-modal-title"></h2>
          <p class="pp-modal-sub" id="pp-modal-sub"></p>
          <div class="pp-modal-body"></div>
          <div class="pp-modal-foot">
          <a class="pp-modal-cta" href="/contact">If you are interested in this project, please get in touch <span class="arrow">&rarr;</span></a>
        </div>
      </div>
    </div>
    </div>

    <!-- Per-project modal body copy, generated from the DESCRIPTIONS map above.
         These <template>s are inert; the modal JS clones the matching one into
         .pp-modal-body (by slug) when a project opens. -->
    <div id="pp-bodies" hidden>
      {items.map((it) => (
        <template data-body={it.slug}>
          {(DESCRIPTIONS[it.slug] || ['Description coming soon.']).map((p) => (<p set:html={p}></p>))}
        </template>
      ))}
    </div>
  </main>

  <style>
    .projects-page { padding: 46px 24px 110px; position: relative; }
    .pp-inner { max-width: 1100px; margin: auto; position: relative; }

    /* ===== Mosaic header banner (mobile only; lifted from About/Writing) ===== */
    .wi-header {
      position: relative; height: 190px; overflow: hidden;
      margin: 0 calc(50% - 50vw) 22px;   /* full-bleed sides, flush under the nav */
      background: var(--bg-secondary);
      transform: scaleY(90%);
      display: none; align-items: center; justify-content: center;   /* shown on mobile */
    }
    .wi-pix {
      --card-pix-cell: var(--small-block-size); --card-pix-gap: var(--small-block-gap);
      --card-pix-radius: var(--small-block-radius); --card-pix-color: var(--border-grey);
      display: grid; grid-auto-rows: var(--card-pix-cell); gap: var(--card-pix-gap); justify-content: center;
    }
    .wi-pix.wi-header-pix {
      position: absolute; inset: 0; align-content: center;
      --card-pix-cell: 7px;
      --card-pix-gap: 1px;
      --card-pix-radius: var(--cell-radius); /* 2px */
      --card-pix-color: var(--almost-white);
      --card-pix-rows: 24;                     /* 24 × 7 + 23 × 1 = 191px — matches the banner art height */
    }
    .wi-heading {
      position: relative; z-index: 1; margin: 0; display: inline-block;
      background: var(--almost-white); padding: 15px 18px; text-transform: lowercase;
      font-family: 'Copperplate', serif; font-weight: normal; font-size: 28px;
      letter-spacing: 0.02em; color: var(--text);
    }

    /* Decorative corner pixel-art (static, non-interactive). */
    .pp-decor {
      position: absolute;
      top: 14px;
      z-index: 0;
      pointer-events: none;
      display: grid;
      grid-template-columns: repeat(var(--d-cols), var(--d-cell, 7px));
      grid-auto-rows: var(--d-cell, 7px);
      gap: var(--d-gap, 1px);
    }
    .pp-decor--left { left: 8px; }
    .pp-decor--right { right: 8px; transform: scaleX(-1); }   /* mirror for the right corner */
    .d-cell { border-radius: 1px; }
    /* Branch-grow: pixels flood out from the seed (left figure: leftmost pixel;
       right figure: rightmost, via the mirror). Armed by JS so no-JS stays static. */
    .pp-decor { --decor-step: 190ms; }
    .pp-decor.anim-ready .d-cell {
      opacity: 0;
      transform: scale(0.35);
      transform-origin: center;
      transition: opacity 0.45s ease, transform 0.55s cubic-bezier(0.2, 0.85, 0.3, 1.1);
      transition-delay: calc(var(--step, 0) * var(--decor-step));
    }
    .pp-decor.anim-ready.is-grown .d-cell { opacity: 1; transform: scale(1); }
    @media (prefers-reduced-motion: reduce) {
      .pp-decor.anim-ready .d-cell { opacity: 1; transform: none; transition: none; }   /* static */
    }
    @media (max-width: 940px) { .pp-decor { display: none; } }   /* declutter on small screens */

    .pp-head { margin: 0 0 28px; text-align: center; }
    .pp-title {
      font-family: 'Copperplate', serif; font-weight: normal; font-size: 40px;
      letter-spacing: -0.02em; color: var(--text); margin: 20px 0 5px;
    }
    .pp-intro {
      font-family: 'Playfair Display', serif; font-weight: 300; font-size: 15px;
      line-height: 1.5; color: var(--text); margin: auto; max-width: 420px;
    }

    .pp-intro a { text-decoration: none; color: var(--text); }
    .pp-intro a:hover { color: var(--theme); }

    /* Flow layout (wrap = the responsive cascade); transform = the scatter. */
    .pp-networks {
      max-width: 1500px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-start;
      gap: 56px 40px;
    }
    .pp-item {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      /* gap: 14px; */
      transform: translate(var(--tx, 0), var(--ty, 0));   /* cosmetic scatter — no scaling */
    }
    .pp-block { flex: 0 0 auto; }

    /* Project info card, sits to the right of the network. */
    .project-card {
      flex: 0 0 auto;
      width: 210px;
      height: 190px;
      box-sizing: border-box;
      text-decoration: none; color: inherit;   /* it's an <a> now; children keep their own colours */
      border: 1px solid var(--border-grey);
      background-color: rgba(248, 243, 239, 0.7);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);   /* Safari */
      border-radius: 6px;
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      transform: translate(var(--ctx, 0), var(--cty, 0));   /* independent card nudge */
      transition: transform 0.2s ease;
    }
    /* Subtle lift on hover — composes with the per-card --ctx/--cty scatter
       offset. Hover-capable devices only, so a touch tap doesn't snap it. */
    @media (hover: hover) {
      .project-card:hover { transform: translate(var(--ctx, 0), calc(var(--cty, 0) - 4px)); }
      .project-card:hover .project-toggle { text-decoration: underline; }   /* hint that the whole card opens it */
    }
    .project-index {
      font-family: var(--button-text); font-weight: 500; font-size: 12px;
      letter-spacing: 0.06em; color: var(--theme); margin: 0 0 6px;
    }
    .project-title {
      font-family: 'Copperplate', serif; font-weight: normal; font-size: 16px;
      line-height: 1.15; color: var(--text); margin: 0 0 8px;
    }
    .project-subtitle {
      font-family: 'Antique Olive', sans-serif; font-weight: 300; font-size: 12px;
      line-height: 1.4; color: var(--text); margin: 0;
    }
    .project-toggle {
      margin-top: auto;   /* pin to the bottom of the card */
      align-self: flex-start;
      font-family: var(--button-text); font-weight: 500; font-size: 12px;
      letter-spacing: 0.02em; text-transform: uppercase;
      color: var(--theme);
    }

    /* ---------- Project modal ---------- */
    .pp-modal[hidden] { display: none; }
    .pp-modal { position: fixed; inset: 0; z-index: 1000; display: grid; place-items: center; padding: 24px; }
    .pp-modal-scrim {
      position: absolute; inset: 0; background: rgba(20, 10, 10, 0.42);
      opacity: 0; transition: opacity 0.32s ease;
    }
    .pp-modal.is-open .pp-modal-scrim { opacity: 1; }
    .pp-modal-card {
      position: relative; z-index: 1;
      /* ── SIZE KNOBS (eyeball these) ───────────────────────────────────
         width:      desktop card width (caps to the viewport via 100%)
         min-height: how tall the card is when content is short
         max-height: cap before the body scrolls; overflow:auto does the scroll
         Mobile height is tuned in the @media (max-width: 600px) block below. */
      width: min(936px, 100%);
      min-height: 430px;
      max-height: 84vh;
      overflow: hidden;               /* the card itself doesn't scroll… */
      display: flex;
      flex-direction: column;         /* …the × stays pinned; .pp-modal-scroll scrolls */
      box-sizing: border-box;
      background: var(--almost-white);
      border: 1px solid var(--border-grey); border-radius: 12px;
      padding: 40px 44px;
      padding-right: 14px;
      box-shadow: 0 24px 70px rgba(68, 2, 20, 0.22);
      /* grows from the clicked card's centre (--ox/--oy set in JS) to centre */
      opacity: 0;
      transform: translate(var(--ox, 0), var(--oy, 0)) scale(0.12);
      transform-origin: center;
      transition: opacity 0.34s ease, transform 0.46s cubic-bezier(0.2, 0.8, 0.25, 1);
      will-change: transform, opacity;
    }
    .pp-modal.is-open .pp-modal-card { opacity: 1; transform: translate(0, 0) scale(1); }
     /* The single scroll region: everything from the index to the CTA scrolls
       together here (one scroll container → no nested-scroll dead zones),
       while the × stays pinned to the card. Inner padding lives here. */
    .pp-modal-scroll {
      flex: 1 1 auto; min-height: 0;
      overflow-y: auto;
      overscroll-behavior: contain;   /* don't scroll the page behind the modal */
      -webkit-overflow-scrolling: touch;
      padding: 0;
      padding-right: 30px; 
    }
    /* Mobile: just a taller card floor. Scroll behaviour is identical to desktop —
       the × stays pinned and everything in .pp-modal-scroll scrolls together. */
    @media (max-width: 600px) {
      .pp-modal-card { min-height: 460px; }
    }
    .pp-modal-close {
      position: absolute; top: 14px; right: 16px; z-index: 1; 
      width: 34px; height: 34px; line-height: 1; font-size: 24px;
      color: var(--text); background: var(--almost-white); border: none; border-radius: 50%; cursor: pointer;
    }
    .pp-modal-close:hover { color: var(--theme); background: var(--beige); }
    .pp-modal-index {
      font-family: var(--button-text); font-weight: 500; font-size: 13px;
      letter-spacing: 0.06em; color: var(--theme); margin: 0 0 8px;
    }
    .pp-modal-title {
      font-family: 'Copperplate', serif; font-weight: normal; font-size: 24px;
      letter-spacing: -0.01em; color: var(--text); margin: 0 0 12px;
    }
    .pp-modal-sub {
      font-family: 'Playfair Display', serif; font-weight: 300; font-size: 17px;
      line-height: 1.4; color: var(--text); margin: 0 0 22px;
    }
    .pp-modal-body {
      font-family: 'Antique Olive', sans-serif; font-weight: 300; font-size: 15px;
      line-height: 1.6; color: var(--text);
    }
    .pp-modal-body p { margin: 0 0 16px; }
    .pp-modal-body p:last-child { margin-bottom: 0; }
    .pp-modal-body a { color: var(--theme); text-decoration: underline; }
    /* CTA pinned below the scrolling body (desktop); on mobile it sits at the
       end of the whole-card scroll. */
    .pp-modal-foot {
      flex: 0 0 auto;
      margin-top: 20px; padding-top: 18px;
      border-top: 1px solid var(--border-grey);
    }
    .pp-modal-cta {
      font-family: var(--button-text); font-weight: 500; font-size: 15px;
      color: var(--theme); text-decoration: none;
    }
    .pp-modal-cta .arrow { display: inline-block; transition: transform 0.2s ease; }
    .pp-modal-cta:hover { text-decoration: underline; }
    .pp-modal-cta:hover .arrow { transform: translateX(3px); }
    @media (prefers-reduced-motion: reduce) {
      .pp-modal-card { transition: opacity 0.2s ease; transform: none !important; }
    }

    /* Narrow screens: drop the scatter, stack each pair cleanly. */
    @media (max-width: 940px) {
      .projects-page { padding-top: 0; }   /* banner controls the top gap, not the page padding */
      .wi-header { display: flex; margin-top: 20px; }   /* match Writing's spacing above the banner */
      .wi-heading { font-size: 25px; padding: 18px 16px;}      /* unify chip size with About/Writing (mobile only) */
      .pp-title { display: none; }          /* banner heading replaces the plain title */
      .pp-head { margin-top: 22px; }
      .pp-networks { flex-direction: column; align-items: center; gap: 40px; max-width: 520px; }
      .pp-item { transform: none; flex-direction: column; align-items: stretch; gap: 12px; width: 100%; }
      .pp-block { align-self: center; }   /* centre the network over its full-width card */
      .project-card {
        transform: none; width: 100%; height: auto;
        margin-top: -40px;                /* lift over the network so growth runs under the blur */
        position: relative; z-index: 1;   /* card (with backdrop blur) sits above the network */
      }
    }
    @media (max-width: 600px) {
      .projects-page { padding: 0 48px 60px; }
      .pp-title { font-size: 26px; }
      .pp-inner { padding-bottom: 26px;}
      .project-card { height: 150px; }




    }
  </style>

  <script is:inline>
    // Grow each network from its seed (then it stays grown). Desktop: on hover.
    // Touch / small screens (no mouse): when the network scrolls into view.
    (function () {
      const items = Array.prototype.slice.call(document.querySelectorAll('.pp-item'));
      if (!items.length) return;
      const grids = items.map(function (it) { return it.querySelector('.pp-mosaic'); }).filter(Boolean);
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;   // static
      grids.forEach(function (g) { g.classList.add('anim-ready'); });   // seed only until triggered

      const touch = window.matchMedia('(hover: none), (max-width: 940px)').matches;
      if (touch && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('is-grown'); io.unobserve(e.target); } });
        }, { threshold: 0.35 });
        grids.forEach(function (g) { io.observe(g); });
      } else {
        items.forEach(function (it) {
          const g = it.querySelector('.pp-mosaic');
          if (g) it.addEventListener('mouseenter', function () { g.classList.add('is-grown'); }, { once: true });
        });
      }
    })();

    // Project card (whole <a>) → modal that grows from the card's centre to centre.
    (function () {
      const modal = document.getElementById('pp-modal');
      if (!modal) return;
      const card = modal.querySelector('.pp-modal-card');
      const scroll = modal.querySelector('.pp-modal-scroll');
      const fIndex = modal.querySelector('#pp-modal-index');
      const fTitle = modal.querySelector('#pp-modal-title');
      const fSub = modal.querySelector('#pp-modal-sub');
      const fBody = modal.querySelector('.pp-modal-body');
      let lastFocus = null;

      // Deep-linking: build a lookup so /projects#<slug> (canonical) — or the
      // numeric alias #01 / #1 — resolves to a project's card (the open trigger).
      const byKey = {};
      const cards = Array.prototype.slice.call(document.querySelectorAll('.project-card[data-open]'));
      cards.forEach(function (b) {
        if (b.dataset.slug) byKey[b.dataset.slug.toLowerCase()] = b;
        if (b.dataset.index) {
          byKey[b.dataset.index.toLowerCase()] = b;                 // "01"
          byKey[String(parseInt(b.dataset.index, 10))] = b;         // "1"
        }
      });
      function btnForHash() {
        const h = (location.hash || '').replace(/^#/, '').toLowerCase();
        return h ? (byKey[h] || null) : null;
      }

      function open(btn) {
        fIndex.textContent = btn.dataset.index || '';
        fTitle.textContent = btn.dataset.title || '';
        fSub.textContent = btn.dataset.subtitle || '';
        // Pull in this project's description (cloned from its inert <template>).
        const tpl = document.querySelector('#pp-bodies template[data-body="' + (btn.dataset.slug || '') + '"]');
        if (fBody) fBody.replaceChildren(tpl ? tpl.content.cloneNode(true) : document.createTextNode(''));
        const r = btn.getBoundingClientRect();
        card.style.setProperty('--ox', Math.round(r.left + r.width / 2 - window.innerWidth / 2) + 'px');
        card.style.setProperty('--oy', Math.round(r.top + r.height / 2 - window.innerHeight / 2) + 'px');
        if (scroll) scroll.scrollTop = 0;            // start each project at the top
        lastFocus = document.activeElement;
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
        void card.offsetWidth;                       // commit the start state before animating
        modal.classList.add('is-open');
        const c = modal.querySelector('.pp-modal-close');
        if (c) c.focus();
        // Reflect the open project in the URL (canonical slug) without adding a
        // history entry — replaceState doesn't fire hashchange, so no loop.
        if (btn.dataset.slug) history.replaceState(null, '', '#' + btn.dataset.slug);
      }
      function close(clearHash) {
        if (!modal.classList.contains('is-open')) return;
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
        const done = function (e) {
          if (e.target === card && e.propertyName === 'transform') { modal.hidden = true; card.removeEventListener('transitionend', done); }
        };
        card.addEventListener('transitionend', done);
        if (lastFocus && lastFocus.focus) lastFocus.focus();
        if (clearHash && location.hash) history.replaceState(null, '', location.pathname + location.search);
      }

      // Open/close to match the current hash (on load and on back/forward).
      function syncToHash() {
        const b = btnForHash();
        if (b) open(b); else close(false);
      }

      cards.forEach(function (b) {
        b.addEventListener('click', function (e) {
          // Let modifier/middle clicks do the native thing (open #slug in a new
          // tab → deep-links there); otherwise intercept and open the modal.
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.button !== 0) return;
          e.preventDefault();
          open(b);
        });
      });
      modal.querySelectorAll('[data-close]').forEach(function (el) {
        el.addEventListener('click', function () { close(true); });   // user close clears the hash
      });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(true); });
      window.addEventListener('hashchange', syncToHash);
      syncToHash();                                  // honour a deep link on initial load
    })();

    // ----- Mosaic header banner (rendered from src/data/decor/projects-banner.json) ----
    (function () {
      const panels = document.querySelectorAll('.wi-header-pix');
      if (!panels.length) return;
      const dataEl = document.getElementById('projects-banner-data');
      if (!dataEl) return;
      const ART = JSON.parse(dataEl.textContent);   // { cols, rows, palette, grid }
      const AW = ART.cols, AH = ART.rows, GRID = ART.grid, PAL = ART.palette;
      function paintMosaic(el, cols, rows) {
        const cells = el.children;
        for (let i = 0; i < cells.length; i++) cells[i].style.background = '';
        const startCol = Math.round((cols - AW) / 2);
        const startRow = Math.max(0, Math.floor((rows - AH) / 2));
        for (let r = 0; r < AH && startRow + r < rows; r++) {
          for (let c = 0; c < AW; c++) {
            const v = GRID[r][c];
            if (v < 0) continue;
            const gc = startCol + c;
            if (gc < 0 || gc >= cols) continue;
            const cell = cells[(startRow + r) * cols + gc];
            if (cell) cell.style.background = PAL[v] || '';
          }
        }
      }
      function fill(el) {
        const cs = getComputedStyle(el);
        const cell = parseFloat(cs.getPropertyValue('--card-pix-cell')) || 10;
        const gap = parseFloat(cs.getPropertyValue('--card-pix-gap')) || 3;
        const rows = parseInt(cs.getPropertyValue('--card-pix-rows'), 10) || 6;
        let cols = Math.max(1, Math.floor((el.clientWidth + gap) / (cell + gap)));
        cols = Math.max(1, cols - ((cols - AW) & 1));   // match the art's column parity → art centres exactly (mobile banner only)
        el.style.gridTemplateColumns = 'repeat(' + cols + ', var(--card-pix-cell))';
        const need = cols * rows;
        if (el.childElementCount !== need) {
          while (el.childElementCount > need) el.removeChild(el.lastChild);
          const frag = document.createDocumentFragment();
          for (let i = el.childElementCount; i < need; i++) { const c = document.createElement('div'); c.className = 'pix-cell'; frag.appendChild(c); }
          el.appendChild(frag);
        }
        paintMosaic(el, cols, rows);
      }
      const ro = new ResizeObserver(function (es) { for (const e of es) fill(e.target); });
      panels.forEach(function (el) { fill(el); ro.observe(el); });
    })();
  </script>

  <!-- Decorative corners grow in on load (tree-branch flood). Own script so it's
       independent of any error in the block above. -->
  <script is:inline>
    (function () {
      const decors = Array.prototype.slice.call(document.querySelectorAll('.pp-decor'));
      if (!decors.length) return;
      // Cells render hidden (anim-ready in the markup → no full-grown first paint).
      // Reduced-motion is handled in CSS, so just trigger the grow.
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      setTimeout(function () { decors.forEach(function (d) { d.classList.add('is-grown'); }); }, 60);
    })();
  </script>
</BaseLayout>
