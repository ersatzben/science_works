<script is:inline>
    (function () {
      const grid = document.querySelector('.signup-pix');
      if (!grid) return;
      const ART = [
        '111111111111111111111111',
        '111111111111100011111111',
        '111111111110000001111111',
        '111111111100000000111111',
        '111111111100000000111111',
        '111111111110000001111111',
        '111111111110000011111111',
        '111111111110001111111111',
        '111111111111111110011111',
        '111111111110001110011111',
        '111111110101000111111111',
        '111111110100000101111111',
        '111111100100000111111111',
        '111000000110001111111111',
        '110000000011110000111111',
        '110000000111111000001111',
        '110000000111011000000111',
        '110000000111111000000011',
        '111000001111111000000011',
        '111110011111111100000111',
        '111111111111111110001111',
        '111111111111111111111111'
      ];
      const RED = 'var(--theme)', WHITE = 'var(--almost-white)';
      const frag = document.createDocumentFragment();
      for (let r = 0; r < ART.length; r++) {
        const row = ART[r];
        for (let c = 0; c < row.length; c++) {
          const cell = document.createElement('div');
          cell.className = 'pix-cell';
          cell.style.background = row[c] === '1' ? RED : WHITE;
          frag.appendChild(cell);
        }
      }
      grid.appendChild(frag);
    })();
</script>

<script is:inline>
    (function () {
      const band = document.querySelector('.footer-pixels');
      const dataEl = document.getElementById('footer-band-data');
      if (!band || !dataEl) return;

      // Band art (sw palette+grid). Painted left-aligned: the leftmost columns
      // show, the rest is clipped when the art is longer than the band; when the
      // band is wider than the art, it tiles (col % ART_COLS).
      const art = JSON.parse(dataEl.textContent);
      const ROWS = art.rows;
      const ART_COLS = art.cols;
      const PALETTE = art.palette;
      const GRID = art.grid;

      function paint(cols) {
        const cells = band.children;
        for (let r = 0; r < ROWS; r++) {
          for (let c = 0; c < cols; c++) {
            const cell = cells[r * cols + c];
            if (cell) cell.style.background = PALETTE[GRID[r][c % ART_COLS]] || '';
          }
        }
      }

      function fill() {
        const cs = getComputedStyle(band);
        const cell = parseFloat(cs.getPropertyValue('--small-block-size')) || 10;
        const gap  = parseFloat(cs.getPropertyValue('--small-block-gap'))  || 3;
        const cols = Math.max(1, Math.floor((band.clientWidth + gap) / (cell + gap)));
        band.style.gridTemplateColumns = 'repeat(' + cols + ', var(--small-block-size))';
        const need = cols * ROWS;
        while (band.childElementCount > need) band.removeChild(band.lastChild);
        const frag = document.createDocumentFragment();
        for (let i = band.childElementCount; i < need; i++) {
          const c = document.createElement('div');
          c.className = 'pix-cell';
          frag.appendChild(c);
        }
        band.appendChild(frag);
        paint(cols);
      }
      if (window.ResizeObserver) new ResizeObserver(fill).observe(band);
      else window.addEventListener('resize', fill);
      fill();
    })();
</script>

<script is:inline>
    (function () {
      // Sparse art behind the signup box, in the empty space to its left.
      // Left-aligned, a single iteration (no horizontal tiling); only the
      // non-transparent cells are placed (by grid coords), so the mostly-(-1)
      // art stays light on the DOM.
      const layer = document.querySelector('.footer-signup-pix');
      const dataEl = document.getElementById('footer-signup-data');
      if (!layer || !dataEl) return;
      const art = JSON.parse(dataEl.textContent);
      const ROWS = art.grid.length;        // actual grid height (robust to a stale rows field)
      const ART_COLS = art.cols;
      const PAL = art.palette;
      const GRID = art.grid;

      const LEFT_PAD = 10;   // empty columns before the art, shifting it right
      function fill() {
        const cs = getComputedStyle(layer);
        const cell = parseFloat(cs.getPropertyValue('--sp-cell')) || 5;
        const gap  = parseFloat(cs.getPropertyValue('--sp-gap'))  || 1;
        // Single iteration only; clip to the band width if it's narrower than the art.
        const fit = Math.max(1, Math.floor((layer.clientWidth + gap) / (cell + gap)));
        const artCols = Math.max(0, Math.min(ART_COLS, fit - LEFT_PAD));
        const totalCols = LEFT_PAD + artCols;
        layer.style.gridTemplateColumns = 'repeat(' + totalCols + ', var(--sp-cell))';
        layer.style.gridTemplateRows = 'repeat(' + ROWS + ', var(--sp-cell))';
        layer.textContent = '';
        const frag = document.createDocumentFragment();
        for (let r = 0; r < ROWS; r++) {
          const row = GRID[r];
          for (let c = 0; c < artCols; c++) {
            const v = row[c];
            if (v == null || v < 0) continue;   // transparent → not rendered
            const el = document.createElement('div');
            el.className = 'pix-cell';
            el.style.gridColumn = (LEFT_PAD + c + 1);
            el.style.gridRow = (r + 1);
            el.style.background = PAL[v] || '';
            // Each pixel gets its own period and its own phase, so they fade in
            // and out independently rather than pulsing as a synchronised group.
            const dur = 10 + Math.random() * 25;          // 10–35s: very varied periodicities
            el.style.animationDuration = dur + 's';
            el.style.animationDelay = (-Math.random() * dur) + 's';   // random start point in its cycle
            el.style.animationTimingFunction = 'ease-in-out';
            frag.appendChild(el);
          }
        }
        layer.appendChild(frag);
      }
      if (window.ResizeObserver) new ResizeObserver(fill).observe(layer);
      else window.addEventListener('resize', fill);
      fill();
    })();
</script>

<!-- Brevo mailing-list signup scripts (lifted from science_works_2) -->
  <script is:inline>
    window.REQUIRED_CODE_ERROR_MESSAGE = 'Please choose a country code';
    window.LOCALE = 'en';
    window.EMAIL_INVALID_MESSAGE = window.SMS_INVALID_MESSAGE = 'The information provided is invalid. Please review the field format and try again.';
    window.REQUIRED_ERROR_MESSAGE = 'This field cannot be left blank.';
    window.GENERIC_INVALID_MESSAGE = 'The information provided is invalid. Please review the field format and try again.';
    window.INVALID_NUMBER = 'The information provided is invalid. Please review the field format and try again.';
    window.INVALID_DATE = 'Please enter a valid date';
    window.REQUIRED_MULTISELECT_MESSAGE = 'Please select at least 1 option';
    window.translation = {
      common: {
        selectedList: '{quantity} list selected',
        selectedLists: '{quantity} lists selected',
        selectedOption: '{quantity} selected',
        selectedOptions: '{quantity} selected',
      }
    };
    var AUTOHIDE = Boolean(0);
  </script>
  <script is:inline defer src="https://sibforms.com/forms/end-form/build/main.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      const bg = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim();
      const tickSvg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><path d='M3 8.5 L6.5 12 L13 4.5' stroke='${bg}' stroke-width='2.5' fill='none' stroke-linecap='square'/></svg>`;
      document.documentElement.style.setProperty('--gdpr-tick-svg', `url("data:image/svg+xml,${encodeURIComponent(tickSvg)}")`);

      const form = document.getElementById('sib-form');
      const gdpr = document.getElementById('GDPR_ACCEPTED');
      if (!form || !gdpr) return;
      // Consent nudge only — no inline message (those grew the box). The
      // checkbox is `required`, so the native validation bubble explains it;
      // we just add a small shake to draw the eye. No layout shift.
      form.addEventListener('submit', (e) => {
        if (!gdpr.checked) {
          e.preventDefault();
          e.stopImmediatePropagation();
          gdpr.classList.remove('gdpr-shake');
          void gdpr.offsetWidth;
          gdpr.classList.add('gdpr-shake');
          gdpr.focus();
        }
      }, true);
      gdpr.addEventListener('animationend', () => gdpr.classList.remove('gdpr-shake'));
    });
  </script>
