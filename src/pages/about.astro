---
import BaseLayout from '../layouts/BaseLayout.astro';
import people from '../data/people.json';
import banner from '../data/decor/about-banner.json';
import footerBand from '../data/decor/footer-band.json';
import { glyphFor } from '../lib/glyphs.js';

// Eyebrow decoration: footer-band cluster #2 (rows 0-1, cols 110-119) — a 10×2
// mosaic. Sliced from the band data so it stays in sync. Flanks the heading on
// desktop (the right copy is mirrored via CSS). Row-major: cells 0-9 = top row.
const EYEBROW_START = 110;
const eyebrowCells = [];
for (let r = 0; r < 2; r++)
  for (let c = 0; c < 10; c++)
    eyebrowCells.push(footerBand.palette[footerBand.grid[r][EYEBROW_START + c]]);

// Photos live in /assets/images/people/<filename>; each person's `photo` field
// holds just the filename (see src/data/people.json). The data file is the
// single source of truth for the People section — edit it, not this page.
const PHOTO_DIR = '/assets/images/people/';

// Card glyphs are 9×6 mosaics loaded from src/data/glyphs/<name-slug>.json
// (covers format) via glyphFor(); everyone falls back to _fallback.json for now.

// Tab order + labels. `hidden`/`unhidden` mirror the responsive label parts
// from the original markup (full label on desktop, short label on mobile).
const TABS = [
  { id: 'team',         hidden: 'Our ',                       label: 'Team' },
  { id: 'contributors', hidden: '',                           label: 'Contributors' },
  { id: 'igb',          hidden: 'Independent Governance ',    label: 'Board' },
  // SAB's desktop and mobile labels share no text, so `label` (always shown) is
  // empty: `hidden` is the desktop-only label, `unhidden` the mobile-only one.
  { id: 'sab',          hidden: 'Strategic Advisory Board',   label: '',         unhidden: 'Advisors' },
];

const ICONS = {
  x: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M18.24 2.25h3.31l-7.23 8.26L23 21.75h-6.66l-5.21-6.82-5.97 6.82H1.85l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23zm-1.16 17.52h1.83L7.08 4.13H5.12L17.08 19.77z"/></svg>',
  bluesky: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 10.8C10.91 8.69 7.95 4.75 5.2 2.8 2.57.94 1.56 1.27.9 1.57.14 1.91 0 3.08 0 3.77c0 .69.38 5.65.62 6.48.82 2.73 3.71 3.66 6.38 3.36-3.91.58-7.38 2.01-2.83 7.08 5.01 5.19 6.87-1.11 7.82-4.31.95 3.2 2.05 9.27 7.73 4.31 4.27-4.31 1.17-6.5-2.74-7.08 2.67.3 5.57-.63 6.38-3.36.25-.83.62-5.79.62-6.48 0-.69-.14-1.86-.9-2.21-.66-.3-1.66-.62-4.3 1.24C16.05 4.75 13.09 8.69 12 10.8z"/></svg>',
  linkedin: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43A2.06 2.06 0 1 1 5.34 3.3a2.06 2.06 0 0 1 0 4.13zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>',
};

function initials(name) {
  const parts = name.trim().split(/\s+/);
  const first = parts[0][0] || '';
  const last = parts.length > 1 ? parts[parts.length - 1][0] : '';
  return (first + last).toUpperCase();
}

// Build the visible social links for a person, skipping any blank field.
// X/Bluesky store handles; LinkedIn stores a full URL.
function socialLinks(p) {
  const out = [];
  if (p.x)        out.push({ key: 'x',        label: 'X',        href: `https://x.com/${p.x.replace(/^@/, '')}` });
  if (p.bluesky)  out.push({ key: 'bluesky',  label: 'Bluesky',  href: `https://bsky.app/profile/${p.bluesky.replace(/^@/, '')}` });
  if (p.linkedin) out.push({ key: 'linkedin', label: 'LinkedIn', href: p.linkedin });
  return out;
}
---
<BaseLayout title="About — Science Works">
  <main>
    <div class="wi-header">
      <div class="wi-pix wi-header-pix" aria-hidden="true"></div>
      <h1 class="wi-heading">About</h1>
      <script type="application/json" id="about-banner-data" set:html={JSON.stringify(banner)}></script>
    </div>

    <section class="about-copy-section">
      <div class="about-heading-row">
        <span class="about-eyebrow" aria-hidden="true">{eyebrowCells.map((col) => (<span style={`background:${col}`}></span>))}</span>
        <h2 class="section-heading">What is Science Works?</h2>
        <span class="about-eyebrow about-eyebrow--flip" aria-hidden="true">{eyebrowCells.map((col) => (<span style={`background:${col}`}></span>))}</span>
      </div>
      <div class="about-copy">
        <p class="section-body">Science Works is a research and policy studio focused<br /> on accelerating progress in British science and technology.</p>
        <p class="section-body">We work on building and improving the organisational, technological, and intellectual infrastructure that the UK's research and innovation system needs to stay at the frontier. We work on a small number of identified problems that we believe, if solved, will generate the highest leverage and impact for both the UK and for humanity as a whole.</p>
        <p class="section-body">Science Works is editorially independent, strictly non-partisan, not-for-profit, and not aligned<br /> with any single funder, department, agency, or institution.</p>
      </div>
    </section>

    <section class="people">
      <div class="people-inner">
        <h2 class="people-title">Our People</h2>
        <div class="tabs" role="tablist">
          {TABS.map((t, i) => (
            <button class:list={["tab", { "is-active": i === 0 }]} data-tab={t.id} role="tab">
              {t.hidden && <span class="hidden">{t.hidden}</span>}
              {t.label}
              {t.unhidden && <span class="unhidden">{t.unhidden}</span>}
            </button>
          ))}
        </div>
        <div class="cards-container">
          {TABS.map((t, ti) => (
            <div class="cards-grid" data-panel={t.id} style={ti === 0 ? undefined : "display:none"}>
              {people[t.id].map((p) => (
                <article class="card">
                  <div class="card-top">
                    {p.photo
                      ? <img class="card-photo" src={PHOTO_DIR + p.photo} alt={p.name} loading="lazy" data-initials={initials(p.name)} />
                      : <div class="card-photo is-placeholder" aria-label={p.name}>{initials(p.name)}</div>}
                    <div class="card-headinfo">
                      <div class="card-glyph" aria-hidden="true">
                        {(glyphFor(p.name)?.cells ?? []).map((hex) => (
                          <span class="glyph-cell" style={hex ? `background:${hex}` : undefined}></span>
                        ))}
                      </div>
                      <div class="card-id">
                        <h3 class="card-name">{p.name}</h3>
                        <div class="card-role">{p.role}</div>
                      </div>
                    </div>
                  </div>
                  <p class="card-bio">{p.bio}</p>
                  {socialLinks(p).length > 0 && (
                    <div class="card-socials">
                      {socialLinks(p).map((s) => (
                        <a href={s.href} aria-label={s.label} title={s.label} target="_blank" rel="noopener" set:html={ICONS[s.key]}></a>
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>


<style is:global>
    /* ===== Mosaic header banner (lifted from the Writing page) ===== */
    .wi-header {
      position: relative; height: 190px; overflow: hidden;
      margin: 26px calc(50% - 50vw) 30px;   /* full-bleed sides; small gap under the nav (About main has no top padding) */
      background: var(--bg-secondary);
      transform: scaleY(90%);
      display: flex; align-items: center; justify-content: center;   /* double duty: desktop + mobile (like Writing) */
    }
    .wi-pix { --card-pix-cell: var(--small-block-size); --card-pix-gap: var(--small-block-gap); --card-pix-radius: var(--small-block-radius); --card-pix-color: var(--border-grey); display: grid; grid-auto-rows: var(--card-pix-cell); gap: var(--card-pix-gap); justify-content: center; }
    .wi-pix.wi-header-pix {
      position: absolute; inset: 0; align-content: center;
      --card-pix-cell: 7px;
      --card-pix-gap: 1px;
      --card-pix-radius: var(--cell-radius); /* 2px */
      --card-pix-color: var(--almost-white);
      --card-pix-rows: 24;                    /* 24 × 7 + 23 × 1 = 191px — matches the banner art height */
    }
    .wi-heading { position: relative; z-index: 1; margin: 0; display: inline-block; background: var(--almost-white); padding: 15px 39px; text-transform: lowercase; font-family: 'Copperplate', serif; font-weight: normal; font-size: 28px; letter-spacing: 0.02em; color: var(--text); }

    .section-heading {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      color: var(--text);
      font-size: 26px;
      letter-spacing: 0.02em;
      margin: 0 0 16px;
      margin-left: 0px; 
      text-align: center;
    }
    .section-body {
      font-family: 'Antique Olive', sans-serif;
      font-weight: 300;
      font-size: 13px;
      line-height: 1.5;
      color: var(--text);
      margin: 0 0 16px;
      text-align: center;
    }
    .section-inner {
      max-width: 800px;
      padding: 80px 50px;
      margin: 0 auto;
    }
    .section-inner--wide { max-width: 1400px; }

    /* ---------- About intro: centred copy under the mosaic banner ---------- */
    .about-copy-section {
      padding: 20px 24px 8px;
    }
    .about-copy {
      max-width: 700px;     /* tune */
      margin: 0 auto;
      text-align: center;
    }
    .about-copy .section-body {
      font-size: 15px;
      line-height: 1.6;
      margin: 0 0 18px;
    }
    /* Heading flanked by the 10×2 footer-band eyebrows (desktop only). The row
       can exceed the 700px copy width — it's centred and clips at the viewport
       on narrow desktops; tune the gap if that bites. */
    .about-heading-row {
      display: flex;
      align-items: center;
      justify-content: space-between;   /* eyebrows to the People-container edges, heading centred */
      max-width: 1240px;                /* match the People container width */
      margin: 0 auto 16px;
    }
    .about-heading-row .section-heading { margin: 0; }
    .about-eyebrow {
      flex: 0 0 auto;
      display: grid;
      grid-template-columns: repeat(10, var(--eb-cell));
      grid-auto-rows: var(--eb-cell);
      gap: var(--eb-gap);
      --eb-cell: 10px;           /* tune */
      --eb-gap: 2px;
      transform: translateY(150px);     /* drop down, past the heading */
    }
    .about-eyebrow span { border-radius: 2px; }
    .about-eyebrow--flip { transform: translateY(150px) scaleX(-1); }   /* mirror + same drop */
    .copy-link {
      color: var(--theme);
      font-weight: bold;
      text-decoration: none;
      white-space: nowrap;
    }
    .copy-link:hover { text-decoration: underline; }
    .copy-link .arrow {
      display: inline-block;
      transition: transform 0.2s ease;
    }
    .copy-link:hover .arrow { transform: translateX(3px); }

    /* ---------- Our People ---------- */
    .people {
      padding: 44px 32px 80px;
    }
    .people-inner {
      max-width: 1240px;
      margin: 0 auto;
    }
    .people-title {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      color: var(--text);
      font-size: 28px;
      letter-spacing: 0.02em;
      margin: 0 0 18px;
    }

     .unhidden { display: none; }

    /* Horizontal tab menu: full-width white rounded bar split into three equal
       sections; the active section is an inset red-outlined rounded box. */
    .tabs {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      background: var(--almost-white);
      border: 1px solid var(--border-grey);
      border-radius: 4px;
      padding: 0;
      margin-bottom: 16px;
    }
    .tab {
      appearance: none;
      background: none;
      border: 1.5px solid transparent;
      border-radius: 4px;       /* sits just inside the container's 12px */
      padding: 9px 8px;
      font-family: 'Roboto', sans-serif;
      font-size: 16px;
      color: var(--text);
      text-align: center;
      cursor: pointer;
      transition: color 0.15s ease, border-color 0.15s ease;
    }
    .tab:hover { color: var(--theme); }
    .tab.is-active {
      color: var(--theme);
      font-weight: bold;
      border-color: rgba(235, 49, 49, 0.55);
    }

    /* White container the cards sit inside, so the cards pop. */
    .cards-container {
      background: var(--almost-white);
      border-radius: 4px;
      padding: 14px;
    }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    .card {
      background: var(--bg);
      border-radius: 4px;
      padding: 22px 24px;     /* tighter top/bottom than sides */
      display: flex;
      flex-direction: column;
      border: 0.5px solid var(--border-grey); 
    }
    .card-top {
      display: flex;
      gap: 14px;
    }
    .card-photo {
      flex: 0 0 auto;
      width: 168px;
      height: 188px;
      border-radius: 2px;     /* same rounding as the homepage cells */
      object-fit: cover;
      display: block;
    }
    /* Initials fallback until real photos arrive. */
    .card-photo.is-placeholder {
      background: var(--beige);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 50px;
      color: var(--text);
      opacity: 0.85;
    }
    .card-headinfo {
      flex: 1;
      min-width: 0;
      height: 188px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      border-bottom: 0.5px solid var(--border-grey); 
    }
    /* Glyph: a 5×5 grid of cells, same metrics as the homepage dot-matrix.
       Colours are seeded randomly for now; later each person can author their
       own. Empty cells are transparent so the card background shows through. */
    .card-glyph {
      display: grid;
      grid-template-columns: repeat(9, 10px);
      grid-template-rows: repeat(6, 10px);
      gap: 1.5px;
      align-self: flex-start;
    }
    .glyph-cell {
      width: 10px;
      height: 10px;
      border-radius: 1px;
    }
    .card-name {
      font-family: 'Copperplate', serif;
      font-weight: 500;
      color: var(--text);
      font-size: 19px;
      line-height: 1.12;
      letter-spacing: 0.02em;
      margin: 0 0 2px;
    }
    .card-role {
      font-family: 'Roboto', sans-serif;
      color: var(--theme);
      font-size: 13px;
      text-transform: uppercase;
      line-height: 1.3;
      margin: 0;
      margin-bottom: 5px; 
    }
    .card-bio {
      font-family: 'Antique Olive', sans-serif; font-weight: 300; 
      color: var(--text);
      font-size: 14px;
      line-height: 1.55;
      margin: 20px 0 24px;
      padding: 0 10px 0 1px;
    }
    .card-socials {
      display: flex;
      gap: 14px;
      margin-top: auto;     /* pin to the bottom of the (stretched) card */
      padding-top: 18px;
    }
    .card-socials a {
      display: inline-flex;
      width: 20px;
      height: 20px;
      color: var(--theme);
      opacity: 0.7;
      transition: opacity 0.15s ease;
    }
    .card-socials a:hover { opacity: 1; }
    .card-socials svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
      display: block;
    }


    @media (max-width: 1080px) {
      .cards-grid { grid-template-columns: repeat(2, 1fr); }
    }

@media (max-width: 720px) {
      .wi-header { margin-top: 20px; margin-bottom: 15px; }   /* match Writing's spacing above the banner */
      .wi-heading { font-size: 25px; padding: 18px 35px; }

      .about-copy-section { padding: 14px 20px 4px; }
      .section-heading { font-size: 20px; }
      .about-heading-row { gap: 0; margin-bottom: 10px; }   /* eyebrows hidden on mobile */
      .about-eyebrow { display: none; }                     /* desktop-only decoration */
      .section-body br { display: none; }
      .about-copy .section-body {
        line-height: 1.4;
        margin: 0 0 18px;
        font-size: 15px;
      }

      .people { margin-top: 32px; padding: 0 20px 60px; }
      .people-title { font-size: 22px; margin-bottom: 14px; }
      
      .tabs {border-radius: 2px; margin-bottom: 10px; }
      .tab {font-size: 12px; padding: 3px 0; border-radius: 2px; }
      .hidden { display: none; }
      .unhidden {display: inline; }

      .cards-container { padding: 14px; border-radius: 6px; }
      .card { padding:18px; border-radius: 6px; position: relative; }
      .cards-grid { grid-template-columns: 1fr; border-radius: 6px; gap: 14px; }
      .card-photo { width: 100px; height: 130px; }
      /* leave room on the right for the vertically-stacked social icons */
      .card-headinfo { height: 135px; padding-right: 28px; }
      /* Socials: stacked in the card's top-right corner instead of the
         desktop bottom row. Anchored to the card padding (10px). */
      .card-socials {
        position: absolute;
        top: 16px;
        right: 10px;
        flex-direction: column;
        gap: 12px;
        margin-top: 0;
        padding-top: 0;
      }
      .card-glyph {
        grid-template-columns: repeat(9, 8px);
        grid-template-rows: repeat(6, 8px);
        gap: 2px;
        padding-top: 1px;
      }
      .card-name { font-size: 16px; }
      .card-role { font-size: 11px; margin-bottom: 0; line-height: 1.4; }
      .glyph-cell {
        width: 8px;
        height: 8px;
        border-radius: 1px;
      }
      .card-bio { font-size: 13px; line-height: 1.6; margin-top: 16px; margin-bottom: 4px; padding-right: 0; }
    }

</style>

<script is:inline>

    // ----- Our People: tab switching + photo fallback -------------------
    // Cards are rendered server-side from src/data/people.json. This only
    // toggles which group is visible and swaps a missing photo for the
    // initials placeholder.
    (function () {
      const tabs = document.querySelectorAll('.tab');
      const panels = document.querySelectorAll('[data-panel]');
      tabs.forEach(function (t) {
        t.addEventListener('click', function () {
          tabs.forEach(function (o) { o.classList.remove('is-active'); });
          t.classList.add('is-active');
          panels.forEach(function (p) {
            p.style.display = p.dataset.panel === t.dataset.tab ? '' : 'none';
          });
        });
      });

      document.querySelectorAll('img.card-photo').forEach(function (img) {
        img.addEventListener('error', function () {
          const ph = document.createElement('div');
          ph.className = 'card-photo is-placeholder';
          ph.textContent = img.dataset.initials || '';
          ph.setAttribute('aria-label', img.alt);
          img.replaceWith(ph);
        });
      });
    })();

    // ----- Mosaic header banner (rendered from src/data/decor/about-banner.json) ----
    (function () {
      const panels = document.querySelectorAll('.wi-header-pix');
      if (!panels.length) return;

      const dataEl = document.getElementById('about-banner-data');
      if (!dataEl) return;
      const ART = JSON.parse(dataEl.textContent);   // { cols, rows, palette, grid }  (-1 = transparent)
      const AW = ART.cols, AH = ART.rows, GRID = ART.grid, PAL = ART.palette;

      function paintMosaic(el, cols, rows) {
        const cells = el.children;
        for (let i = 0; i < cells.length; i++) cells[i].style.background = '';   // reset to CSS default (field cell)
        const startCol = Math.round((cols - AW) / 2);                            // centre the art horizontally
        const startRow = Math.max(0, Math.floor((rows - AH) / 2));
        for (let r = 0; r < AH && startRow + r < rows; r++) {
          for (let c = 0; c < AW; c++) {
            const v = GRID[r][c];
            if (v < 0) continue;                                                 // transparent → leave field cell
            const gc = startCol + c;
            if (gc < 0 || gc >= cols) continue;
            const cell = cells[(startRow + r) * cols + gc];
            if (cell) cell.style.background = PAL[v] || '';
          }
        }
      }

      function fill(el) {
        const cs = getComputedStyle(el);
        const cell = parseFloat(cs.getPropertyValue('--card-pix-cell')) || 10;
        const gap  = parseFloat(cs.getPropertyValue('--card-pix-gap'))  || 3;
        const rows = parseInt(cs.getPropertyValue('--card-pix-rows'), 10) || 6;
        let cols = Math.max(1, Math.floor((el.clientWidth + gap) / (cell + gap)));
        cols = Math.max(1, cols - ((cols - AW) & 1));   // match the art's column parity → art centres exactly (no half-cell drift)
        el.style.gridTemplateColumns = 'repeat(' + cols + ', var(--card-pix-cell))';
        const need = cols * rows;
        if (el.childElementCount !== need) {
          while (el.childElementCount > need) el.removeChild(el.lastChild);
          const frag = document.createDocumentFragment();
          for (let i = el.childElementCount; i < need; i++) {
            const c = document.createElement('div'); c.className = 'pix-cell'; frag.appendChild(c);
          }
          el.appendChild(frag);
        }
        paintMosaic(el, cols, rows);
      }
      const ro = new ResizeObserver(function (es) { for (const e of es) fill(e.target); });
      panels.forEach(function (el) { fill(el); ro.observe(el); });
    })();

</script>
</BaseLayout>
