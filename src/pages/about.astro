---
import BaseLayout from '../layouts/BaseLayout.astro';
import people from '../data/people.json';
import banner from '../data/decor/about-banner.json';
import { glyphFor } from '../lib/glyphs.js';

// Photos live in /assets/images/people/<filename>; each person's `photo` field
// holds just the filename (see src/data/people.json). The data file is the
// single source of truth for the People section — edit it, not this page.
const PHOTO_DIR = '/assets/images/people/';

// Card glyphs are 9×6 mosaics loaded from src/data/glyphs/<name-slug>.json
// (covers format) via glyphFor(); everyone falls back to _fallback.json for now.

// Tab order + labels. `hidden`/`unhidden` mirror the responsive label parts
// from the original markup (full label on desktop, short label on mobile).
const TABS = [
  { id: 'team',         hidden: 'Our ',                       label: 'Team' },
  { id: 'contributors', hidden: '',                           label: 'Contributors' },
  { id: 'igb',          hidden: 'Independent Governance ',    label: 'Board' },
  // SAB's desktop and mobile labels share no text, so `label` (always shown) is
  // empty: `hidden` is the desktop-only label, `unhidden` the mobile-only one.
  { id: 'sab',          hidden: 'Strategic Advisory Board',   label: '',         unhidden: 'Advisors' },
];

const ICONS = {
  x: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M18.24 2.25h3.31l-7.23 8.26L23 21.75h-6.66l-5.21-6.82-5.97 6.82H1.85l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23zm-1.16 17.52h1.83L7.08 4.13H5.12L17.08 19.77z"/></svg>',
  bluesky: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 10.8C10.91 8.69 7.95 4.75 5.2 2.8 2.57.94 1.56 1.27.9 1.57.14 1.91 0 3.08 0 3.77c0 .69.38 5.65.62 6.48.82 2.73 3.71 3.66 6.38 3.36-3.91.58-7.38 2.01-2.83 7.08 5.01 5.19 6.87-1.11 7.82-4.31.95 3.2 2.05 9.27 7.73 4.31 4.27-4.31 1.17-6.5-2.74-7.08 2.67.3 5.57-.63 6.38-3.36.25-.83.62-5.79.62-6.48 0-.69-.14-1.86-.9-2.21-.66-.3-1.66-.62-4.3 1.24C16.05 4.75 13.09 8.69 12 10.8z"/></svg>',
  linkedin: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43A2.06 2.06 0 1 1 5.34 3.3a2.06 2.06 0 0 1 0 4.13zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>',
};

function initials(name) {
  const parts = name.trim().split(/\s+/);
  const first = parts[0][0] || '';
  const last = parts.length > 1 ? parts[parts.length - 1][0] : '';
  return (first + last).toUpperCase();
}

// Build the visible social links for a person, skipping any blank field.
// X/Bluesky store handles; LinkedIn stores a full URL.
function socialLinks(p) {
  const out = [];
  if (p.x)        out.push({ key: 'x',        label: 'X',        href: `https://x.com/${p.x.replace(/^@/, '')}` });
  if (p.bluesky)  out.push({ key: 'bluesky',  label: 'Bluesky',  href: `https://bsky.app/profile/${p.bluesky.replace(/^@/, '')}` });
  if (p.linkedin) out.push({ key: 'linkedin', label: 'LinkedIn', href: p.linkedin });
  return out;
}
---
<BaseLayout title="About — Science Works">
  <main>
    <div class="wi-header">
      <div class="wi-pix wi-header-pix" aria-hidden="true"></div>
      <h1 class="wi-heading">About</h1>
      <script type="application/json" id="about-banner-data" set:html={JSON.stringify(banner)}></script>
    </div>

    <section class="about-hero-section">
      <div class="about-row">
        <div class="about-hero">
          <canvas id="helix" aria-hidden="true"></canvas>
        </div>
        <div class="about-copy">
          <h2 class="section-heading">What is Science Works?</h2>
          <p class="section-body">Science Works is a research and policy studio focused<br /> on accelerating progress in British science and technology.</p>
          <p class="section-body">We work on building and improving the organisational, technological,<br /> and intellectual infrastructure that the UK's research and innovation system needs to stay at the frontier. We work on a small number of identified problems that we believe, if solved, will generate the highest leverage<br /> and impact for both the UK and for humanity as a whole.</p>
          <p class="section-body">Science Works is editorially independent, strictly non-partisan,<br /> not-for-profit, and not aligned with any single funder,<br /> department, agency, or institution.</p>
          <!-- <p class="section-body"><a class="copy-link" href="/charter">Read more about our approach &nbsp;<span class="arrow">&rarr;</span></a></p> -->
        </div>
      </div>
    </section>

    <section class="people">
      <div class="people-inner">
        <h2 class="people-title">Our People</h2>
        <div class="tabs" role="tablist">
          {TABS.map((t, i) => (
            <button class:list={["tab", { "is-active": i === 0 }]} data-tab={t.id} role="tab">
              {t.hidden && <span class="hidden">{t.hidden}</span>}
              {t.label}
              {t.unhidden && <span class="unhidden">{t.unhidden}</span>}
            </button>
          ))}
        </div>
        <div class="cards-container">
          {TABS.map((t, ti) => (
            <div class="cards-grid" data-panel={t.id} style={ti === 0 ? undefined : "display:none"}>
              {people[t.id].map((p) => (
                <article class="card">
                  <div class="card-top">
                    {p.photo
                      ? <img class="card-photo" src={PHOTO_DIR + p.photo} alt={p.name} loading="lazy" data-initials={initials(p.name)} />
                      : <div class="card-photo is-placeholder" aria-label={p.name}>{initials(p.name)}</div>}
                    <div class="card-headinfo">
                      <div class="card-glyph" aria-hidden="true">
                        {(glyphFor(p.name)?.cells ?? []).map((hex) => (
                          <span class="glyph-cell" style={hex ? `background:${hex}` : undefined}></span>
                        ))}
                      </div>
                      <div class="card-id">
                        <h3 class="card-name">{p.name}</h3>
                        <div class="card-role">{p.role}</div>
                      </div>
                    </div>
                  </div>
                  <p class="card-bio">{p.bio}</p>
                  {socialLinks(p).length > 0 && (
                    <div class="card-socials">
                      {socialLinks(p).map((s) => (
                        <a href={s.href} aria-label={s.label} title={s.label} target="_blank" rel="noopener" set:html={ICONS[s.key]}></a>
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>


<style is:global>
    /* ===== Mosaic header banner (lifted from the Writing page) ===== */
    .wi-header {
      position: relative; height: 190px; overflow: hidden;
      margin: 26px calc(50% - 50vw) 30px;   /* full-bleed sides; small gap under the nav (About main has no top padding) */
      background: var(--bg-secondary);
      transform: scaleY(90%);
      display: none; align-items: center; justify-content: center;
    }
    .wi-pix { --card-pix-cell: var(--small-block-size); --card-pix-gap: var(--small-block-gap); --card-pix-radius: var(--small-block-radius); --card-pix-color: var(--border-grey); display: grid; grid-auto-rows: var(--card-pix-cell); gap: var(--card-pix-gap); justify-content: center; }
    .wi-pix.wi-header-pix {
      position: absolute; inset: 0; align-content: center;
      --card-pix-cell: 7px;
      --card-pix-gap: 1px;
      --card-pix-radius: var(--cell-radius); /* 2px */
      --card-pix-color: var(--almost-white);
      --card-pix-rows: 24;                    /* 24 × 7 + 23 × 1 = 191px — matches the banner art height */
    }
    .wi-heading { position: relative; z-index: 1; margin: 0; display: inline-block; background: var(--almost-white); padding: 15px 27px; text-transform: lowercase; font-family: 'Copperplate', serif; font-weight: normal; font-size: 28px; letter-spacing: 0.02em; color: var(--text); }

    .section-heading {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      color: var(--text);
      font-size: 30px;
      letter-spacing: 0.02em;
      margin: 0 0 24px;
      text-align: right;
    }
    .section-body {
      font-family: 'Antique Olive', sans-serif;
      font-weight: 300; 
      font-size: 13px;
      line-height: 1.5;
      color: var(--text);
      margin: 0 0 16px;
      text-align: right;
    }
    .section-inner {
      max-width: 800px;
      padding: 80px 50px;
      margin: 0 auto;
    }
    .section-inner--wide { max-width: 1400px; }

    /* ---------- About hero: helix animation left, text right ---------- */
    .about-row {
      display: flex;
      /* Stable baseline for the helix canvas, but grows to fit taller copy so
         the vertically-centred heading is never pushed off the top. */
      min-height: 500px;
      margin-top: 0px;
      padding: 20px 0;
    }
    .about-hero {
      flex: 0 0 44%;
      position: relative;
      overflow: hidden;
      margin: 25px 0;            /* 50px shorter than the row, vertically centred */
    }
    .about-hero canvas {
      display: block;
      /* Absolutely positioned so the canvas fills the hero but never
         contributes to its layout height — without this, the JS-set pixel
         buffer (height × devicePixelRatio) inflates the box and the row height
         ratchets up on every resize. */
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }
    .about-copy {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-end;         /* push the text block to the column's right edge */
      /* Right edge tracks the People grid's right edge (centred 1240 box, 32px min
         gutter); left padding keeps a gap from the DNA. */
      padding: 0 max(32px, (100vw - 1240px) / 2) 0 100px;
      box-sizing: border-box;
      transform: translateY(80px);   /* nudge down — visual only, no layout feedback to the canvas */
    }
    .about-copy .section-heading {
      max-width: 560px;
    }
    .about-copy .section-body {
      font-size: 16px;
      line-height: 1.6;
      margin: 0 0 18px;
      max-width: 560px;
    }
    .copy-link {
      color: var(--theme);
      font-weight: bold;
      text-decoration: none;
      white-space: nowrap;
    }
    .copy-link:hover { text-decoration: underline; }
    .copy-link .arrow {
      display: inline-block;
      transition: transform 0.2s ease;
    }
    .copy-link:hover .arrow { transform: translateX(3px); }

    /* ---------- Our People ---------- */
    .people {
      padding: 44px 32px 80px;
    }
    .people-inner {
      max-width: 1240px;
      margin: 0 auto;
    }
    .people-title {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      color: var(--text);
      font-size: 28px;
      letter-spacing: 0.02em;
      margin: 0 0 18px;
    }

     .unhidden { display: none; }

    /* Horizontal tab menu: full-width white rounded bar split into three equal
       sections; the active section is an inset red-outlined rounded box. */
    .tabs {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      background: var(--almost-white);
      border: 1px solid var(--border-grey);
      border-radius: 4px;
      padding: 0;
      margin-bottom: 16px;
    }
    .tab {
      appearance: none;
      background: none;
      border: 1.5px solid transparent;
      border-radius: 4px;       /* sits just inside the container's 12px */
      padding: 9px 8px;
      font-family: 'Roboto', sans-serif;
      font-size: 16px;
      color: var(--text);
      text-align: center;
      cursor: pointer;
      transition: color 0.15s ease, border-color 0.15s ease;
    }
    .tab:hover { color: var(--theme); }
    .tab.is-active {
      color: var(--theme);
      font-weight: bold;
      border-color: rgba(235, 49, 49, 0.55);
    }

    /* White container the cards sit inside, so the cards pop. */
    .cards-container {
      background: var(--almost-white);
      border-radius: 4px;
      padding: 14px;
    }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    .card {
      background: var(--bg);
      border-radius: 4px;
      padding: 22px 24px;     /* tighter top/bottom than sides */
      display: flex;
      flex-direction: column;
      border: 0.5px solid var(--border-grey); 
    }
    .card-top {
      display: flex;
      gap: 14px;
    }
    .card-photo {
      flex: 0 0 auto;
      width: 168px;
      height: 188px;
      border-radius: 2px;     /* same rounding as the homepage cells */
      object-fit: cover;
      display: block;
    }
    /* Initials fallback until real photos arrive. */
    .card-photo.is-placeholder {
      background: var(--beige);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 50px;
      color: var(--text);
      opacity: 0.85;
    }
    .card-headinfo {
      flex: 1;
      min-width: 0;
      height: 188px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      border-bottom: 0.5px solid var(--border-grey); 
    }
    /* Glyph: a 5×5 grid of cells, same metrics as the homepage dot-matrix.
       Colours are seeded randomly for now; later each person can author their
       own. Empty cells are transparent so the card background shows through. */
    .card-glyph {
      display: grid;
      grid-template-columns: repeat(9, 10px);
      grid-template-rows: repeat(6, 10px);
      gap: 1.5px;
      align-self: flex-start;
    }
    .glyph-cell {
      width: 10px;
      height: 10px;
      border-radius: 1px;
    }
    .card-name {
      font-family: 'Copperplate', serif;
      font-weight: 500;
      color: var(--text);
      font-size: 19px;
      line-height: 1.12;
      letter-spacing: 0.02em;
      margin: 0 0 2px;
    }
    .card-role {
      font-family: 'Roboto', sans-serif;
      color: var(--theme);
      font-size: 13px;
      text-transform: uppercase;
      line-height: 1.3;
      margin: 0;
      margin-bottom: 5px; 
    }
    .card-bio {
      font-family: 'Antique Olive', sans-serif; font-weight: 300; 
      color: var(--text);
      font-size: 14px;
      line-height: 1.55;
      margin: 20px 0 24px;
      padding: 0 10px 0 1px;
    }
    .card-socials {
      display: flex;
      gap: 14px;
      margin-top: auto;     /* pin to the bottom of the (stretched) card */
      padding-top: 18px;
    }
    .card-socials a {
      display: inline-flex;
      width: 20px;
      height: 20px;
      color: var(--theme);
      opacity: 0.7;
      transition: opacity 0.15s ease;
    }
    .card-socials a:hover { opacity: 1; }
    .card-socials svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
      display: block;
    }


    @media (max-width: 1080px) {
      .cards-grid { grid-template-columns: repeat(2, 1fr); }
    }

@media (max-width: 720px) {
      .wi-header { display: flex; margin-top: 20px; margin-bottom: 15px; }   /* match Writing's spacing above the banner */
      .wi-heading { font-size: 25px; padding: 18px 35px; }

      .about-row {min-height: 400px; background-color: var(--almost-white); margin-top: 36px; margin-bottom: 24px; padding-top: 34px; padding-bottom: 10px; }
      
      .about-hero { display: none; }
      .about-copy {padding: 0 20px; align-items: stretch; 
      transform: translateY(0); 
      }

      .about-copy br {display: none;}
      .section-heading { text-align: left; font-size: 22px; margin-bottom: 10px;}
      .section-body { text-align: left; }
      .about-copy .section-body {
        font-size: 16px;
        line-height: 1.4;
        margin: 0 0 18px;
        max-width: 560px;
        font-size: 15px; 
      }

      .people { margin-top: 32px; padding: 0 20px 60px; }
      .people-title { font-size: 22px; margin-bottom: 14px; }
      
      .tabs {border-radius: 2px; margin-bottom: 10px; }
      .tab {font-size: 12px; padding: 3px 0; border-radius: 2px; }
      .hidden { display: none; }
      .unhidden {display: inline; }

      .cards-container { padding: 14px; border-radius: 6px; }
      .card { padding:18px; border-radius: 6px; position: relative; }
      .cards-grid { grid-template-columns: 1fr; border-radius: 6px; gap: 14px; }
      .card-photo { width: 100px; height: 130px; }
      /* leave room on the right for the vertically-stacked social icons */
      .card-headinfo { height: 135px; padding-right: 28px; }
      /* Socials: stacked in the card's top-right corner instead of the
         desktop bottom row. Anchored to the card padding (10px). */
      .card-socials {
        position: absolute;
        top: 16px;
        right: 10px;
        flex-direction: column;
        gap: 12px;
        margin-top: 0;
        padding-top: 0;
      }
      .card-glyph {
        grid-template-columns: repeat(9, 8px);
        grid-template-rows: repeat(6, 8px);
        gap: 2px;
        padding-top: 1px;
      }
      .card-name { font-size: 16px; }
      .card-role { font-size: 11px; margin-bottom: 0; line-height: 1.4; }
      .glyph-cell {
        width: 8px;
        height: 8px;
        border-radius: 1px;
      }
      .card-bio { font-size: 13px; line-height: 1.6; margin-top: 16px; margin-bottom: 4px; padding-right: 0; }
    }

</style>

<script is:inline>
    // ----- Falling double-helix rain (density-field model) ---------------
    // Strands fall through a tanh density field (runs + voids) with noise
    // scatter and depth-driven alpha; accent particles sweep on their own
    // stretched sine paths. Tuning knobs sit at the top of the IIFE.
    (function () {
      const cv = document.getElementById('helix');
      if (!cv) return;
      const ctx = cv.getContext('2d');

      /* ====================================================================
         TUNING KNOBS
         Each block below is a self-contained group. Change the numbers and
         reload the page. Most knobs are independent, but a few interact —
         those interactions are noted inline.
         ==================================================================== */

      /* --- OVERALL SCALE -------------------------------------------------- */
      const SCALE = 0.64;  // uniform zoom of the whole helix (blocks + spacing + width).

      /* --- CELL APPEARANCE ------------------------------------------------ */
      const CELL   = 14 * SCALE;   // block size in px (square). Your original 14x14.
      const RADIUS = 2;    // corner rounding of each block. 0 = sharp squares.

      /* --- COLOUR --------------------------------------------------------- */
      // Helix strands share one weighted palette; repetition sets pick odds,
      // per the [H] marks in colours_and_fonts.md: red ×3, coral ×2, others ×1.
      const palH = ['#eb3131', '#eb3131', '#eb3131', '#f45e57', '#f45e57',
                    '#66223b', '#00726b', '#004ee6'];
      const palA = palH;
      const palB = palH;

      /* --- MOTION --------------------------------------------------------- */
      const fallSpeed = 16;    // px/sec the whole pattern descends. Lower = slower rain.
      const wavelength = 360 * SCALE;  // px of vertical travel for one full helix turn.
                               // LARGER = turns more spread out vertically.
      const twist = 0.32;      // how fast the helix rotates as it falls.
                               // 0 = strands frozen in shape; higher = livelier swirl.
      const ampFactor = 0.85;  // helix width as a fraction of the base amplitude.
                               // 1 = full width; lower = narrower helix.
      const ARM_PHASE = 0.8;   // phase offset (rad, ~pi/4) on the 2nd strand
                               // to break the mirror symmetry. 0 = symmetric.

      /* --- DEPTH / TRANSPARENCY ------------------------------------------ */
      // Each cell's opacity is driven by its position in the twist (cos phase),
      // so cells "behind" the centre line fade. al = ALPHA_FLOOR + (1-FLOOR)*depth.
      const ALPHA_FLOOR = 0.5; // minimum opacity for the farthest cells.
                               // RAISE toward 0.7 to keep deep-red back-strand
                               // cells visible on a light background.

      /* --- DENSITY FIELD (the "[rand~]->[*~ s]->[tanh~]->[scale~]" curve) -
         A sine runs down the strand; tanh squashes it; the result 0..1 is the
         local density. High density -> tight gaps (a run); low -> big gap (a void).
         ------------------------------------------------------------------- */
      const PERIOD   = 150 * SCALE;  // px of vertical travel per density cycle (your "f").
                             // One run + one void ~= this distance.
      const SHARP    = 0.8;  // your "s". Squareness of the density curve.
                             //   ~1   = gently breathing density, no real voids
                             //   ~2.2 = soft shoulders, legible runs (current)
                             //   ~4+  = hard runs + clean voids (square-wave-ish)
      const DMIN_GAP = 0.13; // gap factor at FULL density (tight core).
                             // LOWER = denser runs. (x spacing = px between cells.)
      const DMAX_GAP = 1.4;  // gap factor at ZERO density (the void).
                             // void px ~= DMAX_GAP * spacing. 3.4*26 ~= 88px ~= pi/2 turn.

      const spacing  = 26 * SCALE;   // base px the gap factors multiply. Sets overall scale.

      /* --- NOISE / SCATTER (breaks the smooth look) ----------------------
         Cores stay solid; only shoulders & voids get thinned by multi-octave
         noise, so a few stray cells appear/vanish around each run.
         ------------------------------------------------------------------- */
      const CORE_THRESHOLD = 0.6;  // density above this keeps EVERY cell (solid cores).
                                   // LOWER toward 0.6 to protect more cells = denser.
      const KEEP_FLOOR     = 0.05; // baseline keep-probability added in the shoulders,
                                   // so low-density zones don't empty out completely.
      const NOISE_AMOUNT   = 0.38; // how strongly noise scatters the shoulder cells.
                                   // RAISE = grainier/more broken; LOWER = cleaner.
      const NOISE_SCALE    = 0.18; // spatial frequency of that scatter along the strand.

      /* --- HORIZONTAL JITTER --------------------------------------------- */
      const JITTER = 12 * SCALE;   // px of random left/right wobble per cell.
                           // LOWER for cleaner bead-like runs; 0 = dead straight.

      /* --- ACCENT PARTICLES ----------------------------------------------
         Non-red blocks swept up in the motion on their own stretched sine
         paths. They fall faster than the strands and never trace them exactly.
         ------------------------------------------------------------------- */
      const PARTICLE_COUNT = 9;   // how many accent particles. 0 = none.
      const ACCENTS = ['#a3c0d7', '#64b37b', '#faf8f6', '#4b5cce', '#72679b'];

      /* --- LAYOUT --------------------------------------------------------- */
      const X_SHIFT = 60 * SCALE;  // px the whole helix is nudged right of centre. 0 = centred.

      /* ====================================================================
         ENGINE — you shouldn't need to edit below here.
         ==================================================================== */

      const TWO_PI = Math.PI * 2;
      let W, H, midX, amp, dpr, pHalf = 0, topWorld = 0;

      function rand(seed) {
        const x = Math.sin(seed * 99991.7) * 43758.545;
        return x - Math.floor(x);
      }

      // Multi-octave noise (~[-1.6, 1.6]) for the scatter.
      function octaveNoise(t) {
        return 1.1 * Math.sin(t * 0.7)
             + 0.3 * Math.sin(t * 1.9 + 1.3)
             + 0.2 * Math.sin(t * 4.7 + 2.7);
      }

      // Density 0..1 at a given world-y: sine -> *SHARP -> tanh -> scale to 0..1.
      function densityAt(yw) {
        const sig = Math.sin((yw / PERIOD) * TWO_PI);
        const t = Math.tanh(sig * SHARP);
        return (t + 1) / 2;
      }

      const blocks = [];
      function makeBlock(strand, yWorld, density) {
        const jitter = (rand(yWorld * 0.13 + strand * 7.7) - 0.5) * JITTER;
        let live = true;
        if (density <= CORE_THRESHOLD) {
          const noise = octaveNoise(yWorld * NOISE_SCALE + strand * 4.1) * NOISE_AMOUNT;
          const keepProb = density + KEEP_FLOOR + noise;
          live = rand(yWorld * 0.53 + strand * 9.3) < keepProb;
        }
        return {
          strand, yWorld, jitter,
          colA: palA[Math.floor(rand(yWorld * 1.7 + 0.5) * palA.length)],
          colB: palB[Math.floor(rand(yWorld * 2.3 + 0.9) * palB.length)],
          live,
        };
      }

      const particles = [];
      function seedParticles() {
        particles.length = 0;
        const span = H + 120;
        for (let i = 0; i < PARTICLE_COUNT; i++) {
          const r1 = rand(i * 1.7 + 0.3);
          const r2 = rand(i * 2.9 + 1.1);
          const r3 = rand(i * 3.7 + 2.2);
          const r4 = rand(i * 5.1 + 0.7);
          particles.push({
            cy: r2 * span,                    // staggered start
            amp: pHalf * (0.55 + 0.45 * r4),  // up to the full unreduced range
            wavelength: span * (1.6 + r3 * 1.9), // stretched -> slow sweep
            phase: r1 * TWO_PI,
            col: ACCENTS[Math.floor(r4 * ACCENTS.length)],
            vy: 34 + r2 * 36,                 // faster than strands
          });
        }
      }

      function seed() {
        blocks.length = 0;
        const span = H + 120;
        const positions = [];
        let yw = 0;
        while (yw < span) {
          positions.push(yw);
          const d = densityAt(yw);
          const f = DMAX_GAP + (DMIN_GAP - DMAX_GAP) * d; // d=1 -> tight, d=0 -> void
          yw += spacing * f;
          yw += 0.0001;  // guard against a zero-gap lock if DMIN_GAP is ever 0
        }
        topWorld = yw;   // loop point -> seamless wrap
        for (let k = 0; k < positions.length; k++) {
          const p = positions[k];
          const d = densityAt(p);
          blocks.push(makeBlock(0, p, d));
          blocks.push(makeBlock(1, p + spacing * DMIN_GAP * 0.5, d));
        }
      }

      function resize() {
        const r = cv.getBoundingClientRect();
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        W = Math.round(r.width);
        H = Math.round(r.height);
        cv.width = W * dpr;
        cv.height = H * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        midX = W / 2 + X_SHIFT;
        const ampBase = Math.min(W * 0.40, 188) * SCALE;
        amp = ampBase * ampFactor;
        pHalf = ampBase * 1.25;   // particles roam the wider, original span
        seed();
        seedParticles();
      }
      resize();
      window.addEventListener('resize', resize);

      function roundRectPath(x, y, w, h, r) {
        if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(x, y, w, h, r); return; }
        ctx.beginPath();
        ctx.moveTo(x + r, y);
        ctx.arcTo(x + w, y, x + w, y + h, r);
        ctx.arcTo(x + w, y + h, x, y + h, r);
        ctx.arcTo(x, y + h, x, y, r);
        ctx.arcTo(x, y, x + w, y, r);
        ctx.closePath();
      }

      let last = performance.now();
      let offset = 0;
      let ptime = 0;

      function draw(now) {
        const dt = Math.min((now - last) / 1000, 0.05);
        last = now;
        offset += fallSpeed * dt;
        ptime += dt;
        ctx.clearRect(0, 0, W, H);

        for (const b of blocks) {
          if (!b.live) continue;
          let yScreen = b.yWorld + offset;
          yScreen = ((yScreen % topWorld) + topWorld) % topWorld;
          yScreen -= 60;
          if (yScreen < -CELL || yScreen > H + CELL) continue;

          const phaseWorld = b.yWorld + offset;
          const phase = (phaseWorld / wavelength) * TWO_PI - offset * 0.004 * twist * 100 / fallSpeed;
          let x, col, al;
          // The x term is negated (a horizontal reflection) so the strands wind
          // the same way as real B-DNA — right-handed. The depth/alpha term is
          // left as-is; reflecting only x is what flips the chirality.
          if (b.strand === 0) {
            const s = Math.sin(phase);
            const depth = Math.cos(phase);
            x = midX - s * amp + b.jitter;
            col = b.colA;
            al = ALPHA_FLOOR + (1 - ALPHA_FLOOR) * ((depth + 1) / 2);
          } else {
            // 2nd arm offset by ARM_PHASE so the helix isn't a perfect mirror.
            const s = Math.sin(phase + ARM_PHASE);
            const depth = Math.cos(phase + ARM_PHASE);
            x = midX + s * amp + b.jitter;
            col = b.colB;
            al = ALPHA_FLOOR + (1 - ALPHA_FLOOR) * ((-depth + 1) / 2);
          }

          const fadeZone = 90;  // top/bottom fade-in distance in px
          let edge = 1;
          if (yScreen < fadeZone) edge = yScreen / fadeZone;
          else if (yScreen > H - fadeZone) edge = (H - yScreen) / fadeZone;
          edge = edge < 0 ? 0 : edge > 1 ? 1 : edge;

          ctx.globalAlpha = al * edge;
          ctx.fillStyle = col;
          roundRectPath(x - CELL / 2, yScreen - CELL / 2, CELL, CELL, RADIUS);
          ctx.fill();
        }

        const pSpan = H + 120;
        for (const p of particles) {
          const raw = (p.cy + ptime * p.vy) % pSpan;
          const px = midX + p.amp * Math.sin(raw / p.wavelength * TWO_PI + p.phase);
          let py = raw - 60;
          if (py < -CELL || py > H + CELL) continue;
          const fadeZone = 90;
          let edge = 1;
          if (py < fadeZone) edge = py / fadeZone;
          else if (py > H - fadeZone) edge = (H - py) / fadeZone;
          edge = edge < 0 ? 0 : edge > 1 ? 1 : edge;
          ctx.globalAlpha = edge;
          ctx.fillStyle = p.col;
          roundRectPath(px - CELL / 2, py - CELL / 2, CELL, CELL, RADIUS);
          ctx.fill();
        }

        ctx.globalAlpha = 1;
        requestAnimationFrame(draw);
      }
      requestAnimationFrame(draw);
    })();

    // ----- Our People: tab switching + photo fallback -------------------
    // Cards are rendered server-side from src/data/people.json. This only
    // toggles which group is visible and swaps a missing photo for the
    // initials placeholder.
    (function () {
      const tabs = document.querySelectorAll('.tab');
      const panels = document.querySelectorAll('[data-panel]');
      tabs.forEach(function (t) {
        t.addEventListener('click', function () {
          tabs.forEach(function (o) { o.classList.remove('is-active'); });
          t.classList.add('is-active');
          panels.forEach(function (p) {
            p.style.display = p.dataset.panel === t.dataset.tab ? '' : 'none';
          });
        });
      });

      document.querySelectorAll('img.card-photo').forEach(function (img) {
        img.addEventListener('error', function () {
          const ph = document.createElement('div');
          ph.className = 'card-photo is-placeholder';
          ph.textContent = img.dataset.initials || '';
          ph.setAttribute('aria-label', img.alt);
          img.replaceWith(ph);
        });
      });
    })();

    // ----- Mosaic header banner (rendered from src/data/decor/about-banner.json) ----
    (function () {
      const panels = document.querySelectorAll('.wi-header-pix');
      if (!panels.length) return;

      const dataEl = document.getElementById('about-banner-data');
      if (!dataEl) return;
      const ART = JSON.parse(dataEl.textContent);   // { cols, rows, palette, grid }  (-1 = transparent)
      const AW = ART.cols, AH = ART.rows, GRID = ART.grid, PAL = ART.palette;

      function paintMosaic(el, cols, rows) {
        const cells = el.children;
        for (let i = 0; i < cells.length; i++) cells[i].style.background = '';   // reset to CSS default (field cell)
        const startCol = Math.round((cols - AW) / 2);                            // centre the art horizontally
        const startRow = Math.max(0, Math.floor((rows - AH) / 2));
        for (let r = 0; r < AH && startRow + r < rows; r++) {
          for (let c = 0; c < AW; c++) {
            const v = GRID[r][c];
            if (v < 0) continue;                                                 // transparent → leave field cell
            const gc = startCol + c;
            if (gc < 0 || gc >= cols) continue;
            const cell = cells[(startRow + r) * cols + gc];
            if (cell) cell.style.background = PAL[v] || '';
          }
        }
      }

      function fill(el) {
        const cs = getComputedStyle(el);
        const cell = parseFloat(cs.getPropertyValue('--card-pix-cell')) || 10;
        const gap  = parseFloat(cs.getPropertyValue('--card-pix-gap'))  || 3;
        const rows = parseInt(cs.getPropertyValue('--card-pix-rows'), 10) || 6;
        const cols = Math.max(1, Math.floor((el.clientWidth + gap) / (cell + gap)));
        el.style.gridTemplateColumns = 'repeat(' + cols + ', var(--card-pix-cell))';
        const need = cols * rows;
        if (el.childElementCount !== need) {
          while (el.childElementCount > need) el.removeChild(el.lastChild);
          const frag = document.createDocumentFragment();
          for (let i = el.childElementCount; i < need; i++) {
            const c = document.createElement('div'); c.className = 'pix-cell'; frag.appendChild(c);
          }
          el.appendChild(frag);
        }
        paintMosaic(el, cols, rows);
      }
      const ro = new ResizeObserver(function (es) { for (const e of es) fill(e.target); });
      panels.forEach(function (el) { fill(el); ro.observe(el); });
    })();

</script>
</BaseLayout>
