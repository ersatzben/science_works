      const ICONS = {
        email: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm9 7.5 8-5.5H4l8 5.5zM4 8.2V18h16V8.2l-8 5.5-8-5.5z"/></svg>',
        x: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M18.24 2.25h3.31l-7.23 8.26L23 21.75h-6.66l-5.21-6.82-5.97 6.82H1.85l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23zm-1.16 17.52h1.83L7.08 4.13H5.12L17.08 19.77z"/></svg>',
        bluesky: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 10.8C10.91 8.69 7.95 4.75 5.2 2.8 2.57.94 1.56 1.27.9 1.57.14 1.91 0 3.08 0 3.77c0 .69.38 5.65.62 6.48.82 2.73 3.71 3.66 6.38 3.36-3.91.58-7.38 2.01-2.83 7.08 5.01 5.19 6.87-1.11 7.82-4.31.95 3.2 2.05 9.27 7.73 4.31 4.27-4.31 1.17-6.5-2.74-7.08 2.67.3 5.57-.63 6.38-3.36.25-.83.62-5.79.62-6.48 0-.69-.14-1.86-.9-2.21-.66-.3-1.66-.62-4.3 1.24C16.05 4.75 13.09 8.69 12 10.8z"/></svg>',
        linkedin: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43A2.06 2.06 0 1 1 5.34 3.3a2.06 2.06 0 0 1 0 4.13zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>',
      };
      const SOCIAL_ORDER = [['email', 'Email'], ['x', 'X'], ['bluesky', 'Bluesky'], ['linkedin', 'LinkedIn']];

      function initials(name) {
        const parts = name.trim().split(/\s+/);
        const first = parts[0][0] || '';
        const last = parts.length > 1 ? parts[parts.length - 1][0] : '';
        return (first + last).toUpperCase();
      }

      // Photo filename derived from the name: lowercase, accents stripped,
      // runs of non-alphanumerics → single hyphen. e.g. "Benedict Macon-Cooney"
      // → "benedict-macon-cooney". Photos live in assets/images/people/<slug>.jpg
      function slug(name) {
        return name.toLowerCase()
          .normalize('NFD').replace(/[̀-ͯ]/g, '')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
      }
      const PHOTO_DIR = '/assets/images/people/';

      const grid = document.getElementById('cards');

      // Glyph: a 5×5 cell grid. For now colours are seeded deterministically
      // from the person's name (so they stay stable across tab switches); later
      // a `glyph` array of length 25 on the person — palette colour or null for
      // a transparent cell — can be authored to replace the random fill.
      const GLYPH_PALETTE = ['#eb3131', '#f45e57', '#66223b', '#440214',
        '#00726b', '#0e676a', '#64b37b', '#004ee6', '#a3c0d7', '#4b5cce',
        '#3a3c7c', '#72679b'];
      function glyphCells(p) {
        if (p.glyph) return p.glyph;            // authored glyph wins
        if (p._glyph) return p._glyph;          // cached random fill
        let s = 0;
        for (let i = 0; i < p.name.length; i++) s += p.name.charCodeAt(i) * (i + 7);
        const rnd = function () { s = (s * 9301 + 49297) % 233280; return s / 233280; };
        const cells = [];
        for (let i = 0; i < 25; i++) {
          cells.push(rnd() < 0.34 ? null : GLYPH_PALETTE[Math.floor(rnd() * GLYPH_PALETTE.length)]);
        }
        p._glyph = cells;
        return cells;
      }
      function makeGlyph(p) {
        const g = document.createElement('div');
        g.className = 'card-glyph';
        g.setAttribute('aria-hidden', 'true');
        const cells = glyphCells(p);
        for (let i = 0; i < 25; i++) {
          const cell = document.createElement('span');
          cell.className = 'glyph-cell';
          if (cells[i]) cell.style.background = cells[i];
          g.appendChild(cell);
        }
        return g;
      }

      function makePlaceholder(p) {
        const ph = document.createElement('div');
        ph.className = 'card-photo is-placeholder';
        ph.textContent = initials(p.name);
        ph.setAttribute('aria-label', p.name);
        return ph;
      }

      function makePhoto(p) {
        // Try the conventional photo path (or an explicit `photo` override);
        // if the file isn't there yet, swap in the initials placeholder.
        const src = p.photo || (PHOTO_DIR + slug(p.name) + '.jpg');
        const img = document.createElement('img');
        img.className = 'card-photo';
        img.src = src;
        img.alt = p.name;
        img.loading = 'lazy';
        img.addEventListener('error', function () {
          if (img.parentNode) img.parentNode.replaceChild(makePlaceholder(p), img);
        });
        return img;
      }

      function makeCard(p) {
        const card = document.createElement('article');
        card.className = 'card';

        const top = document.createElement('div');
        top.className = 'card-top';
        top.appendChild(makePhoto(p));

        const info = document.createElement('div');
        info.className = 'card-headinfo';

        const glyph = makeGlyph(p);

        const id = document.createElement('div');
        id.className = 'card-id';
        const name = document.createElement('h3');
        name.className = 'card-name';
        name.textContent = p.name;
        const role = document.createElement('div');
        role.className = 'card-role';
        role.textContent = p.role;
        id.appendChild(name);
        id.appendChild(role);

        info.appendChild(glyph);
        info.appendChild(id);
        top.appendChild(info);

        const bio = document.createElement('p');
        bio.className = 'card-bio';
        bio.textContent = p.bio;

        const socials = document.createElement('div');
        socials.className = 'card-socials';
        for (const [key, label] of SOCIAL_ORDER) {
          const a = document.createElement('a');
          a.href = '#';                 // placeholder until real links are added
          a.setAttribute('aria-label', label);
          a.title = label;
          a.innerHTML = ICONS[key];
          socials.appendChild(a);
        }

        card.appendChild(top);
        card.appendChild(bio);
        card.appendChild(socials);
        return card;
      }

      function render(tab) {
        grid.innerHTML = '';
        for (const p of PEOPLE[tab]) grid.appendChild(makeCard(p));
      }

      const tabs = document.querySelectorAll('.tab');
      tabs.forEach(function (t) {
        t.addEventListener('click', function () {
          tabs.forEach(function (o) { o.classList.remove('is-active'); });
          t.classList.add('is-active');
          render(t.dataset.tab);
        });
      });

      render('team');
    })();

    // ----- Mosaic header banner (lifted from the Writing page) ----------
    (function () {
      const panels = document.querySelectorAll('.wi-header-pix');
      if (!panels.length) return;

      // Rows are equal-width strings; each char is a palette key ('0' = blank/
      // almost-white). Palette mixes themed CSS vars with hero-JS hexes.
      const MOSAIC = [
        '11234123412341200511353135113511',
        '16750675068506700792289227922711',
        '1893589358835890068B1888168B1611',
        '1821AB188881AB10005A4888805AA011',
        '18234188888888800888888888BA1281',
        '18888888888888800888888888888881',
        '18888888888888800888888888888881',
        '1821AB88888888800888888888143281',
        '1104A5088884A50001BA188881BA5281',
        '1161B8618881B8600985388539853981',
        '117229B2298229B00B6058605B605361',
        '11531153135311500214321432143211',
      ];
      const MOSAIC_W = MOSAIC[0].length;
      const PAL = {
        '0': 'var(--almost-white)', '1': 'var(--theme)', '2': '#a3c0d7', '3': '#0e676a',
        '4': 'var(--text)', '5': 'var(--coral)', '6': '#4b5cce', '7': '#111340',
        '8': '#ebe5cf', '9': '#64b37b', 'A': '#440214', 'B': '#004ee6',
      };

      function paintMosaic(el, cols, rows) {
        const cells = el.children;
        for (let i = 0; i < cells.length; i++) cells[i].style.background = '';   // reset to CSS default
        const startCol = Math.round((cols - MOSAIC_W) / 2);                       // centre the art horizontally
        const startRow = Math.max(0, Math.floor((rows - MOSAIC.length) / 2));
        for (let r = 0; r < MOSAIC.length && startRow + r < rows; r++) {
          const line = MOSAIC[r];
          for (let c = 0; c < line.length; c++) {
            const ch = line[c];
            if (ch === '0') continue;
            const gc = startCol + c;
            if (gc < 0 || gc >= cols) continue;
            const cell = cells[(startRow + r) * cols + gc];
            if (cell) cell.style.background = PAL[ch] || '';
          }
        }
      }

      function fill(el) {
        const cs = getComputedStyle(el);
        const cell = parseFloat(cs.getPropertyValue('--card-pix-cell')) || 10;
        const gap  = parseFloat(cs.getPropertyValue('--card-pix-gap'))  || 3;
        const rows = parseInt(cs.getPropertyValue('--card-pix-rows'), 10) || 6;
        const cols = Math.max(1, Math.floor((el.clientWidth + gap) / (cell + gap)));
        el.style.gridTemplateColumns = 'repeat(' + cols + ', var(--card-pix-cell))';
        const need = cols * rows;
        if (el.childElementCount !== need) {
          while (el.childElementCount > need) el.removeChild(el.lastChild);
          const frag = document.createDocumentFragment();
          for (let i = el.childElementCount; i < need; i++) {
            const c = document.createElement('div'); c.className = 'pix-cell'; frag.appendChild(c);
          }
          el.appendChild(frag);
        }
        paintMosaic(el, cols, rows);
      }
      const ro = new ResizeObserver(function (es) { for (const e of es) fill(e.target); });
      panels.forEach(function (el) { fill(el); ro.observe(el); });
    })();

</script>
</BaseLayout>
