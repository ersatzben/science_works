---
import BaseLayout from '../layouts/BaseLayout.astro';
import MosaicNetwork from '../components/MosaicNetwork.astro';

// Every JSON in src/data/mosaics/ becomes its own network block (sorted by name).
const mods = import.meta.glob('../data/mosaics/*.json', { eager: true });
const mosaics = Object.keys(mods).sort().map((k) => mods[k].default ?? mods[k]);

// Project copy + per-item scatter offset (translate, in px) — tune freely.
const PROJECTS = [
  { index: '01', title: 'Institutional Dynamism',   subtitle: 'We want to inject diversity and dynamism into our institutional landscape.', tx: -20, ty: 0 },
  { index: '02', title: 'AI and Science',           subtitle: 'An ambitious British agenda for AI in science — data, software and incentives.', tx: 20, ty: 64 },
  { index: '03', title: 'The Research Economy',      subtitle: 'Rigorous analysis of how research is funded, costed and governed.', tx: 0, ty: 24 },
  { index: '04', title: 'Software for Science',      subtitle: 'Building tools and shifting incentives so research software can flourish.', tx: -10, ty: 96 },
  { index: '05', title: 'A Story of British Science', subtitle: 'Telling the story of British science — its past, present and future.', tx: 10, ty: 36 },
];
const items = mosaics.map((m, i) => ({ data: m, ...(PROJECTS[i] || { index: String(i + 1).padStart(2, '0'), title: 'Project', subtitle: '', tx: 0, ty: 0 }) }));
---
<BaseLayout title="Projects — Science Works">
  <main class="projects-page">
    <div class="pp-inner">
      <header class="pp-head">
        <h1 class="pp-title">projects</h1>
        <p class="pp-intro">Some introductory text about how we organise our work into projects in order to accelerate British science and tech.</p>
      </header>
    </div>

    <!-- Staggered scatter: flow handles the cascade, translate handles the scatter. -->
    <div class="pp-networks">
      {items.map((it) => (
        <div class="pp-item" style={`--tx:${it.tx}px; --ty:${it.ty}px`}>
          <div class="pp-block">
            <MosaicNetwork data={it.data} cell="6px" gap="1px" />
          </div>
          <div class="project-card">
            <p class="project-index">{it.index}</p>
            <h3 class="project-title">{it.title}</h3>
            <p class="project-subtitle">{it.subtitle}</p>
            <button type="button" class="project-toggle">+ Open Project</button>
          </div>
        </div>
      ))}
    </div>
  </main>

  <style>
    .projects-page { padding: 46px 24px 80px; }
    .pp-inner { max-width: 1100px; margin: auto; position: relative; }

    .pp-head { margin: 0 0 28px; text-align: center; }
    .pp-title {
      font-family: 'Copperplate', serif; font-weight: normal; font-size: 30px;
      letter-spacing: -0.02em; color: var(--text); margin: 0 0 10px;
    }
    .pp-intro {
      font-family: 'Playfair Display', serif; font-weight: 300; font-size: 15px;
      line-height: 1.5; color: var(--text); margin: auto; max-width: 460px;
    }

    /* Flow layout (wrap = the responsive cascade); transform = the scatter. */
    .pp-networks {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-start;
      gap: 56px 40px;
    }
    .pp-item {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      gap: 14px;
      transform: translate(var(--tx, 0), var(--ty, 0));   /* cosmetic scatter — no scaling */
    }
    .pp-block { flex: 0 0 auto; }

    /* Project info card, sits to the right of the network. */
    .project-card {
      flex: 0 0 auto;
      width: 180px;
      height: 180px;
      box-sizing: border-box;
      border: 1px solid var(--border-grey);
      border-radius: 6px;
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
    }
    .project-index {
      font-family: var(--button-text); font-weight: 500; font-size: 12px;
      letter-spacing: 0.06em; color: var(--theme); margin: 0 0 6px;
    }
    .project-title {
      font-family: 'Copperplate', serif; font-weight: normal; font-size: 16px;
      line-height: 1.15; color: var(--text); margin: 0 0 8px;
    }
    .project-subtitle {
      font-family: 'Antique Olive', sans-serif; font-weight: 300; font-size: 12px;
      line-height: 1.4; color: var(--text); margin: 0;
    }
    .project-toggle {
      margin-top: auto;   /* pin to the bottom of the card */
      align-self: flex-start;
      font-family: var(--button-text); font-weight: 500; font-size: 12px;
      letter-spacing: 0.02em; text-transform: uppercase;
      color: var(--theme); background: none; border: none; padding: 0; cursor: pointer;
    }
    .project-toggle:hover { text-decoration: underline; }

    /* Narrow screens: drop the scatter, stack each pair cleanly. */
    @media (max-width: 940px) {
      .pp-networks { flex-direction: column; align-items: center; gap: 40px; }
      .pp-item { transform: none; flex-direction: column; align-items: flex-start; gap: 12px; }
    }
    @media (max-width: 600px) {
      .projects-page { padding: 80px 18px 60px; }
      .pp-title { font-size: 26px; }
    }
  </style>

  <script is:inline>
    // Hovering anywhere on a pair grows its network from the seed; it stays grown.
    (function () {
      const items = Array.prototype.slice.call(document.querySelectorAll('.pp-item'));
      if (!items.length) return;
      const grids = items.map(function (it) { return it.querySelector('.pp-mosaic'); }).filter(Boolean);
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;   // static
      grids.forEach(function (g) { g.classList.add('anim-ready'); });   // seed only until hovered
      items.forEach(function (it) {
        const g = it.querySelector('.pp-mosaic');
        if (!g) return;
        it.addEventListener('mouseenter', function () { g.classList.add('is-grown'); }, { once: true });
      });
    })();
  </script>
</BaseLayout>
