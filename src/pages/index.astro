---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GridArt from '../components/GridArt.astro';
import { getCover } from '../lib/covers.js';
import quotes from '../data/quotes.json';

// In Focus + carousel are driven by the writing collection (same source as /writing).
const all = (await getCollection('writing'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featured = all.find((e) => e.data.featured) ?? all[0];
const fmt = (d) => d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
const typeLabel = (t) => (t === 'report' ? 'Report' : 'Essay');
const ifCover = getCover(featured.id);
---
<BaseLayout title="Science Works">
  <section id="splash">
    <div class="stage">
      <div class="scaler">
        <div class="matrix-wrap">
          <div id="matrix" class="matrix" role="img" aria-label="Science Works dot-matrix field"></div>
          <div class="hero-box">
            <div class="line-1">Reshaping the British</div>
            <div class="line-2">Research System</div>
            <div class="hero-actions">
              <a class="hero-btn hero-btn--primary" href="/writing">Explore Our Work</a>
              <a class="hero-btn hero-btn--secondary" href="/about">About Us</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="mobile-hero">
      <div class="mhero-hero">
        <h1 class="mhero-title">Reshaping<br>the British<br>Research<br>System</h1>
        <p class="mhero-blurb">Science Works is an independent research and policy studio aiming to tackle the biggest problems facing UK science and technology.</p>
        <div class="mhero-rule"></div>
        <div class="mhero-actions">
          <a class="mhero-btn mhero-btn--primary" href="/writing">Explore Our Work</a>
          <a class="mhero-btn mhero-btn--secondary" href="/about">About Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Spotlight: pinned intro (left) + scrolling featured projects (right) -->
  <section class="spotlight" id="projects">
    <div class="content-wrap spotlight-grid">
      <div class="spotlight-intro">
        <div class="intro-matrix" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
        <div class="intro-pic" aria-hidden="true"></div>
        <p class="intro-eyebrow">Science Works</p>
        <h2>Britain needs a metascientific revolution.</h2>
        <p>The UK's place in the world has long been underwritten by the creativity of its laboratories, workshops, and universities. Today that imagination is running into the limits of institutions built for another era. We've lost much of the freedom that once defined British science, and failed to seize the possibilities of our technological age.</p> 
        <p>We have deep talent, trusted universities, and a culture of rigour. But the systems that fund and govern research move slowly, tangled in crude metrics and misaligned incentives, while public science lags behind the private frontier.</p>
        <p>Science Works exists to change that.</p>
        <a class="hero-btn hero-btn--primary" href="/writing">Explore Our Work</a>
      </div>
      <div class="spotlight-main">
        <h2 class="section-label"><a href="/projects">featured projects</a></h2>
        <div class="projects">
        <article class="project">
          <div class="project-body">
            <h3 class="project-title">Institutional Dynamism</h3>
            <div class="project-detail">
              <p class="project-sub">The UK&rsquo;s research ecosystem is unusually homogeneous and slow to evolve</p>
              <p class="project-text"><span class="hidden">In other countries, R&amp;D is spread across a much wider range of institutional forms. </span>We want to inject diversity and dynamism into the sector &ndash; mapping <span class="hidden">the </span>institutional models<span class="hidden"> available to funders and policymakers</span>, strengthening <span class="hidden">the </span>state<span class="hidden">&rsquo;s</span> capacity<span class="hidden"> to assess and support proposals for new organisations</span>, and incubating new organisational forms<span class="hidden"> where we are best placed to do so</span>.</p>
            </div>
            <a class="project-more" href="#">More from this project &rarr;</a>
          </div>
          <div class="project-divider" aria-hidden="true"></div>
          <div class="project-img" aria-hidden="true"></div>
        </article>
        <article class="project">
          <div class="project-body">
            <h3 class="project-title">AI and Science</h3>
            <div class="project-detail">
              <p class="project-sub">Artificial intelligence is poised to change what it means to be a scientist</p>
              <p class="project-text"><span class="hidden">But the UK risks compounding existing dysfunctions rather than unlocking the gains: much of the scientific record remains invisible, research software is undervalued, and the infrastructure for AI-enabled discovery is unevenly available. </span>We are developing an ambitious British agenda for AI in science &ndash; covering data, software, automation, and <span class="hidden">the </span>institutional changes<span class="hidden"> needed to make them count</span>.</p>
            </div>
            <a class="project-more" href="#">More from this project &rarr;</a>
          </div>
          <div class="project-divider" aria-hidden="true"></div>
          <div class="project-img" aria-hidden="true"></div>
        </article>
        <article class="project">
          <div class="project-body">
            <h3 class="project-title">The Research Economy</h3>
            <div class="project-detail">
              <p class="project-sub">The UK funds research without a clear picture of its real costs and trade-offs</p>
              <p class="project-text">We bring quantitative and qualitative analysis to bear on the research base<span class="hidden">: highlighting the hidden costs, frictions, trade-offs, and cross-subsidies that underpin the economics of institutions and the architecture of national R&amp;D spending. We pair this with detailed mapping of the system&rsquo;s structure, and with practical work on the design of funding and assessment</span>, pushing for a system that is less bureaucratic, more honest, and more dynamic.</p>
            </div>
            <a class="project-more" href="#">More from this project &rarr;</a>
          </div>
          <div class="project-divider" aria-hidden="true"></div>
          <div class="project-img" aria-hidden="true"></div>
        </article>
        <article class="project">
          <div class="project-body">
            <h3 class="project-title">Software for Science</h3>
            <div class="project-detail">
              <p class="project-sub">The future of research is digital&mdash;and we need to adapt</p>
              <p class="project-text"><span class="hidden">Scientists lack modern and interoperable software tools for undertaking research in the age of intelligence. The research software engineer is a forgotten role without a clear career path. Much of the research process remains analogue; there is a lack of a well-functioning market for software; open tools are poorly maintained. </span>We are building and testing new software tools <span class="hidden">to address this gap, </span>while working on the incentives that will allow software to flourish.</p>
            </div>
            <a class="project-more" href="#">More from this project &rarr;</a>
          </div>
          <div class="project-divider" aria-hidden="true"></div>
          <div class="project-img" aria-hidden="true"></div>
        </article>
        <article class="project">
          <div class="project-body">
            <h3 class="project-title">The Story of British Science</h3>
            <div class="project-detail">
              <p class="project-sub">Scientific progress requires public confidence and political willpower</p>
              <p class="project-text">Neither is guaranteed to endure over the coming decade. <span class="hidden">The UK currently lacks a compelling, forward-looking story about what its scientific and technological future could be. </span>We want to help develop and articulate an account of British scientific renewal that can resonate<span class="hidden"> across the political spectrum</span>.</p>
            </div>
            <a class="project-more" href="#">More from this project &rarr;</a>
          </div>
          <div class="project-divider" aria-hidden="true"></div>
          <div class="project-img" aria-hidden="true"></div>
        </article>
        </div>
      </div>
    </div>
  </section>
  <div class="content-wrap-lower">
    <!-- 3. In Focus: one highlighted publication -->
    <section class="infocus">
      <div class="content-wrap">
      <div class="infocus-row">
        <div class="infocus-card">
          <a class="infocus-link" href={`/writing/${featured.id}`} aria-label={featured.data.title}></a>
          <div class="infocus-art" id="infocus-art" aria-hidden="true">{ifCover && <GridArt bitmap={ifCover} />}</div>
          <div class="infocus-meta">
            <p class="infocus-tag">In Focus</p>
            <h3 class="infocus-title">{featured.data.title}</h3>
            <p class="infocus-authors">{featured.data.authors.join(', ')}</p>
            {(featured.data.summary ?? featured.data.subtitle) && <p class="infocus-sub">{featured.data.summary ?? featured.data.subtitle}</p>}
            <p class="infocus-foot"><span class="infocus-date">{fmt(featured.data.date)}</span><span class="infocus-type">{typeLabel(featured.data.type)}</span></p>
          </div>
        </div>

        <figure class="quote-box">
          <div class="quote-top">
            <span class="quote-mark" aria-hidden="true">&ldquo;</span>
            <span class="quote-rule" aria-hidden="true"></span>
          </div>
          <div class="quote-content">
            <blockquote class="quote-text">{(Array.isArray(quotes[0].text) ? quotes[0].text : [quotes[0].text]).map((p) => <p class="quote-para">{p}</p>)}</blockquote>
            <figcaption class="quote-author">{quotes[0].author}</figcaption>
          </div>
        </figure>
      </div>
      </div>
    </section>

    <script define:vars={{ IF_COLS: ifCover?.cols ?? 1, IF_ROWS: ifCover?.rows ?? 1, IF_SIZE: ifCover?.cell?.size ?? 14, IF_GAP: ifCover?.cell?.gap ?? 2 }}>
      (function () {
        // Fill the In Focus card height with WHOLE cells: keep all rows, scale so
        // they fill the box height, then show however many whole columns fit the
        // width (centre-cropped). Re-runs as the card grows/shrinks with the quote.
        var box = document.getElementById('infocus-art');
        if (!box) return;
        var svg = box.querySelector('svg');
        if (!svg) return;
        var pitch = IF_SIZE + IF_GAP;
        var hNat = IF_ROWS * pitch - IF_GAP;          // native height of all rows
        function render() {
          var W = box.clientWidth, H = box.clientHeight;
          if (!W || !H) return;
          var scale = H / hNat;                        // all rows fill the height
          var visCols = Math.floor((W / scale + IF_GAP) / pitch);   // whole columns that fit the width
          visCols = Math.max(1, Math.min(IF_COLS, visCols));
          var startCol = Math.floor((IF_COLS - visCols) / 2);
          var vbW = visCols * pitch - IF_GAP;
          svg.setAttribute('viewBox', (startCol * pitch) + ' 0 ' + vbW + ' ' + hNat);
          svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
          svg.style.width = (vbW * scale) + 'px';
          svg.style.height = H + 'px';
          svg.style.margin = '0 auto';                 // centre the column window
        }
        if (window.ResizeObserver) new ResizeObserver(render).observe(box);
        else window.addEventListener('resize', render);
        render();
      })();
    </script>

    <script define:vars={{ swQuotes: quotes, ROTATE_MS: 12000 }}>
      (function () {
        if (!Array.isArray(swQuotes) || swQuotes.length < 2) return;   // single quote → static
        var content = document.querySelector('.quote-content');
        var textEl = document.querySelector('.quote-text');
        var authorEl = document.querySelector('.quote-author');
        if (!content || !textEl || !authorEl) return;
        function renderText(text) {
          var paras = Array.isArray(text) ? text : [text];
          textEl.innerHTML = '';
          paras.forEach(function (p) {
            var pe = document.createElement('p');
            pe.className = 'quote-para';
            pe.textContent = p;
            textEl.appendChild(pe);
          });
        }
        var FADE = 450, i = 0;
        setInterval(function () {
          i = (i + 1) % swQuotes.length;
          content.style.opacity = '0';
          setTimeout(function () {
            renderText(swQuotes[i].text);
            authorEl.textContent = swQuotes[i].author;
            content.style.opacity = '1';
          }, FADE);
        }, ROTATE_MS);
      })();
    </script>

    <!-- 4. Latest reports carousel -->
    <section class="reports">
      <div class="content-wrap">
        
        <div class="reports-box-wrapper">
          
          <div class="reports-box">
            <div class="reports-head">
            <h2 class="reports-head-label">Latest from Science Works</h2>
            <a class="reports-viewall" href="/writing">View all &rarr;</a>
          </div>
            <div class="carousel-track">
              {all.map((e) => (
                <div class="report-card">
                  <a class="report-card-link" href={`/writing/${e.id}`} aria-label={e.data.title}></a>
                  {getCover(e.id)
                    ? <div class="report-card-art" aria-hidden="true"><GridArt bitmap={getCover(e.id)} aspect={12 / 12} /></div>
                    : <div class="report-card-pix" aria-hidden="true"></div>}
                  <div class="report-card-body">
                    <h3 class="report-title">{e.data.shortTitle ?? e.data.title}</h3>
                    <p class="report-authors">{e.data.authors.join(', ')}</p>
                    {e.data.subtitle && <p class="report-sub">{e.data.subtitle}</p>}
                    <p class="report-foot"><span class="report-date">{fmt(e.data.date)}</span><span class="report-type">{typeLabel(e.data.type)}</span></p>
                  </div>
                </div>
              ))}
            </div>
          <div class="carousel-arrows">
            <button class="carousel-arrow" data-dir="-1" type="button" aria-label="Previous reports">&larr;</button>
            <button class="carousel-arrow" data-dir="1" type="button" aria-label="Next reports">&rarr;</button>
          </div>
        </div>
        </div>
      </div>
    </section>
  </div>

<style is:global>
    /* Homepage scrolls continuously (no snap); the hero stage fills the
       viewport and simply scrolls away. */
    .stage {
      width: 100%;
      aspect-ratio: 63 / 32;         /* hero height tracks width → content below reveals at narrow widths */
      overflow: hidden;
      display: flex;
      align-items: center;          /* vertically centre the composition in the hero */
      justify-content: center;
      padding: var(--matrix-gap);
      padding-top: 1.3%;
      box-sizing: border-box;
    }

    /* Outer box reserves space at scaled dimensions so the page lays out cleanly. */
    .scaler {
      width: calc(var(--composition-w) * var(--scale));
      height: calc(var(--composition-h) * var(--scale));
    }

    .matrix-wrap {
      position: relative;
      width: var(--composition-w);
      height: var(--composition-h);
      transform: scale(var(--scale));
      transform-origin: top left;
    }

    .matrix {
      display: flex;
      flex-wrap: wrap;
      align-items: center;                             /* centre each row → tall boxes grow up & down */
      gap: var(--matrix-row-gap) var(--matrix-gap);   /* row-gap (vertical) / column-gap (horizontal) */
      width: var(--composition-w);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(var(--grid-cols), var(--cell-size));
      grid-template-rows: repeat(var(--grid-rows), var(--cell-size));
      gap: var(--cell-gap);
      width: var(--grid-w);
      height: var(--grid-h);
      flex: 0 0 auto;
    }
    /* Boxes 6 & 11: two extra rows (random caps top & bottom). */
    .grid--tall {
      grid-template-rows: repeat(13, var(--cell-size));
      height: calc(13 * var(--cell-size) + 12 * var(--cell-gap));
    }

    .cell {
      width: var(--cell-size);
      height: var(--cell-size);
      border-radius: var(--cell-radius);
      background: var(--beige);
      position: relative;
    }
    /* Theme-red hover overlay; instant on hover-in, 0.5s fade-out on hover-off. */
    .cell::after {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--theme);
      border-radius: inherit;
      opacity: 0;
      transition: opacity 1.5s ease;
      pointer-events: none;
    }
    .cell:hover::after {
      opacity: 1;
      transition: opacity 0s;
    }


      .hero-box {
      position: absolute;
      top: 51.5%;
      left: 50%;
      transform: translate(-50%, -50%);
      /* Extend beyond the four-block gap it sits in; still centred via the
         top/left 50% + translate(-50%, -50%) above. */
      width: calc(var(--hero-w) + 20px);
      height: calc(var(--hero-h) + 50px);
      /* background: transparent; */
      background: var(--bg-secondary);
      border: 1px solid var(--border-grey);
      border-radius: 5px;
      color: var(--text);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 50px;
      box-sizing: border-box;
      font-family: 'Copperplate', serif;
      font-weight: 700;
      font-size: 42px;
      line-height: 1.1;
      letter-spacing: 0;
      text-align: center;
      z-index: 10;
      pointer-events: none;
    }
    .hero-box .line-2 { font-size: 0.9em; }

    /* Hero buttons, side by side under the text. */
    .hero-actions {
      display: flex;
      gap: 12px;
      justify-content: center;
      margin-top: 14px;
      pointer-events: auto;   /* hero-box is pointer-events:none — re-enable here */
    }
    .hero-btn {
      font-family: var(--button-text);
      font-weight: normal;
      font-size: 13px;
      letter-spacing: 0;
      line-height: 1;
      text-decoration: none;
      box-sizing: border-box;
      width: 120px;            /* equalised, ~20% narrower */
      padding: 6px 6px;       /* ~20% shorter */
      text-align: center;
      border-radius: 5px;
      border: 1.5px solid var(--theme);
      cursor: pointer;
      white-space: nowrap;
      transition: transform 0.14s ease, box-shadow 0.14s ease, background-color 0.15s ease, color 0.15s ease;
    }
    /* Hover: a small lift with a soft shadow; clicking presses it back down. */
    .hero-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 10px rgba(68, 2, 20, 0.16); }
    .hero-btn:active { transform: translateY(0); box-shadow: 0 1px 3px rgba(68, 2, 20, 0.16); }
    /* White on red → inverts to red on white on hover. */
    .hero-btn--primary {
      background: var(--theme);
      color: #fff;
    }
    .hero-btn--primary:hover {
      /* background: #fff;
      color: var(--theme); */
      
    }
    /* Red on white (red outline) → inverts to white on red on hover. */
    .hero-btn--secondary {
      background: #fff;
      color: var(--theme);
    }
    .hero-btn--secondary:hover {
      /* background: var(--beige);
      color: #fff; */
    }
    .section-inner {
      max-width: 800px;
      padding: 80px 50px;
      margin: 0 auto;
    }
    .section-inner--wide {
      max-width: 1400px;
    }
    .section-heading {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      color: var(--text);
      font-size: 56px;
      letter-spacing: 0.02em;
      margin: 0 0 24px;
    }
    .section-body {
      font-family: 'Antique Olive', sans-serif;
      font-size: 18px;
      font-weight: 300;
      line-height: 1.5;
      color: var(--text);
      margin: 0 0 16px;
    }

    /* ===================================================================
       Homepage content sections (continuous scroll, IFP-style)
       =================================================================== */
    .content-wrap {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 40px;
      box-sizing: border-box;
    }
    .section-label {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      font-size: 28px;
      letter-spacing: 0.02em;
      color: var(--text);
      margin: 0 0 15px;
    }
    .section-label a { color: var(--theme); text-decoration: none; border-bottom: 1px solid var(--theme); padding: 0 0 3px;}
    .section-label a:hover { border-bottom-width: 3px; }

    /* ---------- Spotlight: pinned intro (left) + scrolling projects (right) ---------- */
    .spotlight { 
      padding: 70px 0 56px; 
      background-color: var(--almost-white);
    }

    .spotlight-grid {
      display: grid;
      grid-template-columns: minmax(280px, 1.5fr) 1.55fr;   /* intro col ~25% wider */
      gap: 56px;
      align-items: start;
    }
    .spotlight-intro {
      position: sticky;
      top: 140px;                   /* sticky threshold — freezes 80px below viewport top (clears the 60px nav) */
      margin-top: 70px;            /* initial gap before the intro */
      align-self: start;
      padding-left: 0px; 
      padding-right: 20px;
    }
    /* Decorative 7x2 dot grid, top-left of the intro. Anchored to the
       container's top-left corner; nudge it anywhere (incl. outside the
       container) with the margins below — negative values are fine. */
    .intro-matrix {
      position: absolute;
      top: 0;
      left: 0;
      margin: -65px 0 0 -100px;      /* top right bottom left — move the grid with these */
      display: grid;
      grid-template-columns: repeat(7, var(--small-block-size));
      grid-auto-rows: var(--small-block-size);
      gap: var(--small-block-gap);
    }
    .intro-matrix span {
      background: var(--border-grey);
      border-radius: var(--small-block-radius);
    }
    .intro-eyebrow { display: none; }   /* mobile-only (shown in the 600px query) */
    .intro-pic { display: none; }       /* mobile-only (shown in the 600px query) */
    .spotlight-intro h2 {
      font-family: 'Copperplate', serif;
      font-weight: normal;
      font-size: 30px;
      letter-spacing: 0.02em;
      color: var(--text);
      margin: 0 0 20px;
    }
    .spotlight-intro p {
      font-family: 'Antique Olive', sans-serif;
      font-weight: 300; 
      font-size: 17px;
      line-height: 1.5;
      color: var(--text);
      margin: 0 0 16px;
      max-width: 520px;     /* use the now-wider column */
    }
    .spotlight-intro .hero-btn { margin-top: 8px; }

    .projects { display: flex; flex-direction: column; gap: 22px; padding-right: 0px; }
    .project {
      display: flex;
      gap: 28px;
      align-items: stretch;
      background: var(--bg-secondary);
      border: 1px solid var(--border-grey);
      border-radius: 6px;
      padding: 24px 24px;
      box-sizing: border-box;
    }

    .project-body { flex: 1; min-width: 0; display: flex; flex-direction: column; }
    .project-title {
      font-family: 'Copperplate', serif;
      font-weight: 600;
      font-size: 22px;
      line-height: 1.15;
      color: var(--text);
      margin: 0 0 6px;
    } 
    .project-sub {
      font-family: 'Playfair Display', serif;
      font-weight: bold;
      font-size: 16px;
      letter-spacing: 0.01em;
      line-height: 1.4;
      color: var(--text);
      margin: 0 0 12px;
    }
    .project-text {
      font-family: 'Antique Olive', sans-serif;
      font-weight: 300; 
      font-size: 14px;
      line-height: 1.4;
      color: var(--text);
      margin: 0;
    }
    .project-detail {
      border-left: 1px solid var(--border-grey);
      padding-left: 16px;
      margin-top: 0px;
      margin-bottom: 6px; 
      padding-bottom: 2px;
    }
    .project-more {
      font-family: 'Roboto', sans-serif;
      display: inline-block;
      align-self: flex-start;   /* content-width within the flex column */
      margin-top: auto;         /* push to the bottom of the card */
      margin-left: 16px;
      font-family: var(--button-text);
      font-weight: 500;
      font-size: 16px;
      letter-spacing: 0.01em;
      color: var(--theme);
      text-decoration: none;
    }
    .project-more:hover { text-decoration: underline; }
    .project-divider {
      flex: 0 0 auto;
      width: 1px;
      align-self: stretch;
      background: var(--border-grey);
      margin: -24px 0;            /* extend to the card's top/bottom edges through the padding */
    }
    /* Procedural dot-matrix filling the card's right panel. The column count
       fixes the panel width; the row count is computed in JS to fit the card
       height in WHOLE cells, so differing card heights never slice a pixel.
       One colour for now. */
    .project-img {
      flex: 0 0 auto;
      align-self: stretch;              /* panel height = card content height */
      --card-pix-cols: 11;              /* columns → drives the panel width */
      --card-pix-cell: var(--small-block-size);   /* pixel size */
