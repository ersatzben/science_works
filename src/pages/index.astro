<script type="application/json" id="splash-art-data" is:inline set:html={JSON.stringify(splashArt)}></script>
<script is:inline>
    (function () {
      const COLS = 16;
      const ROWS = 16;
      const MATRIX_COLS = 6;
      const MATRIX_ROWS = 3;
      const GRID_COUNT = MATRIX_COLS * MATRIX_ROWS;

      // Brand palette, exposed so JS can address cells by colour name later.
      const PALETTE = {
        bg: '#f6f0ed',
        text: '#66223b',
        theme: '#eb3131',
        sage: '#00726b',
        brightBlue: '#004ee6',
        paleBlue: '#a3c0d7',
        lightGreen: '#64b37b',
        deepGreen: '#0e676a',
        coral: '#f45e57',
        beige: '#ebe5cf',
        almostWhite: '#faf8f6',
        purpleBlue: '#4b5cce',
        darkestBrown: '#440214',
        opt1: '#3a3c7c',
        opt2: '#72679b',
      };

      const matrixEl = document.getElementById('matrix');

      // grids[i].cells[row][col] -> HTMLElement
      // grids[i].el                -> grid container
      const grids = [];

      // Boxes 6 & 11 (the ends of the middle row, flanking the hero text) are two
      // rows taller — an extra random-coloured row on the top and the bottom.
      const TALL_SLOTS = new Set([6, 11]);
      const TALL_ROWS = 18;

      function buildGrid(rows) {
        const gridEl = document.createElement('div');
        gridEl.className = rows > ROWS ? 'grid grid--tall' : 'grid';
        const cells = [];
        for (let r = 0; r < rows; r++) {
          const rowArr = [];
          for (let c = 0; c < COLS; c++) {
            const el = document.createElement('div');
            el.className = 'cell';
            el.dataset.row = r;
            el.dataset.col = c;
            gridEl.appendChild(el);
            rowArr.push(el);
          }
          cells.push(rowArr);
        }
        return { el: gridEl, cells, rows, total: rows * COLS };
      }

      // Slots 7–10 sit behind the central banner — binned. Rendered as empty,
      // correctly-sized placeholders so the 6×3 layout (and the alignment of
      // boxes 6 & 11 at the ends of the middle row) holds, but no pixels are
      // built, painted, or animated there.
      const HERO_SLOTS = new Set([7, 8, 9, 10]);
      function buildSpacer() {
        const gridEl = document.createElement('div');
        gridEl.className = 'grid grid--spacer';
        return { el: gridEl, cells: [], rows: ROWS, total: 0 };
      }

      for (let i = 0; i < GRID_COUNT; i++) {
        const g = HERO_SLOTS.has(i)
          ? buildSpacer()
          : buildGrid(TALL_SLOTS.has(i) ? TALL_ROWS : ROWS);
        g.el.dataset.index = i;
        matrixEl.appendChild(g.el);
        grids.push(g);
      }

      // ----- Per-grid art ----------------------------------------------
      // {cols,rows,palette,grid} per slot, from src/data/splash/grid-NN.json,
      // resolved to a flat array of hex colours (or null = transparent, so the
      // background lattice shows through). This is the single source of truth
      // both the initial render and the swap animation operate on.
      let SPLASH_ART = {};
      try {
        const tag = document.getElementById('splash-art-data');
        if (tag) SPLASH_ART = JSON.parse(tag.textContent || '{}');
      } catch (_) {}

      // Resolve a slot's art to a flat colour array (length = grid.total).
      // Centres the art vertically when the slot is taller than the art: the
      // tall grids 6 & 11 have 18 cell rows, so a 16-row art would sit in the
      // middle with transparent caps (a full 16×18 art fills them).
      function artToColors(slotIdx, art) {
        const g = grids[slotIdx];
        const out = new Array(g.total).fill(null);
        if (!g.cells.length || !art || !Array.isArray(art.grid)) return out;
        const pal = art.palette || [];
        const rowOffset = Math.floor((g.cells.length - art.grid.length) / 2);
        for (let r = 0; r < g.cells.length; r++) {
          const srcRow = art.grid[r - rowOffset] || [];
          for (let c = 0; c < COLS; c++) {
            const idx = srcRow[c];
            out[r * COLS + c] = (idx != null && idx >= 0) ? (pal[idx] || null) : null;
          }
        }
        return out;
      }

      // Helpers exposed for future animation code.
      function setCell(gridIdx, row, col, color) {
        const el = grids[gridIdx]?.cells[row]?.[col];
        if (el) el.style.background = color;
      }

      function setAll(color) {
        for (let i = 0; i < grids.length; i++) {
          if (!grids[i].cells.length) continue;   // skip binned (empty) slots
          for (let r = 0; r < ROWS; r++) {
            for (let c = 0; c < COLS; c++) grids[i].cells[r][c].style.background = color;
          }
        }
      }

      // ----- Render + swap animation -----------------------------------
      const EDITABLE_SLOTS = [];
      for (let i = 0; i < grids.length; i++) {
        if (!HERO_SLOTS.has(i)) EDITABLE_SLOTS.push(i);
      }

      // Per-slot current cell colours (hex or null = transparent). Seeded from
      // each grid's art; mutated by swaps so each pair oscillates between its
      // two states over time.
      const slotData = grids.map((g, i) => artToColors(i, SPLASH_ART[i]));

      function renderSlot(slotIdx) {
        const colors = slotData[slotIdx];
        const cells = grids[slotIdx].cells;
        for (let r = 0; r < cells.length; r++) {
          const rowArr = cells[r];
          for (let c = 0; c < rowArr.length; c++) {
            rowArr[c].style.background = colors[r * COLS + c] || 'transparent';
          }
        }
      }

      function renderAll() {
        for (let i = 0; i < grids.length; i++) renderSlot(i);
      }

      // ----- Pair selection --------------------------------------------
      // Fixed couples swap only with each other (and are excluded from the
      // random pairing below). [6, 11] are the two ends of the middle row,
      // flanking the hero text. Pairs are always like-sized (16×16, except
      // 6↔11 which are both 16×18).
      const FIXED_PAIRS = [[0, 12], [5, 17], [6, 11]];

      function buildPairs() {
        const used = new Set(FIXED_PAIRS.flat());
        const remaining = EDITABLE_SLOTS.filter(s => !used.has(s));
        // Fisher–Yates shuffle on the remaining slots.
        for (let i = remaining.length - 1; i > 0; i--) {
          const j = (Math.random() * (i + 1)) | 0;
          [remaining[i], remaining[j]] = [remaining[j], remaining[i]];
        }
        const pairs = FIXED_PAIRS.map(p => p.slice());
        for (let i = 0; i + 1 < remaining.length; i += 2) {
          pairs.push([remaining[i], remaining[i + 1]]);
        }
        return pairs;
      }

      // ----- Dissolve animation ----------------------------------------
      const DISSOLVE_MS = 20000;         // per-swap dissolve window
      const SWAP_INTERVAL_MS = 120000;   // time between swaps for one pair
      const PAIR_STAGGER_MS = 7000;      // cadence between pairs once settled

      // First-swap offset (ms) per pair index. The corner pairs open fast —
      // [0,12] immediately, [5,17] at 2s — then [6,11] at 9s and every pair
      // after it falls into the 7s cadence: 16s, 23s, 30s, …
      function firstSwapDelay(idx) {
        if (idx === 0) return 0;
        if (idx === 1) return 2000;
        return 9000 + (idx - 2) * PAIR_STAGGER_MS;
      }

      // Generation counter lets in-flight timers no-op when animation restarts.
      let animGen = 0;
      let activeIntervals = [];

      function stopAnimations() {
        animGen++;
        activeIntervals.forEach(clearInterval);
        activeIntervals = [];
      }

      // Swap two like-sized grids' colours cell-by-cell over DISSOLVE_MS in a
      // random per-cell order, batched to one repaint per frame (Safari-safe).
      function dissolveSwap(a, b, gen) {
        const total = grids[a].total;   // a and b always share a size
        const order = new Array(total);
        for (let i = 0; i < total; i++) order[i] = i;
        for (let k = total - 1; k > 0; k--) {          // shuffle → cells flip in random order
          const j = (Math.random() * (k + 1)) | 0;
          const t = order[k]; order[k] = order[j]; order[j] = t;
        }
        let cursor = 0, start = 0;
        function frame(now) {
          if (gen !== animGen) return;
          if (!start) start = now;
          const targetCount = Math.min(total, Math.floor(((now - start) / DISSOLVE_MS) * total));
          for (; cursor < targetCount; cursor++) {
            const i = order[cursor];
            const tmp = slotData[a][i];
            slotData[a][i] = slotData[b][i];
            slotData[b][i] = tmp;
            const r = (i / COLS) | 0, c = i % COLS;
            grids[a].cells[r][c].style.background = slotData[a][i] || 'transparent';
            grids[b].cells[r][c].style.background = slotData[b][i] || 'transparent';
          }
          if (cursor < total) requestAnimationFrame(frame);
        }
        requestAnimationFrame(frame);
      }

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

      function startAnimations() {
        if (reduceMotion.matches) return;   // honour Reduce Motion
        const pairs = buildPairs();
        const gen = animGen;
        pairs.forEach((pair, idx) => {
          const startDelay = firstSwapDelay(idx);
          setTimeout(() => {
            if (gen !== animGen) return;
            dissolveSwap(pair[0], pair[1], gen);
            const intervalId = setInterval(() => {
              if (gen !== animGen) { clearInterval(intervalId); return; }
              dissolveSwap(pair[0], pair[1], gen);
            }, SWAP_INTERVAL_MS);
            activeIntervals.push(intervalId);
          }, startDelay);
        });
      }

      // Paint the static art, then start the swap loops.
      renderAll();
      startAnimations();

      // Pause the dissolve loops while the tab is backgrounded — rAF is
      // suspended when hidden but the intervals keep firing, so their queued
      // frames would otherwise burst on return.
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stopAnimations();
        else startAnimations();
      });

      // React to the Reduce Motion preference changing at runtime.
      reduceMotion.addEventListener('change', () => {
        stopAnimations();
        if (!reduceMotion.matches) startAnimations();
      });

      // Proportional scaling: shrink the whole composition when the viewport
      // is narrower than its natural width. Mobile layout (fewer grids) TBD.
      // Composition's natural footprint (6×3 grids). The .stage is an
      // aspect-ratio box; fit the composition inside it (contain) so it scales
      // with the box as the window width changes. Natural size is read from the
      // live .matrix-wrap (offset* is pre-transform), so it tracks the derived
      // CSS geometry automatically — no hardcoded composition dimensions.
      // Target metagrid width as a fraction of the splash width: at a 1280px
      // splash the 6×3 field should span 910px (edge-to-edge of the outer
      // cells), leaving breathing room all round. Tune this single number to
      // make the whole composition larger/smaller within the stage.
      const TARGET_WIDTH_FRAC = 950 / 1280;   // ≈ 0.711
      const matrixWrap = document.querySelector('.matrix-wrap');
      function updateScale() {
        const stage = document.querySelector('.stage');
        if (!stage || !matrixWrap) return;
        const naturalW = matrixWrap.offsetWidth;
        const naturalH = matrixWrap.offsetHeight;
        if (!naturalW || !naturalH) return;
        const cs = getComputedStyle(stage);
        const availW = stage.clientWidth - parseFloat(cs.paddingLeft) - parseFloat(cs.paddingRight);
        const availH = stage.clientHeight - parseFloat(cs.paddingTop) - parseFloat(cs.paddingBottom);
        // Scale to the target fraction of the full splash width, but never
        // exceed what actually fits inside the padded stage (contain).
        const targetScale = (TARGET_WIDTH_FRAC * stage.clientWidth) / naturalW;
        const containScale = Math.min(availW / naturalW, availH / naturalH);
        const scale = Math.max(0, Math.min(targetScale, containScale));
        document.documentElement.style.setProperty('--scale', scale);
      }
      window.addEventListener('resize', updateScale);
      if (window.ResizeObserver) new ResizeObserver(updateScale).observe(document.querySelector('.stage') || document.body);
      updateScale();

      // ----- Legacy splash.json art source -----------------------------
      // The desktop hero no longer uses these — it renders the per-grid files
      // above. They remain ONLY because the (separate, unchanged) mobile hero
      // still reads window.SW.ART_PALETTE and window.SW.loadArt to paint its
      // 12×11 blocks from /assets/pixel_art/splash.json.
      const ART_STORAGE_KEY = 'sw.pixelart.v1';
      const ART_FILE_URL = '/assets/pixel_art/splash.json';
      const ART_PALETTE = [
        '#f6f0ed', '#66223b', '#eb3131', '#00726b', '#004ee6',
        '#a3c0d7', '#64b37b', '#0e676a', '#f45e57', '#ebe5cf',
        '#faf8f6', '#4b5cce', '#440214', '#3a3c7c', '#72679b',
      ];
      function loadArtLocal() {
        try {
          const raw = localStorage.getItem(ART_STORAGE_KEY);
          return raw ? JSON.parse(raw) : null;
        } catch (_) { return null; }
      }
      async function loadArtFile() {
        try {
          const resp = await fetch(ART_FILE_URL, { cache: 'no-cache' });
          if (!resp.ok) return null;
          return await resp.json();
        } catch (_) { return null; }
      }
      async function loadArt() {
        return loadArtLocal() || await loadArtFile();
      }

      // Expose for console tinkering / future modules.
      window.SW = {
        grids, PALETTE, setCell, setAll,
        COLS, ROWS, MATRIX_COLS, MATRIX_ROWS,
        updateScale,
        HERO_SLOTS, EDITABLE_SLOTS,
        slotData, renderAll,
        buildPairs, dissolveSwap,
        stopAnimations, startAnimations,
        // Legacy splash.json source — consumed by the mobile hero.
        ART_PALETTE, loadArt, loadArtLocal, loadArtFile,
      };
    })();

    // ----- Mobile hero: 6 pixel-art blocks (same art as desktop) + swap anim --
    (function () {
      const host = document.querySelector('.mobile-hero');
      if (!host || !window.SW) return;
      const PAL = window.SW.ART_PALETTE;
      const TOTAL = 132, N = 6;

      const blocks = [];
      for (let b = 0; b < N; b++) {
        const el = document.createElement('div');
        el.className = 'mhero-block';
        const cells = [];
        for (let i = 0; i < TOTAL; i++) {
          const cell = document.createElement('div');
          cell.className = 'mhero-cell';
          el.appendChild(cell);
          cells.push(cell);
        }
        host.appendChild(el);
        blocks.push(cells);
      }

      // Per-block live cell data (palette indices), seeded from the art.
      const slotData = Array.from({ length: N }, () => new Array(TOTAL).fill(0));

      function render(art) {
        const grids = (art && art.grids) || [];
        for (let b = 0; b < N; b++) {
          const src = grids[b] || [];
          for (let i = 0; i < TOTAL; i++) {
            slotData[b][i] = src[i] || 0;
            blocks[b][i].style.background = PAL[slotData[b][i]] || PAL[0];
          }
        }
      }

      // ----- Swap animation --------------------------------------------------
      // Block layout (text fills cols 2-3 of rows 2-4):  0 1 2 / 3 / 4 / 5.
      // Fixed pairs per the diagram (1 2 1 / 3 / 2 / 3).
      const FIXED_PAIRS = [[0, 2], [1, 4], [3, 5]];
      const DISSOLVE_MS = 12000;       // each swap dissolves over 12s
      const PAUSE_MS = 7500;           // pause after a swap before it loops
      const SWAP_INTERVAL_MS = DISSOLVE_MS + PAUSE_MS;   // 19.5s loop period per pair
      const PAIR_OFFSETS_MS = [0, 1500, 7500];           // each pair's start offset from load

      let animGen = 0, intervals = [];
      function stop() { animGen++; intervals.forEach(clearInterval); intervals = []; }

      function dissolveSwap(a, b, gen) {
        const order = new Array(TOTAL);
        for (let i = 0; i < TOTAL; i++) order[i] = i;
        for (let k = TOTAL - 1; k > 0; k--) {          // shuffle → cells flip in random order
          const j = (Math.random() * (k + 1)) | 0;
          const t = order[k]; order[k] = order[j]; order[j] = t;
        }
        // One rAF loop: batch all cells due this frame → one repaint per frame.
        let cursor = 0, start = 0;
        function frame(now) {
          if (gen !== animGen) return;
          if (!start) start = now;
          const targetCount = Math.min(TOTAL, Math.floor(((now - start) / DISSOLVE_MS) * TOTAL));
          for (; cursor < targetCount; cursor++) {
            const i = order[cursor];
            const tmp = slotData[a][i];
            slotData[a][i] = slotData[b][i];
            slotData[b][i] = tmp;
            blocks[a][i].style.background = PAL[slotData[a][i]] || PAL[0];
            blocks[b][i].style.background = PAL[slotData[b][i]] || PAL[0];
          }
          if (cursor < TOTAL) requestAnimationFrame(frame);
        }
        requestAnimationFrame(frame);
      }

      function start() {
        stop();
        const gen = animGen;
        FIXED_PAIRS.forEach((pair, idx) => {
          setTimeout(() => {
            if (gen !== animGen) return;
            dissolveSwap(pair[0], pair[1], gen);
            const id = setInterval(() => {
              if (gen !== animGen) { clearInterval(id); return; }
              dissolveSwap(pair[0], pair[1], gen);
            }, SWAP_INTERVAL_MS);
            intervals.push(id);
          }, PAIR_OFFSETS_MS[idx] || 0);
        });
      }

      // Only animate when the mobile hero is visible; respect reduced-motion.
      const mqMobile = window.matchMedia('(max-width: 600px)');
      const mqMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      // Animate only when visible, on a mobile viewport, and motion is allowed —
      // the visibility check stops the backgrounded-tab "catch-up" burst.
      function sync() { (!document.hidden && mqMobile.matches && !mqMotion.matches) ? start() : stop(); }
      mqMobile.addEventListener('change', sync);
      mqMotion.addEventListener('change', sync);
      document.addEventListener('visibilitychange', sync);

      window.SW.loadArt().then((art) => { render(art); sync(); });
    })();

    // ----- Spotlight cards: fill each right panel with a whole-cell dot grid -
    (function () {
      const panels = document.querySelectorAll('.project-img-cells, .infocus-pix, .report-card-pix');
      if (!panels.length) return;

      function fill(el) {
        const cs = getComputedStyle(el);
        const cols = parseInt(cs.getPropertyValue('--card-pix-cols'), 10) || 11;
        const cell = parseFloat(cs.getPropertyValue('--card-pix-cell')) || 10;
        const gap  = parseFloat(cs.getPropertyValue('--card-pix-gap'))  || 3;
        const fixedRows = parseInt(cs.getPropertyValue('--card-pix-rows'), 10);
        // Fixed row count if declared; otherwise fit whole rows to the height
        // (last partial cell dropped, never sliced).
        const rows = fixedRows > 0
          ? fixedRows
          : Math.max(0, Math.floor((el.clientHeight + gap) / (cell + gap)));
        const need = rows * cols;
        let have = el.childElementCount;
        if (have === need) return;
        while (el.childElementCount > need) el.removeChild(el.lastChild);
        if (have < need) {
          const frag = document.createDocumentFragment();
          for (let i = have; i < need; i++) {
            const c = document.createElement('div');
            c.className = 'pix-cell';
            frag.appendChild(c);
          }
          el.appendChild(frag);
        }
      }

      // Re-fill whenever a panel's height changes (font load, reflow, resize).
      const ro = new ResizeObserver(function (entries) {
        for (const e of entries) fill(e.target);
      });
      panels.forEach(function (el) { fill(el); ro.observe(el); });
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function () { panels.forEach(fill); });
      }
    })();

    // ----- Latest reports carousel: arrow controls + drag-to-scroll ------
    (function () {
      const track = document.querySelector('.carousel-track');
      if (!track) return;
      const prev = document.querySelector('.carousel-arrow[data-dir="-1"]');
      const next = document.querySelector('.carousel-arrow[data-dir="1"]');

      function stepWidth() {
        const card = track.querySelector('.report-card');
        return card ? card.getBoundingClientRect().width + 20 : 320;
      }
      function updateArrows() {
        // Tolerance band: scroll-snap + the track's 2px padding leave "home" a
        // few px off 0 (and likewise at the far end), so an exact test misses.
        // 8px is comfortably under a card width, so it never misfires mid-scroll.
        const EDGE = 8;
        const max = track.scrollWidth - track.clientWidth;
        if (prev) prev.disabled = track.scrollLeft <= EDGE;
        if (next) next.disabled = track.scrollLeft >= max - EDGE;
      }
      if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -stepWidth(), behavior: 'smooth' }); });
      if (next) next.addEventListener('click', function () { track.scrollBy({ left: stepWidth(), behavior: 'smooth' }); });
      track.addEventListener('scroll', updateArrows, { passive: true });
      window.addEventListener('resize', updateArrows);
      window.addEventListener('load', updateArrows);
      // Re-check once card images load and reflow the track width.
      if (window.ResizeObserver) new ResizeObserver(updateArrows).observe(track);
      updateArrows();

      // Drag / swipe to scroll.
      let down = false, startX = 0, startLeft = 0, moved = false;
      track.addEventListener('pointerdown', function (e) {
        if (e.pointerType !== 'mouse') return;   // touch/pen use native scroll (no manual drag)
        down = true; moved = false;
        startX = e.clientX; startLeft = track.scrollLeft;
      });
      track.addEventListener('pointermove', function (e) {
        if (!down) return;
        const dx = e.clientX - startX;
        // Only start a real drag — and capture the pointer — once we cross the
        // threshold. Capturing on pointerdown would retarget the trailing click
        // to the track, so a plain click never reached the card's <a> overlay.
        if (!moved && Math.abs(dx) > 4) {
          moved = true;
          track.classList.add('dragging');
          track.setPointerCapture(e.pointerId);
        }
        if (moved) track.scrollLeft = startLeft - dx;
      });
      function release() { down = false; track.classList.remove('dragging'); }
      track.addEventListener('pointerup', release);
      track.addEventListener('pointercancel', release);
      // Suppress the click that follows a drag so cards don't navigate.
      track.addEventListener('click', function (e) {
        if (moved) { e.preventDefault(); e.stopPropagation(); }
      }, true);
    })();

    // ----- Intro matrix: colour the 7x2 decorative grid from a motif ----
    (function () {
      const grid = document.querySelector('.intro-matrix');
      if (!grid) return;
      const MOTIF = '1335513' + '5122403';   // 7 cols x 2 rows, row-major
      const COLOURS = {
        '0': 'var(--almost-white)',
        '1': 'var(--beige)',
        '2': 'var(--bright-blue)',
        '3': 'var(--theme)',
        '4': 'var(--pale-blue)',
        '5': 'var(--coral)',
      };
      const spans = grid.children;
      const base = [];
      for (let i = 0; i < spans.length; i++) {
        const c = (i < MOTIF.length && COLOURS[MOTIF[i]]) || 'var(--border-grey)';
        spans[i].style.background = c;
        base[i] = c;
      }

      // Gentle, occasional life: one cell at a time mostly goes hollow or
      // transparent for a moment; rarely one changes colour. CSS transitions
      // smooth every change. Pauses when hidden; off under reduced-motion.
      const mqMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const PALETTE = ['var(--beige)', 'var(--bright-blue)', 'var(--theme)', 'var(--pale-blue)', 'var(--coral)', 'var(--sage)'];
      const rand = function (a, b) { return a + Math.random() * (b - a); };
      let calmTimer = 0, active = false;

      function revert(i) {
        spans[i].style.background = base[i];
        spans[i].style.boxShadow = 'inset 0 0 0 0 transparent';
      }
      function applyEffect(i) {
        const r = Math.random();
        if (r < 0.45) {                 // hollow ring
          spans[i].style.background = 'transparent';
          spans[i].style.boxShadow = 'inset 0 0 0 2px ' + base[i];
        } else if (r < 0.85) {          // briefly transparent
          spans[i].style.background = 'transparent';
        } else {                        // rare colour change
          spans[i].style.background = PALETTE[(Math.random() * PALETTE.length) | 0];
        }
      }
      function act() {
        const i = (Math.random() * spans.length) | 0;
        applyEffect(i);
        setTimeout(function () { revert(i); }, rand(1400, 3000));
        schedule();
      }
      function schedule() {
        clearTimeout(calmTimer);
        calmTimer = setTimeout(act, rand(2600, 6500));
      }
      function start() { if (!active) { active = true; schedule(); } }
      function stop() {
        active = false;
        clearTimeout(calmTimer);
        for (let i = 0; i < spans.length; i++) revert(i);
      }
      function sync() { (!document.hidden && !mqMotion.matches) ? start() : stop(); }

      mqMotion.addEventListener('change', sync);
      document.addEventListener('visibilitychange', sync);
      sync();
    })();
</script>

<script is:inline>
    // Subtle falling pixel "rain" in the empty band to the right of the project
    // cards. Desktop only; respects reduced-motion; pauses when hidden/off-screen.
    (function () {
      const canvas = document.querySelector('.spotlight-rain');
      if (!canvas || !canvas.getContext) return;
      const ctx = canvas.getContext('2d');

      // Muted theme colours, rendered at low alpha so the effect stays quiet.
      const css = getComputedStyle(document.documentElement);
      const palette = ['--pale-blue', '--sage', '--border-grey', '--deep-green', '--theme']
        .map(function (v) { return css.getPropertyValue(v).trim(); })
        .filter(Boolean);
      const SIZES = [4, 5, 6, 7], RADIUS = 0.5;   // one spread for ALL drops; RADIUS 0 = perfectly square

      let W = 0, H = 0, drops = [], raf = 0, running = false, onScreen = true;
      const rand = function (a, b) { return a + Math.random() * (b - a); };

      function makeDrop(fromTop) {
        const hollow = Math.random() < 0.4;                     // ~40% are outlines, like the SIF cells
        const pick = function () { return SIZES[(Math.random() * SIZES.length) | 0]; };
        const size = hollow ? Math.max(pick(), pick())          // outlines skew larger so they still read
                            : pick();
        const amp = rand(1.5, 4);   // sway amplitude — inset x by it so drops stay in-band
        return {
          x: rand(amp, Math.max(amp + 1, W - size - amp)),
          y: fromTop ? -size : rand(0, H),
          size: size,
          speed: rand(0.12, 0.45),        // slow = rain-like and subtle
          alpha: Math.random() < 0.6 ? 1 : rand(0.5, 1),   // mostly full, never below 0.5
          color: palette[(Math.random() * palette.length) | 0] || '#888',
          hollow: hollow,
          // Smoothed sideways drift: small sine sway tied to vertical position.
          amp: amp,
          freq: rand(0.010, 0.024),
          phase: rand(0, Math.PI * 2),
        };
      }
      function build() {
        const n = Math.max(6, Math.min(26, Math.round(H / 48)));
        drops = [];
        for (let i = 0; i < n; i++) drops.push(makeDrop(false));
      }
      // Height runs from the top of the column down to the top of card 3.
      function targetHeight() {
        const main = canvas.parentElement;
        const cards = main ? main.querySelectorAll('.project') : [];
        if (cards.length >= 3 && cards[2].offsetTop > 0) return cards[2].offsetTop;
        return main ? main.clientHeight : (canvas.clientHeight || 1);
      }
      function resize() {
        canvas.style.height = targetHeight() + 'px';
        const r = canvas.getBoundingClientRect();
        W = Math.max(1, r.width);
        H = Math.max(1, r.height);
        const dpr = window.devicePixelRatio || 1;
        canvas.width = Math.round(W * dpr);
        canvas.height = Math.round(H * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        build();
      }
      function roundRect(x, y, w, h, r) {
        ctx.beginPath();
        ctx.moveTo(x + r, y);
        ctx.arcTo(x + w, y, x + w, y + h, r);
        ctx.arcTo(x + w, y + h, x, y + h, r);
        ctx.arcTo(x, y + h, x, y, r);
        ctx.arcTo(x, y, x + w, y, r);
        ctx.closePath();
      }
      function draw() {
        ctx.clearRect(0, 0, W, H);
        for (let i = 0; i < drops.length; i++) {
          const d = drops[i];
          ctx.globalAlpha = d.alpha;
          const sway = Math.sin(d.y * d.freq + d.phase) * d.amp;
          if (d.hollow) {
            roundRect(d.x + sway, d.y, d.size, d.size, RADIUS);
            ctx.lineWidth = 2;
            ctx.strokeStyle = d.color;
            ctx.stroke();
          } else {
            roundRect(d.x + sway, d.y, d.size, d.size, RADIUS);
            ctx.fillStyle = d.color;
            ctx.fill();
          }
        }
        ctx.globalAlpha = 1;
      }
      function tick() {
        for (let i = 0; i < drops.length; i++) {
          const d = drops[i];
          d.y += d.speed;
          if (d.y > H + d.size) drops[i] = makeDrop(true);
        }
        draw();
        raf = requestAnimationFrame(tick);
      }
      function start() {
        if (running) return;
        running = true;
        if (!W || !H) resize();
        raf = requestAnimationFrame(tick);
      }
      function stop() {
        running = false;
        if (raf) cancelAnimationFrame(raf);
        raf = 0;
      }

      const mqDesktop = window.matchMedia('(min-width: 901px)');
      const mqMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      function sync() {
        (!document.hidden && onScreen && mqDesktop.matches && !mqMotion.matches) ? start() : stop();
      }

      if ('IntersectionObserver' in window) {
        new IntersectionObserver(function (entries) {
          onScreen = entries[0].isIntersecting;
          sync();
        }, { threshold: 0 }).observe(canvas);
      }
      window.addEventListener('resize', function () { if (mqDesktop.matches) resize(); });
      mqDesktop.addEventListener('change', sync);
      mqMotion.addEventListener('change', sync);
      document.addEventListener('visibilitychange', sync);

      if (mqDesktop.matches) resize();
      sync();
      // Card heights can shift once webfonts load — re-measure the target height.
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function () { if (mqDesktop.matches) resize(); });
      }
    })();
</script>
</BaseLayout>
